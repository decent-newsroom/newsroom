<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Chat{% endblock %} — {{ community.name }}</title>
    <link rel="stylesheet" href="{{ asset('styles/04-pages/chat.css') }}">
    {% block head %}{% endblock %}
</head>
<body class="chat-app">
    <nav class="chat-nav">
        <a href="/groups" class="chat-nav__brand">{{ community.name }}</a>
        <div class="chat-nav__links">
            <a href="/groups">Groups</a>
            <a href="/contacts">Contacts</a>
            <a href="/profile">Profile</a>
        </div>
    </nav>

    <main class="chat-main">
        {% if vapidPublicKey is defined and vapidPublicKey %}
        <div data-controller="chat--push"
             data-chat--push-vapid-key-value="{{ vapidPublicKey }}"
             data-chat--push-subscribe-url-value="/push/subscribe"
             data-chat--push-unsubscribe-url-value="/push/unsubscribe">
            <div data-chat--push-target="prompt" class="chat-push-prompt" style="display:none;">
                <span>Enable notifications to know when new messages arrive</span>
                <button data-action="chat--push#requestPermission" class="btn btn--small">Enable</button>
                <button data-action="chat--push#dismissPrompt" class="btn btn--small btn--muted">Not now</button>
            </div>
        </div>
        {% endif %}

        {% for flash in app.flashes('success') %}
            <div class="chat-flash chat-flash--success">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('error') %}
            <div class="chat-flash chat-flash--error">{{ flash }}</div>
        {% endfor %}

        {% block body %}{% endblock %}
    </main>
</body>
</html>

