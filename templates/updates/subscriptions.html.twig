{% extends 'layout.html.twig' %}
{% block title %}{{ 'updates.subscriptionsTitle'|trans }}{% endblock %}
{% block body %}
<div class="w-container py-4">
    <twig:Atoms:PageHeading
        heading="{{ 'updates.subscriptionsTitle'|trans }}"
        tagline="{{ 'updates.subscriptionsTagline'|trans }}" />

    <p>
        <a href="{{ path('updates_index') }}">← {{ 'updates.backToCenter'|trans }}</a>
    </p>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="notice {{ label }}">{{ message|trans }}</div>
        {% endfor %}
    {% endfor %}

    {# Tier status banner #}
    {% if isPro %}
        <div class="notice success mb-3" style="max-width: 600px;">
            <strong>Updates Pro</strong> active — unlimited subscriptions of all source types.
            {% if proSubscription and proSubscription.expiresAt %}
                Expires {{ proSubscription.expiresAt|date('F j, Y') }}.
            {% endif %}
        </div>
    {% else %}
        <div class="notice info mb-3" style="max-width: 600px;">
            Free plan: {{ currentCount }}/{{ freeCap }} subscriptions used. NIP-51 set subscriptions require
            <a href="{{ path('updates_pro_index') }}">Updates Pro</a>.
        </div>
    {% endif %}

    <form method="post" action="{{ path('updates_subscriptions_add') }}" class="mb-4">
        <input type="hidden" name="_token" value="{{ csrf_token('update-subscribe') }}" />
        <label for="identifier">{{ 'updates.subscription.addLabel'|trans }}</label>
        <input type="text" id="identifier" name="identifier"
               placeholder="{{ 'updates.subscription.addPlaceholder'|trans }}"
               autocomplete="off"
               required />
        <div class="actions">
            <button type="submit" class="btn">{{ 'updates.subscription.addSubmit'|trans }}</button>
        </div>
    </form>

    {% if subscriptions is empty %}
        <p class="text-muted">{{ 'updates.subscriptions.empty'|trans }}</p>
    {% else %}
        <ul class="subscription-list">
            {% for s in subscriptions %}
                <li class="subscription-item">
                    <div>
                        <span class="subscription-item__type">{{ s.sourceType.label|trans }}</span>
                        {% if s.sourceType.value == 'npub' %}
                            <span class="subscription-item__value"><twig:Molecules:UserFromNpub ident="{{ s.sourceValue }}" /></span>
                        {% elseif s.sourceType.value == 'publication' %}
                            <span class="subscription-item__value">{{ coordinateTitles[s.sourceValue] ?? (s.sourceValue|split(':')|last) }}</span>
                        {% else %}
                            <span class="subscription-item__value">{{ s.label ?: (s.sourceValue|split(':')|last) }}</span>
                        {% endif %}
                    </div>
                    <form method="post" action="{{ path('updates_subscriptions_remove', {id: s.id}) }}"
                          onsubmit="return confirm('{{ 'updates.subscription.removeConfirm'|trans }}');">
                        <input type="hidden" name="_token" value="{{ csrf_token('update-unsubscribe') }}" />
                        <button type="submit" class="btn btn-sm">{{ 'updates.subscription.remove'|trans }}</button>
                    </form>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}

