{% extends 'newsroom-layout.html.twig' %}

{% set articlePrototype %}
    <div class="reading-list-article__body">
        <span class="reading-list-article__icon" aria-hidden="true">
            {{ ux_icon('iconoir:journal-page', {class: 'icon'}) }}
        </span>
        <div class="reading-list-article__content">
            <div class="article-preview-container">
                <span class="reading-list-article__loading">{{ 'reading_list_editor.article.loading'|trans }}</span>
            </div>
            <label class="visually-hidden" for="{{ form.articles.vars.prototype.vars.id }}">
                {{ 'reading_list_editor.article.coordinate_label'|trans }}
            </label>
            {{ form_widget(form.articles.vars.prototype, {
                attr: {
                    class: 'reading-list-article__coordinate',
                    placeholder: 'reading_list_editor.article.placeholder'|trans,
                    'data-ui--article-preview-input-target': 'input',
                    'data-publishing--reading-list-workspace-target': 'articleInput',
                    'data-action': 'input->publishing--reading-list-workspace#sync change->ui--article-preview-input#onInputChange blur->ui--article-preview-input#onInputChange'
                }
            }) }}
        </div>
        <button
            type="button"
            class="reading-list-article__remove"
            data-action="ui--form-collection#removeCollectionElement"
            title="{{ 'reading_list_editor.article.remove'|trans }}"
        >
            {{ ux_icon('iconoir:trash', {class: 'icon'}) }}
            <span class="visually-hidden">{{ 'reading_list_editor.article.remove'|trans }}</span>
        </button>
    </div>
{% endset %}

{% block body %}
<section
    class="reading-list-editor"
    data-controller="publishing--reading-list-workspace nostr--nostr-single-sign"
    data-publishing--reading-list-workspace-event-value="{{ eventJson|e('html_attr') }}"
    data-publishing--reading-list-workspace-invalid-message-value="{{ 'reading_list_editor.article.invalid'|trans }}"
    data-nostr--nostr-single-sign-event-value="{{ eventJson|e('html_attr') }}"
    data-nostr--nostr-single-sign-publish-url-value="{{ path('api-index-publish') }}"
    data-nostr--nostr-single-sign-csrf-token-value="{{ csrfToken }}"
>
    <header class="reading-list-editor__header">
        <div class="reading-list-editor__header-copy">
            <p class="eyebrow">
                {{ (isMagazineCategory ? 'reading_list_editor.category_eyebrow' : 'reading_list_editor.eyebrow')|trans }}
            </p>
            <h1>{{ draft.title }}</h1>
            <p>{{ draft.summary ?: 'reading_list_editor.description'|trans }}</p>
            <code>{{ draft.slug }}</code>
        </div>
        <div class="reading-list-editor__header-actions">
            <a class="btn btn--secondary" href="{{ path('read_wizard_setup') }}">
                {{ ux_icon('iconoir:edit-pencil', {class: 'icon'}) }}
                {{ 'reading_list_editor.action.edit_details'|trans }}
            </a>
            <a class="btn btn--secondary" href="{{ path('read_wizard_cancel') }}">
                {{ 'reading_list_editor.action.cancel'|trans }}
            </a>
        </div>
    </header>

    {% if saved %}
        <div class="notice success" role="status">
            <p>{{ 'reading_list_editor.saved'|trans }}</p>
        </div>
    {% endif %}

    <div class="reading-list-editor__section-heading">
        <div>
            <p class="eyebrow">{{ 'reading_list_editor.articles.eyebrow'|trans }}</p>
            <h2>{{ 'reading_list_editor.articles.title'|trans }}</h2>
        </div>
        <p>{{ 'reading_list_editor.articles.description'|trans }}</p>
    </div>

    {{ form_start(form, {
        attr: {
            class: 'reading-list-editor__form',
            'data-turbo': 'false'
        }
    }) }}
        {{ form_row(form.title, {row_attr: {class: 'hidden'}}) }}

        <div
            class="reading-list-editor__collection"
            data-controller="ui--form-collection ui--article-preview-input"
            data-ui--article-preview-input-url-value="{{ path('api_article_preview') }}"
            data-ui--article-preview-input-loading-message-value="{{ 'reading_list_editor.article.loading'|trans }}"
            data-ui--article-preview-input-unknown-author-message-value="{{ 'reading_list_editor.article.unknown_author'|trans }}"
            data-ui--article-preview-input-not-found-message-value="{{ 'reading_list_editor.article.not_found'|trans }}"
            data-ui--article-preview-input-load-error-message-value="{{ 'reading_list_editor.article.load_error'|trans }}"
            data-ui--form-collection-index-value="{{ form.articles|length > 0 ? form.articles|last.vars.name + 1 : 0 }}"
            data-ui--form-collection-prototype-value="{{ articlePrototype|e('html_attr') }}"
        >
            <div class="reading-list-editor__columns" aria-hidden="true">
                <span>{{ 'reading_list_editor.article.column_article'|trans }}</span>
                <span>&nbsp;</span> {# actions #}
            </div>

            <ul
                id="aCollection"
                class="reading-list-editor__articles"
                data-ui--form-collection-target="collectionContainer"
            >
                {% for item in form.articles %}
                    <li class="reading-list-article">
                        <div class="reading-list-article__body">
                            <span class="reading-list-article__icon" aria-hidden="true">
                                {{ ux_icon('iconoir:journal-page', {class: 'icon'}) }}
                            </span>
                            <div class="reading-list-article__content">
                                <div class="article-preview-container">
                                    <span class="reading-list-article__loading">{{ 'reading_list_editor.article.loading'|trans }}</span>
                                </div>
                                <label class="visually-hidden" for="{{ item.vars.id }}">
                                    {{ 'reading_list_editor.article.coordinate_label'|trans }}
                                </label>
                                {{ form_widget(item, {
                                    attr: {
                                        class: 'reading-list-article__coordinate',
                                        placeholder: 'reading_list_editor.article.placeholder'|trans,
                                        'data-ui--article-preview-input-target': 'input',
                                        'data-publishing--reading-list-workspace-target': 'articleInput',
                                        'data-action': 'input->publishing--reading-list-workspace#sync change->ui--article-preview-input#onInputChange blur->ui--article-preview-input#onInputChange'
                                    }
                                }) }}
                            </div>
                            <button
                                type="button"
                                class="reading-list-article__remove"
                                data-action="ui--form-collection#removeCollectionElement"
                                title="{{ 'reading_list_editor.article.remove'|trans }}"
                            >
                                {{ ux_icon('iconoir:trash', {class: 'icon'}) }}
                                <span class="visually-hidden">{{ 'reading_list_editor.article.remove'|trans }}</span>
                            </button>
                        </div>
                    </li>
                {% endfor %}
            </ul>

            {{ form_errors(form.articles) }}

            <div class="reading-list-editor__collection-actions">
                <button
                    type="button"
                    class="btn btn--secondary"
                    data-action="ui--form-collection#addCollectionElement"
                >
                    {{ ux_icon('iconoir:plus', {class: 'icon'}) }}
                    {{ 'reading_list_editor.action.add_article'|trans }}
                </button>
                <div class="reading-list-editor__draft-action">
                    <button
                        class="btn btn--secondary"
                        type="submit"
                        aria-describedby="reading-list-draft-storage-notice"
                    >
                        {{ ux_icon('iconoir:check', {class: 'icon'}) }}
                        {{ 'reading_list_editor.action.save_draft'|trans }}
                    </button>
                    <p
                        id="reading-list-draft-storage-notice"
                        class="reading-list-editor__draft-storage-notice"
                    >
                        {{ 'reading_list_editor.draft_storage_notice'|trans }}
                    </p>
                </div>
            </div>
        </div>
    {{ form_end(form) }}

    <section class="reading-list-editor__publish">
        <div class="reading-list-editor__publish-copy">
            <p class="eyebrow">{{ 'reading_list_editor.publish.eyebrow'|trans }}</p>
            <h2>{{ 'reading_list_editor.publish.title'|trans }}</h2>
            <p>{{ 'reading_list_editor.publish.description'|trans }}</p>
            {% if not is_granted('ROLE_USER') %}
                <p class="reading-list-editor__login-note">{{ 'reading_list_editor.publish.login_required'|trans }}</p>
            {% endif %}
            <p
                class="reading-list-editor__validation"
                data-publishing--reading-list-workspace-target="validation"
                role="status"
                hidden
            ></p>
            <div data-nostr--nostr-single-sign-target="status"></div>
        </div>
        <button
            type="button"
            class="btn reading-list-editor__publish-button"
            data-publishing--reading-list-workspace-target="publishButton"
            data-nostr--nostr-single-sign-target="publishButton"
            data-action="click->nostr--nostr-single-sign#signAndPublish"
        >
            {{ ux_icon('iconoir:arrow-right', {class: 'icon'}) }}
            {{ 'reading_list_editor.action.sign_publish'|trans }}
        </button>
    </section>

    <details class="reading-list-editor__event-preview">
        <summary>{{ 'reading_list_editor.publish.event_preview'|trans }}</summary>
        <pre data-nostr--nostr-single-sign-target="computedPreview"></pre>
    </details>
</section>
{% endblock %}
