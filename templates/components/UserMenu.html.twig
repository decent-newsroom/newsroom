<div {{ attributes }}>
  <div data-controller="utility--login utility--signer-modal">
    {% if app.user %}
        <div class="notice info">
            <twig:Molecules:UserFromNpub ident="{{ app.user.npub }}" />
            {% if is_granted('ROLE_ADMIN') %}<span class="badge">{{ 'auth.admin'|trans }}</span>{% endif %}
        </div>
        {% if is_granted('ROLE_ADMIN') %}
        <ul class="user-nav">
            <li><a href="{{ path('admin_dashboard') }}"><strong>{{ 'auth.adminDashboard'|trans }}</strong></a></li>
            <li><a href="{{ path('admin_magazines') }}">{{ 'auth.magazines'|trans }}</a></li>
            <li><a href="{{ path('admin_analytics') }}">{{ 'auth.visitAnalytics'|trans }}</a></li>
        </ul>
        {% elseif is_granted('ROLE_RSS') %}
        <ul class="user-nav">
            <li><a href="{{ path('admin_rss_index') }}">{{ 'auth.rssImport'|trans }}</a></li>
        </ul>
        {% endif %}
        <ul class="user-nav">
            <li><a href="{{ path('settings') }}">{{ 'nav.settings'|trans }}</a></li>
            <li>
                <a href="/logout"
                   data-controller="nostr--logout"
                   data-action="click->nostr--logout#handleLogout">{{ 'heading.logout'|trans }}</a>
            </li>
        </ul>
    {% else %}
        <div class="nav-section">
            <div class="nav-section__label">{{ 'heading.logIn'|trans }}</div>
            <ul class="user-nav">
                <li>
                    <div data-utility--login-target="nostrError" class="nostr-error-message" style="display:none;color:#b00;margin-bottom:0.5em;"></div>
                    <twig:Atoms:Button {{ ...stimulus_action('utility--login', 'loginAct') }} tag="a" class="btn-sm">{{ 'auth.extension'|trans }}</twig:Atoms:Button>
                </li>
                <li>
                    <twig:Atoms:Button {{ ...stimulus_action('utility--signer-modal', 'openDialog') }} tag="a" class="btn-sm">{{ 'auth.signer'|trans }}</twig:Atoms:Button>
                </li>
            </ul>
        </div>
        <twig:SignerModal />
    {% endif %}
  </div>
</div>
