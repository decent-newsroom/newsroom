<div {{ attributes }}>
  <div>
    {% if app.user %}
        <div class="notice info">
            {% if app.user.npub %}
                <twig:Molecules:UserFromNpub ident="{{ app.user.npub }}" />
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}<span class="badge">{{ 'auth.admin'|trans }}</span>{% endif %}
        </div>
        {% if is_granted('ROLE_ADMIN') %}
        <ul class="user-nav">
            <li><a href="{{ path('admin_dashboard') }}"><strong>{{ 'auth.adminDashboard'|trans }}</strong></a></li>
            <li><a href="{{ path('admin_magazines') }}">{{ 'auth.magazines'|trans }}</a></li>
            <li><a href="{{ path('admin_analytics') }}">{{ 'auth.visitAnalytics'|trans }}</a></li>
        </ul>
        {% elseif is_granted('ROLE_RSS') %}
        <ul class="user-nav">
            <li><a href="{{ path('admin_rss_index') }}">{{ 'auth.rssImport'|trans }}</a></li>
        </ul>
        {% endif %}
        <ul class="user-nav">
            {% if is_granted('ROLE_ESSAYIST_MEMBER') %}
                <li><a href="{{ path('app_essayist_home') }}">{{ 'essayist.home.title'|trans }}</a></li>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <li><a href="{{ path('updates_index') }}">{{ 'updates.pageTitle'|trans }}</a></li>
                <li><a href="{{ path('profile_stats') }}">{{ 'nav.myStats'|trans }}</a></li>
            {% endif %}
            <li>
                <a href="/logout"
                   data-controller="nostr--logout"
                   data-action="click->nostr--logout#handleLogout">{{ 'heading.logout'|trans }}</a>
            </li>
        </ul>
    {% else %}
        <div class="nav-section" data-controller="utility--login-modal">
            <div class="nav-section__label">{{ 'heading.logIn'|trans }}</div>
            <ul class="user-nav">
                <li>
                    <twig:Atoms:Button {{ ...stimulus_action('utility--login-modal', 'openDialog') }} tag="a" class="btn-sm">{{ 'auth.login'|trans }}</twig:Atoms:Button>
                </li>
            </ul>
            <twig:LoginModal />
        </div>
    {% endif %}
  </div>
</div>
