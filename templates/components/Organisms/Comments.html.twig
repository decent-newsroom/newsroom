<div
    {{ attributes
        .add(stimulus_controller('content--comments-mercure', { coordinate: current }))
        .add(stimulus_target('content--comments-mercure', 'loading'))
        .add(stimulus_target('content--comments-mercure', 'list'))
    }}
    class="comments"
>

    {% if loading %}
        <div class="comments-loading" data-content--comments-mercure-target="loading">{{ 'comments.loading'|trans }}</div>
    {% endif %}
    <div class="comments-list" data-content--comments-mercure-target="list" {% if loading %}style="display:none"{% endif %}>
        {% for item in list %}
            <div class="card comment {% if item.kind is defined and item.kind == '9735' %}zap-comment{% endif %}">
                <div class="metadata">
                    {% if item.kind != '9735' %}
                        <twig:Molecules:UserFromNpub ident="{{ item.pubkey }}" :user="authorsMetadata[item.pubkey]" />
                    {% elseif zappers[item.id] %}
                        <twig:Molecules:UserFromNpub ident="{{ zappers[item.id]  }}" :user="authorsMetadata[zappers[item.id]]" />
                    {% else %}
                        <p><em>{{ 'text.unknown'|trans }}</em></p>
                    {% endif %}
                    <small>{{ item.created_at|date('F j Y') }}</small>
                </div>

                {# Replying to names from p-tags #}
                {% if replyingTo[item.id] is defined and replyingTo[item.id]|length > 0 %}
                    <div class="comment-replying-to">
                        <small>{{ 'comments.replyingTo'|trans }} {{ replyingTo[item.id]|join(', ') }}</small>
                    </div>
                {% endif %}

                {# Parent comment one-line preview #}
                {% if parentPreview[item.id] is defined %}
                    <div class="comment-parent-preview">
                        <small>
                            {% set parentMeta = authorsMetadata[parentPreview[item.id].pubkey] ?? null %}
                            {% set parentName = parentMeta ? (parentMeta.display_name ?? parentMeta.name ?? parentPreview[item.id].pubkey[:8] ~ '…') : parentPreview[item.id].pubkey[:8] ~ '…' %}
                            <span class="comment-parent-preview__author">{{ parentName }}:</span>
                            <span class="comment-parent-preview__text">{{ parentPreview[item.id].content }}</span>
                        </small>
                    </div>
                {% endif %}

                <div class="card-body">
                    {% if item.kind is defined and item.kind == '9735' %}
                        <div class="zap-amount">
                            {% if zapAmounts[item.id] is defined %}
                                <strong>{{ zapAmounts[item.id] }} sat</strong>
                            {% else %}
                                <em>{{ 'comments.zap'|trans }}</em>
                            {% endif %}
                        </div>
                    {% endif %}
                    <twig:Atoms:Content content="{{ item.content }}" />
                </div>

                {# Reply-to-comment form (NIP-22): keeps the original root, overrides parent to this comment #}
                {% if rootContext and replyPublishUrl and item.kind != '9735' and item.id is defined %}
                    {% set replyAuthor = authorsMetadata[item.pubkey] ?? null %}
                    {% set replyName = replyAuthor ? (replyAuthor.display_name ?? replyAuthor.name ?? item.pubkey[:8] ~ '…') : item.pubkey[:8] ~ '…' %}
                    <details class="comment-reply-toggle">
                        <summary class="comment-reply-toggle__cta">{{ 'comments.replyTo'|trans({'%name%': replyName}) }}</summary>
                        <twig:Organisms:CommentForm
                            :publish_url="replyPublishUrl"
                            :csrf_token="replyCsrfToken"
                            :root_context="rootContext"
                            :parent_context="{
                                tag: 'e',
                                value: item.id,
                                relay: null,
                                pubkey: item.pubkey,
                                kind: 1111
                            }"
                            :form_id="'reply_' ~ item.id" />
                    </details>
                {% endif %}
            </div>
        {% else %}
            <div class="no-comments">{{ 'comments.noComments'|trans }}</div>
        {% endfor %}
    </div>

</div>
