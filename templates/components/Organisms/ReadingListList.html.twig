<div {{ attributes }}>
  {% set items = this.lists %}
  {% if items is not empty %}
      {% for item in items %}
      <div class="card p-3 ln-section--reader">
          {% if item.image|default(null) %}
              {% if item.kind == 30040 %}
                  <div class="card-header m-0">
                      <a href="{{ path('reading-list', { slug: item.slug, npub: item.pubkey|toNpub }) }}">
                          <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
                      </a>
                  </div>
              {% else %}
                  <div class="card-header m-0">
                      <a href="{{ path('curation-set', { kind: item.kind, slug: item.slug, npub: item.pubkey|toNpub }) }}">
                          <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
                      </a>
                  </div>
              {% endif %}
          {% endif %}
          <div class="card-body text-center">
          {% if item.kind == 30040 %}
              <h2 class="card-title"><a href="{{ path('reading-list', { slug: item.slug, npub: item.pubkey|toNpub }) }}">{{ item.title }}</a></h2>
          {% else %}
              <h2 class="card-title"><a href="{{ path('curation-set', { kind: item.kind, slug: item.slug, npub: item.pubkey|toNpub }) }}">{{ item.title }}</a></h2>
          {% endif %}
          {% if item.summary is defined and item.summary %}
              <p class="eyebrow">{{ item.summary }}</p>
          {% endif %}
          <div class="d-flex flex-row gap-2 align-items-center justify-content-center">
              <span class="badge bg-secondary">{{ item.type }}</span>
              <span class="badge bg-info text-dark">{{ item.itemCount }} item{{ item.itemCount != 1 ? 's' : '' }}</span>
          </div>
          <p>by
              {% if item.author is defined and item.author %}
                  {{ item.author }}
              {% else %}
                  <twig:Molecules:UserFromNpub :ident="item.pubkey" />
              {% endif %}
          </p>
          </div>
      </div>
      {% endfor %}
  {% else %}
    <p><small>No reading lists yet.</small></p>
  {% endif %}
</div>
