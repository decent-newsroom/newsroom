<div {{ attributes }}>
    {% if error and parsedPubkey and parsedSlug %}
        {# Article not found – show fetch placeholder #}
        <twig:Molecules:CardPlaceholder :item="{
            kind: parsedKind,
            pubkey: parsedPubkey,
            slug: parsedSlug,
            coordinate: coordinate
        }" />
    {% elseif error %}
        {# Parse error – show simple message #}
        <div class="alert alert-info">{{ error }}</div>
    {% elseif article %}
        {# Render the article card #}
        <twig:Molecules:Card
            :article="article"
            :authors_metadata="authorsMetadata"
            :mag="mag"
            :cat="cat"
        />
    {% endif %}
</div>
