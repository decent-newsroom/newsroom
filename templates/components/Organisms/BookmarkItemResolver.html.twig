<div {{ attributes }}>
    {% if type == 'a' %}
        <div class="bookmark-item-container d-flex justify-content-between align-items-start gap-2">
            <div class="flex-grow-1">
                <twig:Organisms:ArticleFromCoordinate :coordinate="value" />
            </div>
            <button
                class="btn btn-sm btn-outline-danger flex-shrink-0"
                title="{{ 'bookmark.remove'|trans }}"
                data-action="live#action"
                data-live-action-param="removeBookmark"
                data-live-value-param="{{ value|json_encode }}"
            >
                ?
            </button>
        </div>
    {% elseif type == 'e' %}
        <div class="bookmark-item-container d-flex justify-content-between align-items-start gap-2">
            <div class="flex-grow-1">
                {% if event %}
                    {% include 'partial/_bookmark_event_card.html.twig' with {event: event} %}
                {% elseif error %}
                    <div class="bookmark-item-entry text-muted">
                        <span class="tag">e</span> - {{ error }}
                    </div>
                {% else %}
                    <div class="bookmark-item-entry">
                        <span class="tag">e</span>
                        <span class="text-muted">{{ value|slice(0, 16) }}...</span>
                        <button
                            class="btn btn-sm btn-outline-primary ms-2"
                            data-action="live#action"
                            data-live-action-param="fetchEvent"
                        >
                            Fetch
                        </button>
                    </div>
                {% endif %}
            </div>
            <button
                class="btn btn-sm btn-outline-danger flex-shrink-0"
                title="{{ 'bookmark.remove'|trans }}"
                data-action="live#action"
                data-live-action-param="removeBookmark"
                data-live-value-param="{{ value|json_encode }}"
            >
                ?
            </button>
        </div>
    {% elseif type == 'p' %}
        <div class="bookmark-item-container d-flex justify-content-between align-items-start gap-2">
            <div class="flex-grow-1">
                <div class="bookmark-item-entry">
                    <twig:Molecules:UserFromNpub ident="{{ value|toNpub }}" />
                </div>
            </div>
            <button
                class="btn btn-sm btn-outline-danger flex-shrink-0"
                title="{{ 'bookmark.remove'|trans }}"
                data-action="live#action"
                data-live-action-param="removeBookmark"
                data-live-value-param="{{ value|json_encode }}"
            >
                ?
            </button>
        </div>
    {% elseif type == 't' %}
        <div class="bookmark-item-container d-flex justify-content-between align-items-start gap-2">
            <div class="flex-grow-1">
                <div class="bookmark-item-entry">
                    <a class="tag" href="{{ path('forum_tag', {tag: value}) }}">{{ value }}</a>
                </div>
            </div>
            <button
                class="btn btn-sm btn-outline-danger flex-shrink-0"
                title="{{ 'bookmark.remove'|trans }}"
                data-action="live#action"
                data-live-action-param="removeBookmark"
                data-live-value-param="{{ value|json_encode }}"
            >
                ?
            </button>
        </div>
    {% else %}
        <div class="bookmark-item-container d-flex justify-content-between align-items-start gap-2">
            <div class="flex-grow-1">
                <div class="bookmark-item-entry text-muted">
                    <span class="tag">{{ type }}</span> - {{ value }}
                </div>
            </div>
            <button
                class="btn btn-sm btn-outline-danger flex-shrink-0"
                title="{{ 'bookmark.remove'|trans }}"
                data-action="live#action"
                data-live-action-param="removeBookmark"
                data-live-value-param="{{ value|json_encode }}"
            >
                ?
            </button>
        </div>
    {% endif %}
</div>
