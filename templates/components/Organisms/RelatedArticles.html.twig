{% if articles|length > 0 %}
<section class="w-container related-articles" aria-label="{{ 'article.relatedArticles'|trans }}">
    <p class="related-articles__heading">
        {% if fromInterests %}
            {{ 'article.relatedFromInterests'|trans }}
        {% else %}
            {{ 'article.relatedArticles'|trans }}
        {% endif %}
    </p>
    {% for article in articles %}
        <twig:Molecules:Card :article="article" />
    {% endfor %}
</section>
{% endif %}
