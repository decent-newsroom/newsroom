<nav {{ attributes.defaults({id: 'leftNav', class: 'app-sidebar'}) }}>
    <div class="app-sidebar__mobile-header">
        <button
            type="button"
            class="icon-button"
            data-action="click->ui--sidebar-toggle#close"
            aria-label="{{ 'nav.closeLeftSidebar'|trans }}"
        >
            {{ ux_icon('iconoir:xmark', {class: 'icon'}) }}
        </button>
    </div>

    {% if backLink %}
        <div class="sidebar-nav__back">
            <a href="{{ path(backLink.route) }}">
                {% if backLink.icon|default(null) %}
                    {{ ux_icon(backLink.icon, {class: 'icon'}) }}
                {% endif %}
                {{ backLink.label|trans }}
            </a>
        </div>
    {% endif %}

    {% for section in sections %}
        <div class="nav-section">
            {% if section.label %}
                <div class="nav-section__label">{{ section.label|trans }}</div>
            {% endif %}
            <ul class="user-nav">
                {% for item in section.items %}
                    <li>
                        <a
                            href="{{ path(item.route) }}"
                            {% if app.current_route == item.route %}aria-current="page"{% endif %}
                        >
                            {% if item.icon|default(null) %}
                                {{ ux_icon(item.icon, {class: 'icon'}) }}
                            {% endif %}
                            <span>{{ item.label|trans }}</span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endfor %}

    {% if footerComponent %}
        <div class="app-sidebar__footer">
            {{ include(footerComponent) }}
        </div>
    {% endif %}
</nav>
