<div data-utility--signer-modal-target="dialog" class="iu-dialog" style="display:none;">
  <div class="iu-backdrop" data-action="click->utility--signer-modal#closeDialog"></div>
  <div class="iu-modal">
    <div class="modal-header">
      <h5>{{ 'signerModal.title'|trans }}</h5>
      <button type="button" class="close" data-action="click->utility--signer-modal#closeDialog">&times;</button>
    </div>
    <div class="modal-body">
        <div>
            <h5 class="mt-0">{{ 'signerModal.status'|trans }}:</h5>
            <div data-utility--signer-modal-target="status" class="small text-muted">{{ 'signerModal.initializing'|trans }}</div>
            <p class="small text-muted mb-1 hidden">{{ 'signerModal.afterPairing'|trans }}</p>
            <p class="small text-muted hidden">{{ 'signerModal.stallHint'|trans }}</p>
        </div>
        <div>
          <h5>Pair with signer:</h5>
          <p class="text-muted mb-3">Scan the QR code or copy the connection string.</p>
          <div class="text-center mb-3">
              <div data-utility--signer-modal-target="qr" class="mb-2"></div>
          </div>
          <div class="mt-3">
              <label for="signer-modal-uri-input" class="small text-muted mb-2 d-block hidden">Connection string:</label>
              <div class="input-group input-group-sm d-flex flex-row">
                  <input type="text"
                         id="signer-modal-uri-input"
                         class="form-control font-monospace small"
                         data-utility--signer-modal-target="uriInput"
                         readonly
                         placeholder="Loading...">
                  <button class="btn"
                          type="button"
                          data-action="click->utility--signer-modal#copyUri"
                          data-utility--signer-modal-target="copyButton">
                      {{ 'signerModal.copy'|trans }}
                  </button>
              </div>
              <p class="small text-muted mt-1 mb-0">{{ 'signerModal.pasteHint'|trans }}</p>
          </div>
        </div>
        {# Bunker reconnect — for users who already have an active session #}
        <div class="mb-4">
            <h5>Reconnect:</h5>
            <p class="text-muted mb-3">{{ 'signerModal.bunkerLabel'|trans }}</p>

            <label for="signer-modal-bunker-input" class="small fw-bold d-block mb-1 hidden">Connection string:</label>
            <div class="input-group input-group-sm d-flex flex-row">
                <input type="text"
                       id="signer-modal-bunker-input"
                       class="form-control font-monospace small"
                       data-utility--signer-modal-target="bunkerInput"
                       placeholder="bunker://...">
                <button class="btn"
                        type="button"
                        data-action="click->utility--signer-modal#connectBunker">
                    {{ 'signerModal.connect'|trans }}
                </button>
            </div>
            <p class="small text-muted mt-1 mb-0">{{ 'signerModal.bunkerHint'|trans }}</p>
        </div>
    </div>
  </div>
</div>

