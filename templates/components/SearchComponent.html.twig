<div {{ attributes }}>
        {% if interactive %}
        <form
            class="mb-5"
            data-controller="search--nostr-redirect"
            data-live-action-param="search"
            data-action="submit->search--nostr-redirect#submit live#action:prevent">
            <label class="search">
                <input type="search"
                       placeholder="{{ 'text.search'|trans }}"
                       data-model="norender|query"
                       value="{{ this.query }}"
                       data-controller="search--search-broadcast"
                       data-action="input->search--search-broadcast#onInput"
                       data-search--nostr-redirect-target="input"
                />
                <button type="submit"><twig:ux:icon name="iconoir:search" class="icon" /></button>
            </label>
        </form>

        {# ── Advanced Filters Toggle ────────────────────────────── #}
        <div class="advanced-filters"
             data-controller="search--advanced-filters">

            <button type="button"
                    class="advanced-filters__toggle"
                    data-action="live#action"
                    data-live-action-param="toggleFilters">
                <twig:ux:icon name="iconoir:filter" class="icon" />
                {{ 'search.filters.toggle'|trans }}
                {% if this.hasActiveFilters %}
                    <span class="advanced-filters__badge">●</span>
                {% endif %}
            </button>

            {% if this.showFilters %}
            <div class="advanced-filters__panel">
                <div class="advanced-filters__grid">
                    {# Date range #}
                    <div class="advanced-filters__field">
                        <label for="filter-date-from">{{ 'search.filters.dateFrom'|trans }}</label>
                        <input type="date"
                               id="filter-date-from"
                               data-model="filterDateFrom"
                               value="{{ this.filterDateFrom }}" />
                    </div>
                    <div class="advanced-filters__field">
                        <label for="filter-date-to">{{ 'search.filters.dateTo'|trans }}</label>
                        <input type="date"
                               id="filter-date-to"
                               data-model="filterDateTo"
                               value="{{ this.filterDateTo }}" />
                    </div>

                    {# Author #}
                    <div class="advanced-filters__field advanced-filters__field--wide">
                        <label for="filter-author">{{ 'search.filters.author'|trans }}</label>
                        <input type="text"
                               id="filter-author"
                               data-model="filterAuthor"
                               value="{{ this.filterAuthor }}"
                               placeholder="{{ 'search.filters.authorPlaceholder'|trans }}" />
                    </div>

                    {# Tags #}
                    <div class="advanced-filters__field advanced-filters__field--wide">
                        <label for="filter-tags">{{ 'search.filters.tags'|trans }}</label>
                        <input type="text"
                               id="filter-tags"
                               data-model="filterTags"
                               value="{{ this.filterTags }}"
                               placeholder="{{ 'search.filters.tagsPlaceholder'|trans }}" />
                    </div>

                    {# Sort #}
                    <div class="advanced-filters__field">
                        <label for="filter-sort">{{ 'search.filters.sortBy'|trans }}</label>
                        <select id="filter-sort"
                                data-model="filterSort">
                            <option value="relevance" {{ this.filterSort == 'relevance' ? 'selected' : '' }}>{{ 'search.filters.sortRelevance'|trans }}</option>
                            <option value="newest" {{ this.filterSort == 'newest' ? 'selected' : '' }}>{{ 'search.filters.sortNewest'|trans }}</option>
                            <option value="oldest" {{ this.filterSort == 'oldest' ? 'selected' : '' }}>{{ 'search.filters.sortOldest'|trans }}</option>
                        </select>
                    </div>
                </div>

                <div class="advanced-filters__actions">
                    <button type="button"
                            class="btn btn-sm btn-primary"
                            data-action="live#action"
                            data-live-action-param="search">
                        {{ 'search.filters.apply'|trans }}
                    </button>
                    <button type="button"
                            class="btn btn-sm"
                            data-action="live#action"
                            data-live-action-param="clearFilters">
                        {{ 'search.filters.clear'|trans }}
                    </button>
                </div>
            </div>
            {% endif %}
        </div>

        <p class="advanced-filters__user-hint">
            <small>{{ 'search.filters.userSearchHint'|trans({'%url%': path('users_search_page', {q: this.query})})|raw }}</small>
        </p>

        <!-- Loading Indicator -->
            <div class="search-loading">
                <div class="spinner" data-loading>
                    <div class="lds-dual-ring"></div>
                </div>
            </div>
        {% endif %}

        <!-- Results -->
        {% if this.results is not empty %}
            {% if this.selectMode %}
                <div class="article-list">
                    <ul class="list-unstyled d-grid gap-2">
                        {% for art in this.results %}
                            {% if art.slug is not empty and art.title is not empty %}
                                {% set artKind = art.kind ? art.kind.value : 30023 %}
                                {% set coordinate = artKind ~ ':' ~ art.pubkey ~ ':' ~ art.slug %}
                                <li class="card p-3">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div class="flex-fill">
                                            <div class="metadata">
                                                <small>by <twig:Molecules:UserFromNpub ident="{{ art.pubkey }}" user="{{ authors[art.pubkey] }}" /></small>
                                                <small class="ms-2">{{ art.createdAt|date('F j Y') }}</small>
                                            </div>
                                            <a href="{{ path('article-slug', {slug: art.slug}) }}" data-turbo-frame="_top"><h3 class="h5 m-0">{{ art.title }}</h3></a>
                                            {% if art.summary %}<p class="mt-2 small line-clamp-5">{{ art.summary }}</p>{% endif %}
                                            <code class="small text-muted">{{ coordinate }}</code>
                                        </div>
                                        <div>
                                            <button
                                                class="btn btn-sm btn-primary"
                                                data-action="live#action"
                                                data-live-action-param="addToReadingList"
                                                data-live-coordinate-param="{{ coordinate }}"
                                            >{{ 'search.addToList'|trans }}</button>
                                        </div>
                                    </div>
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
            {% else %}
                <twig:Organisms:CardList :list="this.results" class="article-list" />
            {% endif %}
        {% elseif this.query is not empty or this.hasActiveFilters %}
            <p><small>{{ 'text.noResults'|trans }}</small></p>
        {% endif %}
</div>
