{% if article is defined %}
    <div class="card{% if isEmbed is defined and isEmbed %} embed{% endif %}">
        <div class="metadata">
            {% if not is_author_profile|default(false) and app.current_route != 'latest_articles' %}
                {% set pubkey = article.pubkey %}
                {% set user = authors_metadata|default([])[pubkey] ?? null %}
                <p class="m-0">by <twig:Molecules:UserFromNpub :user="user" :ident="pubkey" /></p>
            {% endif %}
            {# Show published date; if article has been edited (created_at ≠ published_at), show edit indicator #}
            {% set displayDate = (article.publishedAt is not null) ? article.publishedAt : article.createdAt %}
            {% set isEdited = article.publishedAt is not null and article.createdAt is not null and article.publishedAt|date('U') != article.createdAt|date('U') %}
            <small>{{ displayDate|date('F j Y') }}</small>
            {% if isEdited %}
                <small class="article-edited-note" title="{{ 'text.edited'|trans }}: {{ article.createdAt|date('F j, Y') }}">· {{ 'text.edited'|trans }} {{ article.createdAt|date('M j, Y') }}</small>
            {% endif %}
        </div>
        {% if article.kind == 30024 %}
            {# Draft - use draft route #}
            {% set link = path('author-draft-slug', {npub: article.pubkey|toNpub, slug: article.slug|url_encode }) %}
        {% else %}
            {# Regular article #}
            {% set link = path('author-article-slug', {npub: article.pubkey|toNpub, slug: article.slug|url_encode }) %}

            {% if cat  and mag %}
                {% set link = path('magazine-category-article', {slug: article.slug|url_encode, cat: cat, mag: mag}) %}
            {% endif %}
        {% endif %}
        <a href="{{ link }}" data-turbo-frame="_top">
            <div class="card-header">
                {% if article.image %}
                    <img src="{{ article.image }}" alt="{{ 'card.coverImageAlt'|trans({'%title%': article.title}) }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" >
                    <div class="card-placeholder-bg" style="display:none; background-color: hsl({{ (article.slug|default(article.title))|pastelHue }}, 70%, 85%);"></div>
                {% else %}
                    <div class="card-placeholder-bg" style="background-color: hsl({{ (article.slug|default(article.title))|pastelHue }}, 70%, 85%);"></div>
                {% endif %}
            </div>
            {% if source_labels|default([])|length > 0 or category_label|default(null) %}
                <div class="card-sources">
                    {% if category_label|default(null) %}
                        <span class="source-badge source-badge--category">{{ category_label }}</span>
                    {% endif %}
                    {% for label in source_labels|default([]) %}
                        <span class="source-badge source-badge--{{ label }}">{{ ('home_feed.source.' ~ label)|trans }}</span>
                    {% endfor %}
                </div>
            {% endif %}
            <div class="card-body">
                    <h2 class="card-title line-clamp-5">{{ article.title }}</h2>
                    {% if article.summary %}
                        <p class="lede line-clamp-5" data-controller="utility--katex" data-utility--katex-display-value="false">
                            {{ article.summary }}
                        </p>
                    {% endif %}
            </div>
        </a>
        <div class="card-footer">
            {% if comment_count|default(0) > 0 %}
                <div class="card-footer__comments">
                    <span>{{ 'home_feed.discussed.commentCount'|trans({'%count%': comment_count}) }}</span>
                </div>
            {% endif %}
        </div>
    </div>
{% endif %}
