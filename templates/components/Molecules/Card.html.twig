{% if article is defined %}
    {% set itemNaddr = attribute(article, 'naddr', [], 'any', true) ? attribute(article, 'naddr') : null %}
    {% set articleKind = article.kind.value|default(article.kind|default(30023)) %}
    {% set bookmarkCoordinate = (article.slug is defined and article.slug and article.pubkey is defined and article.pubkey) ? articleKind ~ ':' ~ article.pubkey ~ ':' ~ article.slug : null %}

    {% if articleKind == 30817 and cat and mag %}
        {% set link = path('magazine-category-wiki', {slug: article.slug, cat: cat, mag: mag}) %}
    {% elseif itemNaddr %}
        {% set link = path('nevent', {nevent: itemNaddr}) %}
    {% elseif articleKind == 30024 %}
        {% set link = path('author-draft-slug', {npub: article.pubkey|toNpub, slug: article.slug}) %}
    {% else %}
        {% set link = path('author-article-slug', {npub: article.pubkey|toNpub, slug: article.slug}) %}
        {% if cat and mag %}
            {% set link = path('magazine-category-article', {slug: article.slug, cat: cat, mag: mag}) %}
        {% endif %}
    {% endif %}

    {% set displayDate = article.publishedAt is not null ? article.publishedAt : article.createdAt %}
    {% set isEdited = article.publishedAt is not null and article.createdAt is not null and article.publishedAt|date('U') != article.createdAt|date('U') %}
    {% set isEssayistExclusive = article.essayistExclusive|default(false) %}

    <article
        class="card article-card{% if isEmbed|default(false) %} embed{% endif %}{% if not article.image %} article-card--text-only{% endif %}"
        data-article-id="{{ article.id }}"
        data-uuid="{{ article.id }}"
        data-coordinate="{{ articleKind }}:{{ article.pubkey }}:{{ article.slug }}"
        data-npub="{{ article.pubkey|toNpub }}"
    >
        <div class="article-card__body">
            <div class="article-card__content">
                <div class="metadata">
                    {% if not is_author_profile|default(false) and app.current_route != 'latest_articles' %}
                        {% set pubkey = article.pubkey %}
                        {% set user = authors_metadata|default([])[pubkey] ?? null %}
                        <span>{{ 'text.by'|trans }} <twig:Molecules:UserFromNpub :user="user" :ident="pubkey" /></span>
                    {% endif %}
                    <span>
                        <time datetime="{{ displayDate|date('c') }}">{{ displayDate|date('M j, Y') }}</time>
                        {% if isEdited %}
                            <span class="article-edited-note" title="{{ 'text.edited'|trans }}: {{ article.createdAt|date('F j, Y') }}">· {{ 'text.edited'|trans }}</span>
                        {% endif %}
                    </span>
                </div>

                <h2 class="card-title line-clamp-5">
                    <a class="article-card__title-link" href="{{ link }}" data-turbo-frame="_top">{{ article.title }}</a>
                </h2>
                {% if article.summary %}
                    <p class="lede line-clamp-5" data-controller="utility--katex" data-utility--katex-display-value="false">
                        {{ article.summary }}
                    </p>
                {% endif %}
            </div>

            {% if article.image %}
                <figure class="article-card__media">
                    <img
                        src="{{ article.image }}"
                        alt="{{ 'card.coverImageAlt'|trans({'%title%': article.title}) }}"
                        loading="lazy"
                        decoding="async"
                    >
                </figure>
            {% endif %}
        </div>

        <div class="card-footer">
            {% if source_labels|default([])|length > 0 or category_label|default(null) or isEssayistExclusive %}
                {% if category_label|default(null) %}
                    <span class="source-badge source-badge--category">{{ category_label }}</span>
                {% endif %}
                {% if isEssayistExclusive %}
                    <span class="source-badge source-badge--essayist" title="{{ 'home_feed.source.essayist_title'|trans }}">{{ 'home_feed.source.essayist'|trans }}</span>
                {% endif %}
                {% for label in source_labels|default([]) %}
                    <span class="source-badge source-badge--{{ label }}">{{ ('home_feed.source.' ~ label)|trans }}</span>
                {% endfor %}
            {% endif %}
            {% if comment_count|default(0) > 0 %}
                <span>{{ 'home_feed.discussed.commentCount'|trans({'%count%': comment_count}) }}</span>
            {% endif %}
            {% if app.user and bookmarkCoordinate %}
                <button
                    type="button"
                    class="card-bookmark-btn"
                    data-controller="ui--card-bookmark"
                    data-ui--card-bookmark-target="button"
                    data-action="click->ui--card-bookmark#toggle"
                    data-ui--card-bookmark-coordinate-value="{{ bookmarkCoordinate }}"
                    data-ui--card-bookmark-bookmark-fetch-url-value="{{ path('api_bookmarks_current') }}"
                    data-ui--card-bookmark-bookmark-publish-url-value="{{ path('api_bookmarks_publish') }}"
                    data-ui--card-bookmark-add-label-value="{{ 'bookmark.add'|trans|e('html_attr') }}"
                    data-ui--card-bookmark-remove-label-value="{{ 'bookmark.remove'|trans|e('html_attr') }}"
                    title="{{ 'bookmark.add'|trans }}"
                >
                    {{ ux_icon('iconoir:bookmark', {class: 'icon', 'data-ui--card-bookmark-target': 'icon'}) }}
                    <span data-ui--card-bookmark-target="label">{{ 'bookmark.add'|trans }}</span>
                </button>
            {% endif %}
        </div>
    </article>
{% endif %}
