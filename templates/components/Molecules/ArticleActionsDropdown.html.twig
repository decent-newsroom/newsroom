{% set dropdownAttributes = attributes.without(
    'article',
    'coordinate',
    'canonicalUrl',
    'naddrEncoded',
    'isProtected',
    'relays'
).defaults({class: 'article-actions-dropdown'}) %}

<div {{ dropdownAttributes }}
     data-controller="ui--article-actions-dropdown"
     data-ui--article-actions-dropdown-coordinate-value="{{ coordinate }}">
    <div class="dropdown">
        <button class="btn article-actions-trigger"
                type="button"
                data-ui--article-actions-dropdown-target="trigger"
                data-action="click->ui--article-actions-dropdown#toggle"
                aria-haspopup="true"
                aria-expanded="false"
                title="{{ 'articleActions.more'|trans }}">
            {{ ux_icon('iconoir:more-vert', {class: 'icon', 'aria-hidden': 'true'}) }}
            <span class="visually-hidden">{{ 'articleActions.more'|trans }}</span>
        </button>

        <div class="dropdown-menu dropdown-menu-end"
             data-ui--article-actions-dropdown-target="menu">
            <div class="dropdown-header">{{ 'articleActions.nostrIdentifiers'|trans }}</div>

            <button class="dropdown-item"
                    type="button"
                    data-action="click->ui--article-actions-dropdown#copy"
                    data-copy="{{ naddrEncoded|e('html_attr') }}">
                {{ ux_icon('iconoir:copy', {class: 'icon action-icon', 'aria-hidden': 'true'}) }}
                {{ 'articleActions.copyNaddr'|trans }}
            </button>

            <button class="dropdown-item"
                    type="button"
                    data-action="click->ui--article-actions-dropdown#copy"
                    data-copy="{{ coordinate|e('html_attr') }}">
                {{ ux_icon('iconoir:copy', {class: 'icon action-icon', 'aria-hidden': 'true'}) }}
                {{ 'articleActions.copyCoordinate'|trans }}
            </button>

            {% if app.user %}
                {% set canBroadcast = not isProtected or this.isAuthorOfArticle() %}
                {% if canBroadcast %}
                    <hr class="dropdown-divider">
                    <button class="dropdown-item"
                            type="button"
                            data-ui--article-actions-dropdown-target="broadcastItem"
                            data-action="click->ui--article-actions-dropdown#broadcast"
                            data-article-id="{{ article.id }}"
                            data-coordinate="{{ coordinate }}"
                            {% if relays is not null %}
                            data-relays="{{ relays|json_encode|e('html_attr') }}"
                            {% endif %}>
                        {{ ux_icon('iconoir:rss-feed', {class: 'icon action-icon', 'aria-hidden': 'true'}) }}
                        {{ 'articleActions.broadcast'|trans }}
                        {% if isProtected %}
                            <span class="badge-protected" title="{{ 'articleActions.protectedNote'|trans }}">{{ 'articleActions.protectedShort'|trans }}</span>
                        {% endif %}
                    </button>
                {% endif %}

                {% if essayist_relay_url is defined and essayist_relay_url
                    and (is_granted('ROLE_ESSAYIST_MEMBER') or is_granted('ROLE_ADMIN'))
                    and (not isProtected or this.isAuthorOfArticle()) %}
                    <button class="dropdown-item"
                            type="button"
                            data-action="click->ui--article-actions-dropdown#broadcastEssayist"
                            data-article-id="{{ article.id }}"
                            data-coordinate="{{ coordinate }}"
                            data-relays="{{ [essayist_relay_url]|json_encode|e('html_attr') }}"
                            data-target-label="Essayist"
                            title="{{ 'articleActions.broadcastEssayistTitle'|trans }}">
                        {{ ux_icon('iconoir:book-stack', {class: 'icon action-icon', 'aria-hidden': 'true'}) }}
                        {{ 'articleActions.broadcastEssayist'|trans }}
                        {% if not is_granted('ROLE_ESSAYIST_MEMBER') and is_granted('ROLE_ADMIN') %}
                            <small class="badge-admin">{{ 'articleActions.adminOnly'|trans }}</small>
                        {% endif %}
                    </button>
                {% endif %}
            {% endif %}
        </div>
    </div>
</div>
