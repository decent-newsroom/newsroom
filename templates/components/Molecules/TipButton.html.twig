<div {{ attributes.defaults({class: 'tip-button-component d-inline'}) }}>
    {% set targets = this.targets %}

    {# Only render the trigger if at least one payment target exists. #}
    {% if targets|length > 0 %}
        <button
            type="button"
            class="btn tip-trigger {{ btnClass|default('') }}"
            data-action="live#action"
            data-live-action-param="openDialog"
            title="{{ 'tip.send'|trans }}"
        >
            <span class="tip-trigger__label">{{ 'tip.button'|trans }}</span>
        </button>
    {% endif %}

    {% if this.open %}
        <div class="zap-modal-overlay" data-action="click->live#action" data-live-action-param="closeDialog">
            <div class="zap-modal-content card shadow-lg" onclick="event.stopPropagation()">
                <div class="card-body">
                    <div class="d-flex flex-row justify-content-between align-items-center mb-3">
                        <div>
                            <h5 class="m-0">{{ 'tip.send'|trans }}</h5>
                            {% if recipientPubkey %}
                                <small class="text-muted">to <twig:Molecules:UserFromNpub :ident="recipientPubkey"/></small>
                            {% endif %}
                        </div>
                        <button
                            type="button"
                            class="btn btn-secondary"
                            data-action="live#action"
                            data-live-action-param="closeDialog"
                        >{{ 'tip.close'|trans }}</button>
                    </div>

                    {# Phase: select payment method #}
                    {% if this.phase == 'select' %}
                        <p class="text-muted small mb-3">{{ 'tip.choose'|trans }}</p>
                        {% for group in this.targetGroups %}
                            <section class="tip-target-group">
                                <div class="tip-target-group__heading">
                                    {% if group.symbol %}<span class="tip-target-group__symbol">{{ group.symbol }}</span>{% endif %}
                                    <strong class="tip-target-group__label">{{ group.label }}</strong>
                                    <span class="badge bg-secondary">{{ group.targets|length }}</span>
                                    {% if not group.recognized %}
                                        <span class="badge bg-secondary">{{ 'tip.unknown'|trans }}</span>
                                    {% endif %}
                                </div>

                                <ul class="list-unstyled tip-target-list tip-target-group__list">
                                    {% for target in group.targets %}
                                        <li class="tip-target-list__item">
                                            {% if target.type == 'geyser' %}
                                                <a
                                                    class="tip-target-list__btn tip-target-list__btn--link d-flex flex-row align-items-center justify-content-between"
                                                    href="{{ target.href }}"
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                >
                                                    <span class="tip-target-list__authority font-monospace text-truncate">{{ target.authority }}</span>
                                                    <span class="text-muted small ms-3">Open in Geyser Fund</span>
                                                </a>
                                            {% else %}
                                                <button
                                                    type="button"
                                                    class="tip-target-list__btn d-flex flex-row align-items-center justify-content-between"
                                                    data-action="live#action"
                                                    data-live-action-param="selectTarget"
                                                    data-live-target-key-param="{{ target.key }}"
                                                >
                                                    <span class="tip-target-list__authority text-muted small font-monospace text-truncate">{{ target.authority }}</span>
                                                    <span class="tip-target-list__meta text-muted small ms-3">{{ target.shortLabel }}</span>
                                                </button>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                </ul>
                            </section>
                        {% endfor %}
                    {% endif %}

                    {# Phase: loading targets #}
                    {% if this.phase == 'targets_loading' %}
                        <button
                            type="button"
                            class="hidden"
                            data-controller="utility--live-action-on-connect"
                            data-action="live#action"
                            data-live-action-param="loadTargets"
                        ></button>
                        <div class="text-center py-4">
                            <div class="spinner-border text-warning mb-3" role="status">
                                <span class="visually-hidden hidden">Loading...</span>
                            </div>
                            <p class="text-muted small mb-0">{{ 'tip.loadingTargets'|trans }}</p>
                        </div>
                    {% endif %}

                    {# Phase: lightning amount/comment input #}
                    {% if this.phase == 'lightning_input' %}
                        <form data-action="submit->live#action:prevent" data-live-action-param="createLightningInvoice">
                            <div class="alert alert-info mb-3">
                                <strong>{{ 'tip.method.lightning'|trans }}</strong>
                                {% set selected = this.selectedTarget %}
                                <div class="small font-monospace">{{ selected ? selected.authority : '' }}</div>
                            </div>
                            <div class="mb-3">
                                <label for="tip-amount" class="form-label">{{ 'tip.amount'|trans }}</label>
                                <input
                                    type="number"
                                    id="tip-amount"
                                    class="form-control"
                                    min="1"
                                    step="1"
                                    data-model="debounce(300)|amount"
                                    value="{{ amount }}"
                                    required
                                    autofocus
                                />
                                <div class="d-flex flex-row gap-2 mt-2">
                                    {% for preset in [21, 100, 1000, 21000] %}
                                        <button
                                            type="button"
                                            class="btn btn-sm flex-fill"
                                            onclick="document.getElementById('tip-amount').value = {{ preset }}; document.getElementById('tip-amount').dispatchEvent(new Event('input', { bubbles: true }));"
                                        >{{ preset >= 1000 ? (preset // 1000) ~ 'k' : preset }}</button>
                                    {% endfor %}
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="tip-comment" class="form-label">{{ 'tip.note'|trans }}</label>
                                <textarea
                                    id="tip-comment"
                                    class="form-control"
                                    rows="2"
                                    data-model="norender|comment"
                                    placeholder="{{ 'tip.notePlaceholder'|trans }}"
                                >{{ comment }}</textarea>
                            </div>

                            <div class="d-flex gap-2">
                                <button
                                    type="button"
                                    class="btn btn-secondary"
                                    data-action="live#action"
                                    data-live-action-param="backToSelect"
                                >← {{ 'tip.back'|trans }}</button>
                                <button type="submit" class="btn btn-warning flex-fill">
                                    {{ 'tip.createInvoice'|trans }}
                                </button>
                            </div>
                        </form>
                    {% endif %}

                    {# Phase: loading #}
                    {% if this.phase == 'loading' %}
                        <div class="text-center py-4">
                            <div class="spinner-border text-warning mb-3" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="text-muted">{{ 'tip.creatingInvoice'|trans }}</p>
                        </div>
                    {% endif %}

                    {# Phase: lightning invoice ready #}
                    {% if this.phase == 'invoice' %}
                        <div class="text-center mb-3">
                            <p class="text-success mb-2">✓ {{ 'tip.invoiceReady'|trans }}</p>
                            <p class="text-muted small">{{ 'tip.scanWithWallet'|trans }}</p>
                        </div>

                        <div class="qr-container text-center mb-3">
                            {{ qrSvg|raw }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">BOLT11</label>
                            <div class="d-flex flex-row input-group input-group-sm">
                                <input
                                    type="text"
                                    class="form-control font-monospace small"
                                    value="{{ bolt11 }}"
                                    readonly
                                    onclick="this.select()"
                                />
                                <button
                                    class="btn btn-outline-secondary"
                                    type="button"
                                    onclick="navigator.clipboard.writeText('{{ bolt11|e('js') }}'); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 2000)"
                                >Copy</button>
                            </div>
                        </div>

                        <div class="text-center mb-3">
                            <a href="lightning:{{ bolt11|upper }}" class="btn btn-warning w-100">
                                ⚡ {{ 'tip.openInWallet'|trans }}
                            </a>
                        </div>

                        <button
                            type="button"
                            class="btn btn-sm btn-outline-secondary w-100"
                            data-action="live#action"
                            data-live-action-param="backToSelect"
                        >← {{ 'tip.choosePaymentMethod'|trans }}</button>
                    {% endif %}

                    {# Phase: non-lightning payto target (generic) #}
                    {% if this.phase == 'payto' %}
                        {% set selected = this.selectedTarget %}
                        <div class="alert alert-info mb-3">
                            <strong>
                                {% if selected.symbol %}<span class="me-1">{{ selected.symbol }}</span>{% endif %}
                                {{ selected.label }}
                            </strong>
                            {% if not selected.recognized %}
                                <div class="small">{{ 'tip.unknownTypeHint'|trans }}</div>
                            {% endif %}
                        </div>

                        <div class="text-center mb-3">
                            <p class="text-muted small mb-2">{{ 'tip.scanOrOpen'|trans }}</p>
                            <div class="qr-container text-center mb-3">
                                {{ paytoQrSvg|raw }}
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">{{ 'tip.address'|trans }}</label>
                            <div class="d-flex flex-row input-group input-group-sm">
                                <input
                                    type="text"
                                    class="form-control font-monospace small"
                                    value="{{ selected.authority }}"
                                    readonly
                                    onclick="this.select()"
                                />
                                <button
                                    class="btn btn-outline-secondary"
                                    type="button"
                                    onclick="navigator.clipboard.writeText('{{ selected.authority|e('js') }}'); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 2000)"
                                >Copy</button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">payto URI</label>
                            <div class="d-flex flex-row input-group input-group-sm">
                                <input
                                    type="text"
                                    class="form-control font-monospace small"
                                    value="{{ selected.href }}"
                                    readonly
                                    onclick="this.select()"
                                />
                                <button
                                    class="btn btn-outline-secondary"
                                    type="button"
                                    onclick="navigator.clipboard.writeText('{{ selected.href|e('js') }}'); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 2000)"
                                >Copy</button>
                            </div>
                        </div>

                        <div class="text-center mb-3">
                            <a href="{{ selected.href }}" class="btn btn-primary" rel="noopener">
                                {{ 'tip.openInPaymentApp'|trans }}
                            </a>
                        </div>

                        <button
                            type="button"
                            class="btn btn-sm btn-secondary"
                            data-action="live#action"
                            data-live-action-param="backToSelect"
                        >← {{ 'tip.choosePaymentMethod'|trans }}</button>
                    {% endif %}

                    {# Phase: error #}
                    {% if this.phase == 'error' %}
                        <div class="alert alert-danger mb-3">
                            <strong>Error:</strong> {{ error }}
                        </div>
                        <button
                            type="button"
                            class="btn btn-sm btn-secondary"
                            data-action="live#action"
                            data-live-action-param="backToSelect"
                        >← {{ 'tip.tryAnother'|trans }}</button>
                    {% endif %}

                    {% if is_granted('ROLE_ADMIN') %}
                        {% set debugEvent = this.debugTargetEventPreview %}
                        <details class="mt-3">
                            <summary class="small">Debug: source payment-target event</summary>
                            {% if debugEvent %}
                                <pre class="small mt-2 mb-0">{{ debugEvent }}</pre>
                            {% else %}
                                <p class="small text-muted mt-2 mb-0">No kind 10133 event found for this recipient.</p>
                            {% endif %}
                        </details>
                    {% endif %}
                </div>
            </div>
        </div>
    {% endif %}
</div>

