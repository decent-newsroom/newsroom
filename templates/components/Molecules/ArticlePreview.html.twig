<div class="nostr-article-preview card">
    <div class="card-body">
        {% if article.image %}
            <div class="article-preview-image">
                <img src="{{ article.image }}" alt="{{ article.title }}" class="img-fluid rounded">
            </div>
        {% endif %}
        <div class="article-preview-meta d-flex flex-row justify-content-between align-items-center px-2">
            <div class="author-info">
                <twig:Molecules:UserFromNpub
                    ident="{{ article.pubkey }}"
                    :compact="true"
                />
            </div>

            <div class="article-date text-muted small">
                {% set displayDate = (article.publishedAt is defined and article.publishedAt is not null) ? article.publishedAt : article.createdAt %}
                {% set isEdited = article.publishedAt is defined and article.publishedAt is not null and article.createdAt is not null and article.publishedAt|date('U') != article.createdAt|date('U') %}
                {{ displayDate|date('M j, Y') }}
                {% if isEdited %}
                    <span class="article-edited-note">· {{ 'text.edited'|trans }} {{ article.createdAt|date('M j, Y') }}</span>
                {% endif %}
            </div>
        </div>

        <div class="px-2">
            <h5 class="card-title">
                <a href="{{ path('author-article-slug', {npub: npub, slug: article.slug}) }}" class="text-decoration-none" data-turbo-frame="_top">
                    {{ article.title }}
                </a>
            </h5>

            {% if article.summary %}
                <p class="card-text text-muted small line-clamp-3">{{ article.summary }}</p>
            {% endif %}
        </div>
    </div>
</div>

