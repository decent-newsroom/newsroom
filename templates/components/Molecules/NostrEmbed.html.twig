{# Molecules:NostrEmbed — resolves a nostr reference to a rich card at render time #}
{% if resolved %}
    {% if article is not null %}
        {# Longform article card #}
        <twig:Molecules:Card
            :article="article"
            :authors_metadata="authorsMetadata"
            :is_author_profile="false"
        />
    {% elseif isPicture %}
        {# Kind 20 picture card #}
        {% include 'event/_kind20_picture.html.twig' with {event: event, embed: true} %}
    {% elseif event is not null %}
        {# Generic event card #}
        {% include 'components/event_card.html.twig' with {
            event: event,
            author: authorMeta,
            nevent: bech
        } %}
    {% endif %}
{% else %}
    {# Unresolved — show placeholder with client-side fetch #}
    <div class="nostr-placeholder"
         data-nostr="{{ bech }}"
         data-controller="nostr--deferred-embed"
         data-nostr--deferred-embed-bech-value="{{ bech }}"
         data-nostr--deferred-embed-type-value="{{ type }}">
        <div class="nostr-placeholder-icon">
            {% if type == 'note' or type == 'nevent' %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {% elseif type == 'naddr' %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            {% else %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            {% endif %}
        </div>
        <div class="nostr-placeholder-body">
            <span class="nostr-placeholder-label">Referenced {{ label }} not yet available</span>
            <a href="{{ href }}" class="nostr-placeholder-ref">{{ shortBech }}</a>
        </div>
    </div>
{% endif %}

