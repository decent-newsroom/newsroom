{% extends 'layout.html.twig' %}

{% block title %}{{ relay_url }} — Relay Feed — Decent Newsroom{% endblock %}

{% block body %}
<div class="relay-feed"
     data-controller="content--relay-feed"
     data-content--relay-feed-topic-value="{{ mercure_topic }}"
     data-content--relay-feed-keepalive-url-value="{{ path('relay_feed_keepalive', { key: relay_key }) }}"
     data-content--relay-feed-muted-pubkeys-value="{{ muted_pubkeys|json_encode }}"
     data-content--relay-feed-by-label-value="{{ 'text.by'|trans|e('html_attr') }}"
     data-content--relay-feed-untitled-label-value="{{ 'relay_feed.untitled'|trans|e('html_attr') }}"
     data-content--relay-feed-cover-image-alt-template-value="{{ 'card.coverImageAlt'|trans({'%title%': '__TITLE__'})|e('html_attr') }}"
     data-content--relay-feed-logged-in-value="{{ app.user ? 'true' : 'false' }}"
     data-content--relay-feed-bookmark-fetch-url-value="{{ app.user ? path('api_bookmarks_current') : '' }}"
     data-content--relay-feed-bookmark-publish-url-value="{{ app.user ? path('api_bookmarks_publish') : '' }}"
     data-content--relay-feed-bookmark-add-label-value="{{ 'bookmark.add'|trans|e('html_attr') }}"
     data-content--relay-feed-bookmark-remove-label-value="{{ 'bookmark.remove'|trans|e('html_attr') }}"
     data-content--relay-feed-bookmark-icon-value="{{ ux_icon('iconoir:bookmark', {class: 'icon', 'data-ui--card-bookmark-target': 'icon'})|e('html_attr') }}"
>
    <div class="relay-feed__header">
        <div class="relay-feed__meta">
            <a href="{{ path('relay_feed_index') }}" class="relay-feed__back">
                ← {{ 'relay_feed.back'|trans }}
            </a>
            <h1 class="relay-feed__title">{{ relay_url }}</h1>
        </div>
        <div class="relay-feed__status">
            <span class="relay-feed__indicator" data-content--relay-feed-target="indicator"></span>
            <span class="relay-feed__count" data-content--relay-feed-target="count">
                {{ articles|length }}
            </span>
            {{ 'relay_feed.articles_cached'|trans }}
        </div>
    </div>

    <div class="w-container">
        <div class="article-list" data-content--relay-feed-target="list">
            {% for article in articles %}
                {% include 'relay_feed/_card.html.twig' with { article: article } %}
            {% else %}
                <div class="relay-feed__empty" data-content--relay-feed-target="empty">
                    <p>{{ 'relay_feed.waiting'|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

