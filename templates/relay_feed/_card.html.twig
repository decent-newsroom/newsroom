{% set articleCard = {
    id: article.id,
    slug: article.d_tag,
    title: article.title ?: ('relay_feed.untitled'|trans),
    pubkey: article.pubkey,
    createdAt: article.created_at,
    publishedAt: null,
    summary: article.summary,
    image: article.image,
    kind: 30023,
    naddr: article.naddr,
} %}

<twig:Molecules:Card :article="articleCard" />
