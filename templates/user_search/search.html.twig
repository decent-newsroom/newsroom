{% extends 'layout.html.twig' %}

{% block title %}{{ 'userSearch.heading'|trans }} - Decent Newsroom{% endblock %}

{% block nav %}
{% endblock %}

{% block body %}
    <twig:Atoms:PageHeading
        heading="{{ 'userSearch.heading'|trans }}"
        tagline="{{ 'userSearch.tagline'|trans }}" />

    <section>
        <form action="{{ path('users_search_page') }}"
              method="get"
              class="mb-5"
              data-controller="search--nostr-redirect"
              data-action="submit->search--nostr-redirect#submit">
            <label class="search">
                <input type="text"
                       name="q"
                       value="{{ query }}"
                       placeholder="{{ 'userSearch.searchPlaceholder'|trans }}"
                       data-search--nostr-redirect-target="input"
                       autofocus />
                <button type="submit"><twig:ux:icon name="iconoir:search" class="icon" /></button>
            </label>
        </form>

        {% if query %}
            <div class="user-search__results-header">
                {% if resultsCount > 0 %}
                    <h2>{{ 'userSearch.found'|trans({'%count%': resultsCount}) }}</h2>
                {% endif %}
            </div>

            {% if users|length > 0 %}
                <div class="users-grid">
                    {% for user in users %}
                        <a href="{{ path('author-profile', { npub: user.npub }) }}"
                           class="user-card"
                           data-turbo-frame="_top">
                            <div class="user-card__avatar">
                                {% if user.picture %}
                                    <img src="{{ user.picture }}"
                                         alt="{{ user.displayName ?? user.name ?? 'User' }}"
                                         loading="lazy">
                                {% else %}
                                    <div class="user-card__avatar-placeholder">
                                        {{ (user.displayName ?? user.name ?? user.npub[:8])|slice(0, 2)|upper }}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="user-card__body">
                                <h3 class="user-card__name">
                                    {{ user.displayName ?? user.name ?? 'Anonymous' }}
                                </h3>
                                {% if user.nip05 %}
                                    <div class="user-card__nip05">{{ user.nip05 }}</div>
                                {% endif %}
                                {% if user.about %}
                                    <p class="user-card__about">{{ user.about|length > 140 ? user.about|slice(0, 140) ~ '…' : user.about }}</p>
                                {% endif %}
                                <div class="user-card__meta">
                                    <span class="user-card__npub">{{ user.npub[:12] }}…{{ user.npub[-6:] }}</span>
                                    {% if user.lud16 %}
                                        <span class="user-card__lightning" title="Lightning: {{ user.lud16 }}">⚡</span>
                                    {% endif %}
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="user-search__empty">
                    <p>{{ 'userSearch.noResults'|trans({'%query%': query}) }}</p>
                    <p class="user-search__help">{{ 'userSearch.noResultsHint'|trans }}</p>
                </div>
            {% endif %}
        {% else %}
            <div class="user-search__suggestions">
                <h3>{{ 'userSearch.quickLinks'|trans }}</h3>
                <a href="{{ path('featured_writers_page') }}" class="user-search__suggestion-link">
                    <h4>{{ 'featuredWriters.heading'|trans }}</h4>
                    <p>{{ 'userSearch.featuredDescription'|trans }}</p>
                </a>
            </div>
        {% endif %}
    </section>
{% endblock %}

{% block aside %}
    <twig:Atoms:ForumAside />
{% endblock %}

