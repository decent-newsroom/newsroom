{% extends 'layout.html.twig' %}

{% block title %}{{ 'featuredWriters.heading'|trans }} - Decent Newsroom{% endblock %}

{% block nav %}
{% endblock %}

{% block body %}
    <twig:Atoms:PageHeading
        heading="{{ 'featuredWriters.heading'|trans }}"
        tagline="{{ 'featuredWriters.tagline'|trans }}" />

    <section>
        <form action="{{ path('featured_writers_page') }}"
              method="get"
              class="mb-5">
            <label class="search">
                <input type="text"
                       name="q"
                       value="{{ query }}"
                       placeholder="{{ 'featuredWriters.filterPlaceholder'|trans }}" />
                <button type="submit"><twig:ux:icon name="iconoir:search" class="icon" /></button>
            </label>
            {% if query %}
                <div class="mt-2">
                    <a href="{{ path('featured_writers_page') }}" class="btn btn-sm">{{ 'search.filters.clear'|trans }}</a>
                </div>
            {% endif %}
        </form>

        {% if query %}
            <div class="user-search__results-header">
                <h2>{{ 'userSearch.found'|trans({'%count%': resultsCount}) }}</h2>
            </div>
        {% endif %}

        {% if users|length > 0 %}
            <div class="users-grid">
                {% for user in users %}
                    <a href="{{ path('author-profile', { npub: user.npub }) }}"
                       class="user-card"
                       data-turbo-frame="_top">
                        <div class="user-card__avatar">
                            {% if user.picture %}
                                <img src="{{ user.picture }}"
                                     alt="{{ user.displayName ?? user.name ?? 'Writer' }}"
                                     loading="lazy">
                            {% else %}
                                <div class="user-card__avatar-placeholder">
                                    {{ (user.displayName ?? user.name ?? user.npub[:8])|slice(0, 2)|upper }}
                                </div>
                            {% endif %}
                        </div>
                        <div class="user-card__body">
                            <h3 class="user-card__name">
                                {{ user.displayName ?? user.name ?? 'Anonymous' }}
                            </h3>
                            {% if user.nip05 %}
                                <div class="user-card__nip05">{{ user.nip05 }}</div>
                            {% endif %}
                            {% if user.about %}
                                <p class="user-card__about">{{ user.about|length > 140 ? user.about|slice(0, 140) ~ '…' : user.about }}</p>
                            {% endif %}
                            <div class="user-card__meta">
                                <span class="user-card__npub">{{ user.npub[:12] }}…{{ user.npub[-6:] }}</span>
                                {% if user.lud16 %}
                                    <span class="user-card__lightning" title="Lightning: {{ user.lud16 }}">⚡</span>
                                {% endif %}
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="user-search__empty">
                {% if query %}
                    <p>{{ 'userSearch.noResults'|trans({'%query%': query}) }}</p>
                {% else %}
                    <p>{{ 'featuredWriters.noWriters'|trans }}</p>
                {% endif %}
            </div>
        {% endif %}

        <div class="user-search__back">
            <a href="{{ path('users_search_page') }}">← {{ 'featuredWriters.backToSearch'|trans }}</a>
        </div>
    </section>
{% endblock %}

{% block aside %}
    <twig:Atoms:ForumAside />
{% endblock %}

