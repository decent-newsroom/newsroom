{# Render a NIP-22 comment as a "callout on top of the referenced item".
   Used in bookmark / expression-result lists where the user is browsing a
   feed of items and wants to see the article that's being commented on,
   not the comment itself. The comment author + text are shown as a small
   strip above the resolved parent/root card.

   For the single-event page (`/e/{nevent}`), use `_kind1111_comment.html.twig`
   instead — that view focuses on the comment itself.
#}
{% set parentE = null %}
{% set parentA = null %}
{% set parentI = null %}
{% set rootE = null %}
{% set rootA = null %}
{% set rootI = null %}

{% for tag in event.tags %}
    {% if tag[0] == 'a' and parentA is null and tag[1] is defined %}{% set parentA = tag[1] %}{% endif %}
    {% if tag[0] == 'e' and parentE is null and tag[1] is defined %}{% set parentE = tag[1] %}{% endif %}
    {% if tag[0] == 'i' and parentI is null and tag[1] is defined %}{% set parentI = tag[1] %}{% endif %}
    {% if tag[0] == 'A' and rootA is null and tag[1] is defined %}{% set rootA = tag[1] %}{% endif %}
    {% if tag[0] == 'E' and rootE is null and tag[1] is defined %}{% set rootE = tag[1] %}{% endif %}
    {% if tag[0] == 'I' and rootI is null and tag[1] is defined %}{% set rootI = tag[1] %}{% endif %}
{% endfor %}

{# Prefer the root scope (uppercase) when present — for an expression listing,
   the article that started the conversation is more useful as the headline
   than an intermediate parent. Fall back to the direct parent. #}
{% set targetA = rootA ?? parentA %}
{% set targetE = rootE ?? parentE %}
{% set targetI = rootI ?? parentI %}

{# Comment author + text, shown as a small callout above the target. #}
<div class="comment-callout">
    <div class="comment-callout-header">
        <small>
            <twig:Molecules:UserFromNpub :ident="event.pubkey" />
            commented:
        </small>
    </div>
    <blockquote class="comment-callout-body">
        <twig:Atoms:Content :content="event.content" />
    </blockquote>
</div>

{# Resolved target — the actual headline of this list item. #}
{% if targetA %}
    <twig:Organisms:ArticleFromCoordinate :coordinate="targetA" />
{% elseif targetE %}
    <twig:Molecules:NostrEmbed :bech="targetE|nEncode" type="note" />
{% elseif targetI %}
    <div class="comment-callout-external">
        <a href="{{ targetI }}" target="_blank" rel="noopener noreferrer">{{ targetI }}</a>
    </div>
{% else %}
    {# Standalone comment with no resolvable target — fall back to plain content #}
    <div class="event-content">
        <twig:Atoms:Content :content="event.content" />
    </div>
{% endif %}

