<div class="highlight-card">
    <div class="highlight-header">
        <div class="highlight-author">
            {% if highlight.pubkey %}
                <twig:Molecules:UserFromNpub
                    ident="{{ highlight.pubkey }}"
                    :compact="true"
                />
            {% else %}
                <span>{{ 'text.anonymous'|trans }}</span>
            {% endif %}
        </div>
        <div class="highlight-date">
            {{ highlight.created_at|date('M j, Y') }}
        </div>
    </div>

    <div class="highlight-content" data-controller="utility--show-more">
        {% if highlight.context %}
            {% set htmlContext = highlight.context|markdown_to_html %}
            {% if highlight.content in highlight.context %}
                {% set wrapper = '<span class="highlight-mark">' ~ highlight.content ~ '</span>' %}
                {% set rendered = htmlContext|replace({ (highlight.content): wrapper }) %}
                <div data-utility--show-more-target="preview" class="content-preview">
                    {{ rendered|raw }}
                </div>
                <div data-utility--show-more-target="full" class="content-full" style="display: none;">
                    {{ rendered|raw }}
                </div>
            {% else %}
                <div data-utility--show-more-target="preview" class="content-preview">
                    <div class="context-text">{{ htmlContext|raw }}</div>
                    <div><span class="highlight-mark">{{ highlight.content }}</span></div>
                </div>
                <div data-utility--show-more-target="full" class="content-full" style="display: none;">
                    <div class="context-text">{{ htmlContext|raw }}</div>
                    <div><span class="highlight-mark">{{ highlight.content }}</span></div>
                </div>
            {% endif %}
            <button data-utility--show-more-target="button"
                    data-action="click->utility--show-more#toggle"
                    class="show-more-button">
                {{ 'text.showMore'|trans }}
            </button>
        {% else %}
            <span class="highlight-mark">{{ highlight.content }}</span>
        {% endif %}
    </div>

    <div class="highlight-footer">
        {% if highlight.preview is defined and highlight.preview %}
            <div class="article-preview">
                <twig:Molecules:NostrPreview :preview="highlight.preview" />
            </div>
        {% elseif highlight.naddr is defined and highlight.naddr %}
            <a href="{{ path('article-naddr', {naddr: highlight.naddr}) }}"
               class="article-reference"
               data-turbo-frame="_top">
                {% if highlight.article_title %}
                    {{ highlight.article_title }}
                {% else %}
                    {{ 'text.viewOriginalArticle'|trans }}
                {% endif %}
            </a>
        {% elseif highlight.article_ref %}
            {% set refParts = highlight.article_ref|split(':', 3) %}
            {% set refNpub = refParts|length == 3 ? refParts[1]|hex_to_npub : '' %}
            {% if refNpub and refParts|length == 3 %}
                <a href="{{ path('author-article-slug', {npub: refNpub, slug: refParts[2]}) }}"
                   class="article-reference"
                   data-turbo-frame="_top">
                    {% if highlight.article_title %}
                        {{ highlight.article_title }}
                    {% else %}
                        {{ 'text.viewOriginalArticle'|trans }}
                    {% endif %}
                </a>
            {% else %}
                <span class="article-reference" style="opacity: 0.6; cursor: default;">
                    {% if highlight.article_title %}
                        {{ highlight.article_title }}
                    {% else %}
                        {{ 'text.articleReference'|trans }}: {{ highlight.article_ref }}
                    {% endif %}
                </span>
            {% endif %}
        {% elseif highlight.event_ref is defined and highlight.event_ref %}
            <twig:Molecules:NostrEmbed :bech="highlight.event_ref|nEncode" type="note" />
        {% elseif highlight.url %}
            <a href="{{ highlight.url }}"
               class="article-reference"
               target="_blank"
               rel="noopener noreferrer"
               data-turbo-frame="_top">
                {{ ux_icon('iconoir/open-new-window', {width: 14, height: 14}) }}
                Source: {{ highlight.url|replace({'https://': '', 'http://': ''})|split('/')[0] }}
            </a>
        {% endif %}
    </div>
</div>

