{# Bookmark event card - renders a bookmarked event as a card #}
<div class="bookmark-event-card card mb-3">
    {# Extract title from tags #}
    {% set eventTitle = null %}
    {% for tag in event.tags %}
        {% if tag[0] == 'title' %}
            {% set eventTitle = tag[1] %}
        {% endif %}
    {% endfor %}

    <div class="card-header">
        <h4 class="card-title {{ eventTitle ? '' : 'hidden' }}">
            {{ eventTitle ?? 'Untitled' }}
        </h4>
        <div class="metadata">
            <p class="m-0">by <twig:Molecules:UserFromNpub :ident="event.pubkey" /></p>
            <small>{{ event.createdAt|date('M j, Y') }}</small>
        </div>
    </div>

    <div class="card-body">
        {# Reuse existing event kind partials #}
        {% if event.kind == 20 %}
            {% include 'event/_kind20_picture.html.twig' with {event: event, embed: true} %}
        {% elseif event.kind in [21, 22, 34235, 34236] %}
            {% include 'event/_kind22_video.html.twig' with {event: event, embed: true} %}
        {% elseif event.kind == 1450 %}
            {% include 'event/_kind1450_tabular.html.twig' with {event: event} %}
        {% elseif event.kind == 10015 %}
            {% include 'event/_kind10015_tags.html.twig' with {event: event} %}
        {% elseif event.kind == 39089 %}
            {% include 'event/_kind39089_followPack.html.twig' with {event: event} %}
        {% else %}
            {# Default: parsed content preview #}
            <div class="event-content">
                <twig:Atoms:Content :content="event.content" />
            </div>
            {% include 'partial/_gallery.html.twig' with {event: event, isEmbed: true} %}
        {% endif %}
    </div>

    <div>
        {% set note1 = event.encodeAsNote1() %}
        {% if note1 %}
            <a href="/e/{{ note1 }}">
                View Full Event
            </a>
        {% else %}
            <span class="text-muted">Event ID: {{ event.id|slice(0, 16) }}…</span>
        {% endif %}
    </div>
    <hr>
</div>
