<div class="w-container">
    <section class="p-0">
        <h1>
            <twig:Atoms:NameOrNpub :author="author" :npub="npub"></twig:Atoms:NameOrNpub>
            {% if author.bot is defined and author.bot %}
                <span class="tag">bot</span>
            {% endif %}
        </h1>

        {% if author.nip05 is defined and author.nip05 is not empty %}
            {% set nip05Values = [] %}
            {% for rawNip05 in (author.nip05 is iterable ? author.nip05 : [author.nip05]) %}
                {% if rawNip05 is not empty %}
                    {% for candidateNip05 in rawNip05|split(',') %}
                        {% set normalizedNip05 = candidateNip05|trim %}
                        {% if normalizedNip05 is not empty and normalizedNip05 not in nip05Values %}
                            {% set nip05Values = nip05Values|merge([normalizedNip05]) %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
            {% endfor %}

            {% if nip05Values is not empty %}
                <div class="nip05-badge-list">
                    {% for nip05Value in nip05Values %}
                        <twig:Atoms:Nip05Badge
                            nip05="{{ nip05Value }}"
                            :npub="npub"
                        />
                    {% endfor %}
                </div>
            {% endif %}
        {% endif %}
        <div class="mt-2">
            {% if author.about is defined and author.about %}
                {{ author.about|markdown_to_html|mentionify|linkify  }}
            {% endif %}
        </div>

        {% if author.website is defined and author.website %}
            {% set website = author.website is iterable ? author.website|first : author.website %}
            {% if website is not empty %}
                {% set websiteLabel = website|replace({'https://': '', 'http://': ''}) %}
                {% if websiteLabel starts with 'www.' %}
                    {% set websiteLabel = websiteLabel|slice(4) %}
                {% endif %}
                <div class="mt-2">
                    <a href="{{ website }}" target="_blank" rel="noopener noreferrer">
                        {{ websiteLabel|trim('/') }}
                    </a>
                </div>
            {% endif %}
        {% endif %}
    </section>
    <div class="article-actions">
        {% if app.user and app.user.userIdentifier != (pubkey|hex_to_npub) %}
            <form method="post" action="{{ path('updates_subscriptions_add') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('update-subscribe') }}" />
                <input type="hidden" name="identifier" value="{{ pubkey }}" />
                <input type="hidden" name="redirect_to" value="{{ app.request.requestUri }}" />
                <button type="submit" class="btn btn-outline-primary">{{ 'updates.subscription.addSubmit'|trans }}</button>
            </form>
            <twig:FollowPackDropdown pubkey="{{ pubkey }}" />
        {% endif %}
        {% if author.lud16 is defined and author.lud16 %}
            <twig:Molecules:ZapButton
                recipientPubkey="{{ pubkey }}"
                recipientLud16="{{ author.lud16 is iterable ? author.lud16|first : author.lud16 }}"
            />
        {% endif %}
        {% if app.user and app.user.userIdentifier == (pubkey|hex_to_npub) %}
            <a href="{{ path('settings') }}" class="btn btn-outline-secondary">Settings</a>
        {% endif %}
        <div class="position-relative d-inline-block"
             data-controller="utility--share-dropdown">
            <button class="btn btn-outline-secondary"
                    type="button"
                    data-action="click->utility--share-dropdown#toggle"
                    aria-label="More actions">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <circle cx="12" cy="5" r="2"/>
                    <circle cx="12" cy="12" r="2"/>
                    <circle cx="12" cy="19" r="2"/>
                </svg>
            </button>
            <div data-utility--share-dropdown-target="menu"
                 class="dropdown-menu dropdown-menu-end"
                 style="display:none;position:absolute;z-index:1000;min-width:180px;">
                <button class="dropdown-item"
                        type="button"
                        data-action="click->utility--share-dropdown#copy"
                        data-copy="{{ npub }}">
                    Copy npub
                </button>
            </div>
        </div>
    </div>
</div>
