{% extends 'layout-full.html.twig' %}

{% block body %}
    <main class="d-flex gap-3 static">
        <twig:Atoms:PageHeading heading="{{ 'about.heading'|trans }}" />
        <section>
            <h2>{{ 'about.rebuildingTrust'|trans }}</h2>

            <p>{{ 'about.intro'|trans }}</p>

            <p>{{ 'about.answer'|trans }}</p>
        </section>

        <section>
            <h2>{{ 'about.whyItMatters'|trans }}</h2>
            <p>{{ 'about.whyText'|trans }}</p>
        </section>

        <section class="mb-5">
            <p>{{ 'about.supportUs'|trans }} <a href="https://geyser.fund/project/newsroom" target="_blank">{{ 'about.geyserLink'|trans }}</a>.</p>
            <br>
            <p>{{ 'about.moreInfo'|trans }}
                <twig:Molecules:UserFromNpub ident="{{ project_npub }}" /> {{ 'text.or'|trans }}
                <twig:Molecules:UserFromNpub ident="{{ dev_npub }}" />.
            </p>
        </section>
    </main>

    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5">
            <h1>{{ 'home.newsstand.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.newsstand.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.newsstand.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('newsstand') }}">{{ 'about.exploreRack'|trans }}</a>
            </div>
        </div>
    </section>

{% endblock %}
