{% extends 'layout-full.html.twig' %}

{% block title %}{{ 'essayist.landing.title'|trans }} | {{ brand_name }}{% endblock %}

{% block body %}
    {%- set fmt_launch   = launchDate|format_date('long') -%}
    {%- set fmt_deadline = earlyBirdDeadline|format_date('long') -%}
    <main class="essayist-page" data-controller="utility--login-modal">
        <section class="essayist-hero">
            <div class="essayist-shell">
                <twig:Atoms:PageHeading heading="{{ 'essayist.landing.title'|trans }}" tagline="{{ 'essayist.landing.hero.heading'|trans }}"/>
                <p class="essayist-lede">{{ 'essayist.landing.hero.lede'|trans }}</p>

                <div class="essayist-actions">
                    {% if isMember %}
                        <a class="btn btn--primary" href="{{ path('app_essayist_home') }}">{{ 'essayist.landing.hero.ctaMember'|trans }}</a>
                    {% elseif isAdmin|default(false) %}
                        <a class="btn btn--primary" href="{{ path('app_essayist_home') }}">Admin preview</a>
                    {% elseif app.user %}
                        {% if isPending %}
                            <span class="btn btn--disabled" aria-disabled="true">{{ 'essayist.landing.join.pendingBody'|trans }}</span>
                        {% else %}
                            <form method="post" action="{{ path('app_static_essayist_request_access') }}" style="display:inline;" class="m-0">
                                <input type="hidden" name="_token" value="{{ csrf_token('essayist_request_access') }}">
                                <button type="submit" class="btn btn--primary">{{ 'essayist.landing.join.requestCta'|trans }}</button>
                            </form>
                        {% endif %}
                    {% else %}
                        <button class="btn btn--primary" type="button" data-action="click->utility--login-modal#openDialog">{{ 'essayist.landing.hero.ctaAnon'|trans }}</button>
                    {% endif %}
                    <a class="btn" href="#essayist-how">{{ 'essayist.landing.hero.secondaryCta'|trans }}</a>
                </div>
            </div>
        </section>

        <section class="essayist-status">
            <div class="essayist-shell essayist-status__grid">
                <div class="essayist-status__item">
                    <div class="essayist-status__label">{{ 'essayist.landing.status.memberLabel'|trans }}</div>
                    <p class="essayist-status__count">{{ memberCount }}</p>
                    <p>{{ 'essayist.landing.status.memberBody'|trans }}</p>
                </div>
                <div class="essayist-status__item">
                    <div class="essayist-status__label">{{ 'essayist.landing.status.renewalLabel'|trans }}</div>
                    <p>{{ 'essayist.landing.status.renewalBody'|trans }}</p>
                </div>
            </div>
        </section>

        <section id="essayist-how" class="essayist-section essayist-section--muted">
            <div class="essayist-shell essayist-grid-two">
                <div>
                    <p class="essayist-eyebrow">{{ 'essayist.landing.how.eyebrow'|trans }}</p>
                    <h2>{{ 'essayist.landing.how.heading'|trans }}</h2>
                </div>
                <div>
                    <ol class="essayist-steps">
                        <li>
                            <strong>{{ 'essayist.landing.how.step1.title'|trans }}</strong>
                            <p>{{ 'essayist.landing.how.step1.body'|trans }}</p>
                        </li>
                        <li>
                            <strong>{{ 'essayist.landing.how.step2.title'|trans }}</strong>
                            <p>{{ 'essayist.landing.how.step2.body'|trans({'%deadline%': fmt_deadline}) }}</p>
                        </li>
                        <li>
                            <strong>{{ 'essayist.landing.how.step3.title'|trans }}</strong>
                            <p>{{ 'essayist.landing.how.step3.body'|trans }}</p>
                        </li>
                        <li>
                            <strong>{{ 'essayist.landing.how.step4.title'|trans }}</strong>
                            <p>{{ 'essayist.landing.how.step4.body'|trans }}</p>
                        </li>
                        <li>
                            <strong>{{ 'essayist.landing.how.step5.title'|trans }}</strong>
                            <p>{{ 'essayist.landing.how.step5.body'|trans }}</p>
                        </li>
                    </ol>
                </div>
            </div>
        </section>

        <section id="essayist-join" class="essayist-section">
            <div class="essayist-shell essayist-grid-two">
                <div>
                    <p class="essayist-eyebrow">{{ 'essayist.landing.join.eyebrow'|trans }}</p>
                    <h2>{{ 'essayist.landing.join.heading'|trans }}</h2>
                </div>
                <div>
                    {% if joinStatus %}
                        <div class="essayist-alert {{ joinStatus in ['request_created'] ? 'essayist-alert--success' : 'essayist-alert--info' }}">
                            {{ ('essayist.landing.join.status.' ~ joinStatus)|trans({'%launch_date%': fmt_launch, '%deadline%': fmt_deadline}) }}
                        </div>
                    {% endif %}

                    {% if isMember %}
                        <p class="essayist-copy">{{ 'essayist.landing.join.memberBody'|trans }}</p>
                        <div class="essayist-actions">
                            <a class="btn btn--primary" href="{{ path('app_essayist_home') }}">{{ 'essayist.landing.join.memberCta'|trans }}</a>
                            <a class="btn" href="{{ path('app_essayist_members') }}">{{ 'essayist.members.heading'|trans }}</a>
                        </div>
                    {% elseif isPending %}
                        <p class="essayist-copy">{{ 'essayist.landing.join.pendingBody'|trans }}</p>
                        <div class="essayist-actions">
                            <a class="btn btn--primary" href="{{ path('app_essayist_members') }}">{{ 'essayist.members.heading'|trans }}</a>
                        </div>
                    {% elseif app.user %}
                        <p class="essayist-copy">{{ 'essayist.landing.join.loggedInBody'|trans({'%launch_date%': fmt_launch}) }}</p>
                        <form method="post" action="{{ path('app_static_essayist_request_access') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('essayist_request_access') }}">
                            <button type="submit" class="btn btn--primary">{{ 'essayist.landing.join.requestCta'|trans }}</button>
                        </form>
                    {% else %}
                        <p class="essayist-copy">{{ 'essayist.landing.join.anonBody'|trans }}</p>
                        <div class="essayist-actions">
                            <button class="btn btn--primary" type="button" data-action="click->utility--login-modal#openDialog">{{ 'essayist.landing.join.anonCta'|trans }}</button>
                        </div>
                    {% endif %}
                </div>
            </div>
        </section>

        <section class="essayist-section essayist-section--muted">
            <div class="essayist-shell essayist-grid-two">
                <div>
                    <p class="essayist-eyebrow">{{ 'essayist.landing.model.eyebrow'|trans }}</p>
                    <h2>{{ 'essayist.landing.model.heading'|trans }}</h2>
                </div>
                <div class="essayist-copy">
                    <p>{{ 'essayist.landing.model.paragraph1'|trans }}</p>
                    <p>{{ 'essayist.landing.model.paragraph2'|trans({'%deadline%': fmt_deadline}) }}</p>
                </div>
            </div>
        </section>

        <section class="essayist-section">
            <div class="essayist-shell essayist-grid-two">
                <div>
                    <p class="essayist-eyebrow">{{ 'essayist.landing.faq.eyebrow'|trans }}</p>
                    <h2>{{ 'essayist.landing.faq.heading'|trans }}</h2>
                </div>
                <div>
                    <dl class="essayist-faq">
                        <dt>{{ 'essayist.landing.faq.q1'|trans }}</dt>
                        <dd>{{ 'essayist.landing.faq.a1'|trans }}</dd>

                        <dt>{{ 'essayist.landing.faq.q2'|trans }}</dt>
                        <dd>{{ 'essayist.landing.faq.a2'|trans }}</dd>

                        <dt>{{ 'essayist.landing.faq.q3'|trans }}</dt>
                        <dd>{{ 'essayist.landing.faq.a3'|trans }}</dd>

                        <dt>{{ 'essayist.landing.faq.q4'|trans }}</dt>
                        <dd>{{ 'essayist.landing.faq.a4'|trans }}</dd>

                        <dt>{{ 'essayist.landing.faq.q5'|trans }}</dt>
                        <dd>{{ 'essayist.landing.faq.a5'|trans }}</dd>

                        <dt>{{ 'essayist.landing.faq.q6'|trans }}</dt>
                        <dd>{{ 'essayist.landing.faq.a6'|trans }}</dd>
                    </dl>
                </div>
            </div>
        </section>

        <twig:LoginModal />
    </main>
{% endblock %}
