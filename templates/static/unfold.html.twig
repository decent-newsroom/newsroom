{% extends 'layout.html.twig' %}

{% block title %}{{ 'unfold.title'|trans }}{% endblock %}

{% block body %}

    <section class="ln-hero d-flex gap-3 center">
        <h1 class="brand">{{ 'unfold.hero'|trans }}</h1>
        <p class="eyebrow">{{ 'unfold.heroEyebrow'|trans }}</p>
        <p class="lede mb-5">
            {{ 'unfold.heroLede'|trans }}
        </p>
    </section>

    <section class="d-flex gap-3 center ln-section--unfold">
        <div class="container mt-5">
            <h2>{{ 'unfold.unfoldMagazine'|trans }}</h2>
        </div>
        <div class="mb-5">
            <p class="measure">
                {{ 'unfold.unfoldDesc1'|trans }}
            </p>
            <p class="measure">
                {{ 'unfold.unfoldDesc2'|trans }}
            </p>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--newsroom">
        <div class="container mt-5">
            <h2>{{ 'unfold.hero'|trans }}</h2>
        </div>
        <div class="mb-5">
            <p class="measure">
                {{ 'unfold.unfoldHosting'|trans }}
            </p>

            <p class="measure">
                <strong>{{ 'unfold.unfoldPrice'|trans }}</strong><br>
                {{ 'unfold.unfoldPriceDesc'|trans }}
            </p>

            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('publication_subdomain_index') }}">
                    {{ 'unfold.launchMagazine'|trans }}
                </a>
            </div>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--marketplace">
        <div class="container mt-5">
            <h2>{{ 'unfold.seeInAction'|trans }}</h2>
        </div>
        <div class="mb-5">
            <p class="measure">
                {{ 'unfold.liveDescription'|trans }}
            </p>
            <ul class="measure list-unstyled">
                <li>
                    {{ 'unfold.supportMag'|trans }}
                    <a href="https://support.decentnewsroom.com/" target="_blank" rel="noopener">
                        support.decentnewsroom.com
                    </a>
                </li>
                <li>
                    {{ 'unfold.newsroomMag'|trans }}
                    <a href="https://newsroommag.decentnewsroom.com/" target="_blank" rel="noopener">
                        newsroommag.decentnewsroom.com
                    </a>
                </li>
            </ul>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--editor hidden">
        <div class="container mt-5">
            <h2>{{ 'unfold.advancedUse'|trans }}</h2>
        </div>
        <div class="mb-5">
            <p class="measure">
                {{ 'unfold.advancedDesc'|trans }}
                <twig:Molecules:UserFromNpub ident="{{ project_npub }}" />
                {{ 'text.or'|trans }}
                <twig:Molecules:UserFromNpub ident="{{ dev_npub }}" />.
            </p>
        </div>
    </section>

    <section class="d-flex gap-3 center">
        <div class="container mt-5">
            <h1>{{ 'home.newsstand.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.newsstand.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('newsstand') }}">{{ 'unfold.browseMagazines'|trans }}</a>
            </div>
        </div>
    </section>

{% endblock %}
