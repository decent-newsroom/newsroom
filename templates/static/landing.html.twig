{% extends 'layout-full.html.twig' %}

{% block title %}{{ 'home.title'|trans }}{% endblock %}

{% block body %}

    <section class="ln-hero d-flex gap-3 center">
        <h1 class="brand">{{ brand_name }}</h1>
        <p class="eyebrow">{{ 'brand.tagline'|trans }}</p>
        <p class="lede mb-5">{{ 'home.hero.lede'|trans }}</p>
    </section>

    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5">
            <h1>{{ 'home.newsstand.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.newsstand.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.newsstand.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('newsstand') }}">{{ 'about.exploreRack'|trans }}</a>
            </div>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--search">
        <div class="container mt-5">
            <h1>{{ 'nav.discover'|trans }}</h1>
            <p class="eyebrow">{{ 'home.explore.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.explore.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('app_search_index') }}">{{ 'home.explore.cta'|trans }}</a>
            </div>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--editor">
        <div class="container mt-5">
            <h1>{{ 'home.editor.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.editor.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.editor.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('editor-create') }}">{{ 'home.editor.cta'|trans }}</a>
            </div>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--newsroom">
        <div class="container mt-5">
            <h1>{{ 'home.newsroom.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.newsroom.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.newsroom.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('mag_wizard_setup') }}">{{ 'home.newsroom.cta'|trans }}</a>
                <a class="btn btn-secondary" href="{{ path('blog_journey_landing') }}">{{ 'home.blog.cta'|trans }}</a>
            </div>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--unfold">
        <div class="container mt-5">
            <h1>{{ 'home.unfold.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.unfold.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.unfold.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('unfold') }}">{{ 'home.unfold.cta'|trans }}</a>
            </div>
        </div>
    </section>


    <section class="d-flex gap-3 center ln-section--marketplace">
        <div class="container mt-5">
            <h1>{{ 'home.marketplace.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.marketplace.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.marketplace.description'|trans }}</p>
        </div>
    </section>

{% endblock %}
