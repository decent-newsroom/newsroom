{% if app.user %}
    <div class="panel-section">
        <p>Your article will be published to the following relays.</p>
        <small>You'll be able to select a subset in the future.</small>
        <br>
        {% set relays = app.user.relays %}
        {% if relays %}
            {# Handle both flat array and nested {write: [], read: [], all: []} structure #}
            {% set writeRelays = relays.write is defined ? relays.write : (relays.all is defined ? relays.all : relays) %}
            {% if writeRelays and writeRelays|length > 0 %}
                <ul class="list-unstyled">
                    {% for relay in writeRelays %}
                        <li><pre>{{ relay }}</pre></li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No relays found. Relays will be loaded automatically.</p>
            {% endif %}
        {% else %}
            <p>Loading relays...</p>
            <small>Refresh the page if relays don't appear shortly.</small>
        {% endif %}

        <span>Default relay:</span>
        <ul class="list-unstyled">
            <li><pre>{{ relay_registry.publicUrl }}</pre></li>
        </ul>

        {# ── Essayist publish options ──────────────────────────────────────
           Visible to active Essayist members and to admins (preview).
           - "Also publish to Essayist": appends the Essayist relay to the
             outbound list alongside the user's regular NIP-65 outbox relays.
           - "Publish ONLY to Essayist": restricts the publish target list
             to the Essayist relay only and stores the article as
             essayist-exclusive in Decent Newsroom. #}
        {% set is_essayist_member = is_granted('ROLE_ESSAYIST_MEMBER') %}
        {% set is_admin_preview = is_granted('ROLE_ADMIN') and not is_essayist_member %}
        {% if essayist_relay_url is defined and essayist_relay_url and (is_essayist_member or is_admin_preview) %}
            <hr>
            <div class="essayist-publish-options"
                 data-controller="ui--essayist-publish-options">
                <p class="mb-1"><strong>Essayist</strong>
                    {% if is_admin_preview %}
                        <span class="badge bg-secondary">admin preview</span>
                    {% endif %}
                </p>
                <small class="text-muted d-block mb-2">
                    Target the members-only relay:<br>
                    <code>{{ essayist_relay_url }}</code>
                </small>

                <div class="form-check essayist-publish-option">
                    {{ form_widget(form.publishToEssayist, {
                        'attr': {
                            'class': 'form-check-input',
                            'data-ui--essayist-publish-options-target': 'alsoInput'
                        }
                    }) }}
                    {{ form_label(form.publishToEssayist, null, {'label_attr': {'class': 'form-check-label'}}) }}
                </div>

                <div class="form-check essayist-publish-option">
                    {{ form_widget(form.publishOnlyToEssayist, {
                        'attr': {
                            'class': 'form-check-input',
                            'data-ui--essayist-publish-options-target': 'onlyInput',
                            'data-action': 'change->ui--essayist-publish-options#onOnlyChanged'
                        }
                    }) }}
                    {{ form_label(form.publishOnlyToEssayist, null, {'label_attr': {'class': 'form-check-label'}}) }}
                </div>

                <div class="alert alert-warning mt-2 mb-0 small"
                     data-ui--essayist-publish-options-target="onlyWarning"
                     hidden>
                    This article will only be visible to Essayist members and
                    the author, and will not appear on public feeds.
                </div>
            </div>
        {% endif %}
    </div>
{% endif %}
