{% extends 'newsroom-layout.html.twig' %}

{% set currentQuery = {type: activeType, q: searchQuery, sort: sort} %}

{% block body %}
<section
    class="my-content-page"
    data-controller="content--my-content-delete"
    data-content--my-content-delete-publish-url-value="{{ path('api_settings_event_publish') }}"
    data-content--my-content-delete-missing-event-message-value="{{ 'my_content.delete.missing_event'|trans }}"
    data-content--my-content-delete-confirm-template-value="{{ 'my_content.delete.confirm_description'|trans({'%title%': '__TITLE__'}) }}"
    data-content--my-content-delete-content-template-value="{{ 'my_content.delete.event_content'|trans({'%title%': '__TITLE__'}) }}"
    data-content--my-content-delete-connecting-message-value="{{ 'my_content.delete.connecting'|trans }}"
    data-content--my-content-delete-signing-message-value="{{ 'my_content.delete.signing'|trans }}"
    data-content--my-content-delete-publishing-message-value="{{ 'my_content.delete.publishing'|trans }}"
    data-content--my-content-delete-rejected-message-value="{{ 'my_content.delete.rejected'|trans }}"
    data-content--my-content-delete-success-message-value="{{ 'my_content.delete.success'|trans }}"
    data-content--my-content-delete-failed-template-value="{{ 'my_content.delete.failed'|trans({'%error%': '__ERROR__'}) }}"
    data-content--my-content-delete-sent-label-value="{{ 'my_content.delete.sent'|trans }}"
>
    <header class="my-content-header">
        <div class="my-content-header__copy">
            <p class="eyebrow">{{ 'my_content.eyebrow'|trans }}</p>
            <h1>{{ 'my_content.title'|trans }}</h1>
            <p>{{ 'my_content.description'|trans }}</p>
        </div>
        <div class="my-content-header__actions">
            <a class="btn btn--secondary" href="{{ path('read_wizard_new') }}">
                {{ ux_icon('iconoir:journal-page', {class: 'icon'}) }}
                {{ 'my_content.action.new_list'|trans }}
            </a>
            <a class="btn" href="{{ path('editor-create') }}">
                {{ ux_icon('iconoir:edit-pencil', {class: 'icon'}) }}
                {{ 'my_content.action.new_article'|trans }}
            </a>
        </div>
    </header>

    <div class="my-content-summary" aria-label="{{ 'my_content.summary.label'|trans }}">
        <div>
            <strong>{{ counts.published }}</strong>
            <span>{{ 'my_content.summary.published'|trans }}</span>
        </div>
        <div>
            <strong>{{ counts.drafts }}</strong>
            <span>{{ 'my_content.summary.drafts'|trans }}</span>
        </div>
        <div>
            <strong>{{ counts.lists }}</strong>
            <span>{{ 'my_content.summary.lists'|trans }}</span>
        </div>
        <a href="{{ path('reading_nook') }}">
            {{ ux_icon('iconoir:bookmark', {class: 'icon'}) }}
            <span>{{ 'my_content.action.open_bookmarks'|trans }}</span>
            {{ ux_icon('iconoir:arrow-right', {class: 'icon'}) }}
        </a>
    </div>

    <nav class="my-content-tabs" aria-label="{{ 'my_content.tabs.label'|trans }}">
        {% for type, label in {
            all: 'my_content.tabs.all',
            drafts: 'my_content.tabs.drafts',
            published: 'my_content.tabs.published',
            lists: 'my_content.tabs.lists'
        } %}
            <a
                href="{{ path('my_content', {type: type, q: searchQuery, sort: sort}) }}"
                {% if activeType == type %}aria-current="page"{% endif %}
            >
                <span>{{ label|trans }}</span>
                <strong>{{ attribute(counts, type) }}</strong>
            </a>
        {% endfor %}
    </nav>

    <form class="my-content-toolbar" action="{{ path('my_content') }}" method="get">
        <input type="hidden" name="type" value="{{ activeType }}">
        <label class="my-content-search">
            <span class="visually-hidden">{{ 'my_content.filter.search_label'|trans }}</span>
            {{ ux_icon('iconoir:search', {class: 'icon'}) }}
            <input
                type="search"
                name="q"
                value="{{ searchQuery }}"
                placeholder="{{ 'my_content.filter.search_placeholder'|trans }}"
                autocomplete="off"
            >
        </label>
        <label class="my-content-sort">
            <span>{{ 'my_content.filter.sort_label'|trans }}</span>
            <select name="sort">
                <option value="recent"{% if sort == 'recent' %} selected{% endif %}>{{ 'my_content.filter.sort_recent'|trans }}</option>
                <option value="title"{% if sort == 'title' %} selected{% endif %}>{{ 'my_content.filter.sort_title'|trans }}</option>
            </select>
        </label>
        <button class="btn btn-sm" type="submit">{{ 'my_content.filter.apply'|trans }}</button>
        {% if searchQuery or sort != 'recent' %}
            <a class="my-content-toolbar__clear" href="{{ path('my_content', {type: activeType}) }}">
                {{ 'my_content.filter.clear'|trans }}
            </a>
        {% endif %}
    </form>

    <div class="my-content-results">
        <p>{{ 'my_content.results_count'|trans({'%count%': filteredCount}) }}</p>
        {% if totalPages > 1 %}
            <p>{{ 'my_content.pagination.page'|trans({'%current%': page, '%total%': totalPages}) }}</p>
        {% endif %}
    </div>

    <div class="my-content-inventory">
        <div class="my-content-row my-content-row--head" aria-hidden="true">
            <span>{{ 'my_content.column.content'|trans }}</span>
            <span>{{ 'my_content.column.status'|trans }}</span>
            <span>{{ 'my_content.column.updated'|trans }}</span>
            <span>{{ 'my_content.column.items'|trans }}</span>
            <span>{{ 'my_content.column.actions'|trans }}</span>
        </div>

        {% for item in contentItems %}
            {% set title = item.title|default('my_content.untitled'|trans) %}
            <article class="my-content-row" data-content-type="{{ item.category }}">
                <div class="my-content-row__main">
                    <span class="my-content-row__icon my-content-row__icon--{{ item.category }}" aria-hidden="true">
                        {% if item.category == 'published' %}
                            {{ ux_icon('iconoir:check', {class: 'icon'}) }}
                        {% elseif item.category == 'drafts' %}
                            {{ ux_icon('iconoir:page-edit', {class: 'icon'}) }}
                        {% else %}
                            {{ ux_icon('iconoir:journal-page', {class: 'icon'}) }}
                        {% endif %}
                    </span>
                    <div>
                        <h2>
                            {% if item.category == 'published' %}
                                <a href="{{ path('editor-edit-slug', {slug: item.article.slug}) }}">{{ title }}</a>
                            {% elseif item.category == 'drafts' %}
                                <a href="{{ path('editor-edit-slug-draft', {slug: item.article.slug}) }}">{{ title }}</a>
                            {% elseif item.list.kind == 30040 and item.list.slug %}
                                <a href="{{ path('read_wizard_articles', {load: item.list.slug}) }}">{{ title }}</a>
                            {% elseif item.list.slug %}
                                <a href="{{ path('curation-set', {kind: item.list.kind, slug: item.list.slug, npub: item.list.pubkey|toNpub}) }}">{{ title }}</a>
                            {% else %}
                                {{ title }}
                            {% endif %}
                        </h2>
                        {% if item.summary %}
                            <p>{{ item.summary }}</p>
                        {% else %}
                            <p class="my-content-row__slug">
                                {% if item.category == 'lists' %}
                                    {{ item.list.slug|default('my_content.no_identifier'|trans) }}
                                {% else %}
                                    {{ item.article.slug }}
                                {% endif %}
                            </p>
                        {% endif %}
                    </div>
                </div>

                <div class="my-content-row__status">
                    {% if item.category == 'published' %}
                        <span class="my-content-status my-content-status--published">{{ 'my_content.status.published'|trans }}</span>
                    {% elseif item.category == 'drafts' %}
                        <span class="my-content-status my-content-status--draft">{{ 'my_content.status.draft'|trans }}</span>
                    {% else %}
                        <span class="my-content-status my-content-status--list">{{ item.list.typeKey|trans }}</span>
                        {% if item.list.isEmpty %}
                            <small>{{ 'my_content.status.empty'|trans }}</small>
                        {% endif %}
                    {% endif %}
                </div>

                <time datetime="{{ item.updatedAt ? item.updatedAt|date('c') : '' }}">
                    {{ item.updatedAt ? item.updatedAt|date('Y-m-d') : '—' }}
                </time>

                <span class="my-content-row__count">
                    {{ item.category == 'lists' ? item.list.itemCount : '—' }}
                </span>

                <details class="my-content-menu" name="my-content-actions">
                    <summary aria-label="{{ 'my_content.action.menu'|trans({'%title%': title}) }}">
                        {{ ux_icon('iconoir:more-horiz', {class: 'icon'}) }}
                    </summary>
                    <div class="my-content-menu__panel">
                        {% if item.category == 'published' %}
                            <a href="{{ path('editor-edit-slug', {slug: item.article.slug}) }}">
                                {{ ux_icon('iconoir:edit-pencil', {class: 'icon'}) }}
                                {{ 'my_content.action.edit'|trans }}
                            </a>
                            <a href="{{ path('author-article-slug', {npub: item.article.pubkey|toNpub, slug: item.article.slug}) }}">
                                {{ ux_icon('iconoir:open-new-window', {class: 'icon'}) }}
                                {{ 'my_content.action.view'|trans }}
                            </a>
                        {% elseif item.category == 'drafts' %}
                            <a href="{{ path('editor-edit-slug-draft', {slug: item.article.slug}) }}">
                                {{ ux_icon('iconoir:edit-pencil', {class: 'icon'}) }}
                                {{ 'my_content.action.edit'|trans }}
                            </a>
                        {% elseif item.list.kind == 30040 and item.list.slug %}
                            <a href="{{ path('read_wizard_articles', {load: item.list.slug}) }}">
                                {{ ux_icon('iconoir:edit-pencil', {class: 'icon'}) }}
                                {{ 'my_content.action.edit'|trans }}
                            </a>
                            <a href="{{ path('reading-list', {slug: item.list.slug, npub: item.list.pubkey|toNpub}) }}">
                                {{ ux_icon('iconoir:open-new-window', {class: 'icon'}) }}
                                {{ 'my_content.action.view'|trans }}
                            </a>
                        {% elseif item.list.slug %}
                            <a href="{{ path('curation-set', {kind: item.list.kind, slug: item.list.slug, npub: item.list.pubkey|toNpub}) }}">
                                {{ ux_icon('iconoir:open-new-window', {class: 'icon'}) }}
                                {{ 'my_content.action.view'|trans }}
                            </a>
                        {% endif %}

                        {% if item.category == 'lists' and item.list.slug %}
                            {% set coordinate = item.list.kind ~ ':' ~ item.list.pubkey ~ ':' ~ item.list.slug %}
                        {% elseif item.category == 'drafts' %}
                            {% set coordinate = '30024:' ~ item.article.pubkey ~ ':' ~ item.article.slug %}
                        {% elseif item.category == 'published' %}
                            {% set coordinate = '30023:' ~ item.article.pubkey ~ ':' ~ item.article.slug %}
                        {% else %}
                            {% set coordinate = null %}
                        {% endif %}

                        {% if coordinate %}
                            <span data-controller="utility--copy-to-clipboard">
                                <code class="hidden" data-utility--copy-to-clipboard-target="textToCopy">{{ coordinate }}</code>
                                <button
                                    type="button"
                                    data-utility--copy-to-clipboard-target="copyButton"
                                    data-action="click->utility--copy-to-clipboard#copyToClipboard"
                                >
                                    {{ ux_icon('iconoir:copy', {class: 'icon'}) }}
                                    {{ 'my_content.action.copy_coordinate'|trans }}
                                </button>
                            </span>
                        {% endif %}

                        {% if item.category == 'published' and item.article.eventId %}
                            <hr>
                            <button
                                type="button"
                                class="my-content-menu__danger"
                                data-action="click->content--my-content-delete#open"
                                data-event-id="{{ item.article.eventId }}"
                                data-coordinate="30023:{{ item.article.pubkey }}:{{ item.article.slug }}"
                                data-article-title="{{ title }}"
                            >
                                {{ ux_icon('iconoir:trash', {class: 'icon'}) }}
                                <span data-delete-label>{{ 'my_content.action.delete'|trans }}</span>
                            </button>
                        {% endif %}
                    </div>
                </details>
            </article>
        {% else %}
            <div class="my-content-empty">
                {{ ux_icon('iconoir:search', {class: 'icon'}) }}
                <h2>{{ 'my_content.empty.title'|trans }}</h2>
                <p>{{ 'my_content.empty.description'|trans }}</p>
                {% if searchQuery or activeType != 'all' %}
                    <a class="btn btn--secondary" href="{{ path('my_content') }}">{{ 'my_content.filter.clear'|trans }}</a>
                {% else %}
                    <a class="btn" href="{{ path('editor-create') }}">{{ 'my_content.action.new_article'|trans }}</a>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    {% if totalPages > 1 %}
        <nav class="my-content-pagination" aria-label="{{ 'my_content.pagination.label'|trans }}">
            {% if page > 1 %}
                <a class="btn btn--secondary btn-sm my-content-pagination__previous" href="{{ path('my_content', currentQuery|merge({page: page - 1})) }}">
                    {{ ux_icon('iconoir:arrow-left', {class: 'icon'}) }}
                    {{ 'my_content.pagination.previous'|trans }}
                </a>
            {% endif %}
            <span>{{ 'my_content.pagination.page'|trans({'%current%': page, '%total%': totalPages}) }}</span>
            {% if page < totalPages %}
                <a class="btn btn--secondary btn-sm my-content-pagination__next" href="{{ path('my_content', currentQuery|merge({page: page + 1})) }}">
                    {{ 'my_content.pagination.next'|trans }}
                    {{ ux_icon('iconoir:arrow-right', {class: 'icon'}) }}
                </a>
            {% endif %}
        </nav>
    {% endif %}

    <dialog
        class="my-content-delete-dialog"
        data-content--my-content-delete-target="dialog"
        data-action="click->content--my-content-delete#dismissOnBackdrop"
        aria-labelledby="my-content-delete-title"
    >
        <div class="my-content-delete-dialog__header">
            <div>
                <p class="eyebrow">{{ 'my_content.delete.eyebrow'|trans }}</p>
                <h2 id="my-content-delete-title">{{ 'my_content.delete.title'|trans }}</h2>
            </div>
            <button
                type="button"
                class="my-content-delete-dialog__close"
                data-action="click->content--my-content-delete#cancel"
                aria-label="{{ 'my_content.action.close'|trans }}"
            >
                {{ ux_icon('iconoir:xmark', {class: 'icon'}) }}
            </button>
        </div>
        <p data-content--my-content-delete-target="description"></p>
        <div class="my-content-delete-dialog__actions">
            <button type="button" class="btn btn--secondary" data-action="click->content--my-content-delete#cancel">
                {{ 'my_content.action.cancel'|trans }}
            </button>
            <button
                type="button"
                class="btn my-content-delete-dialog__confirm"
                data-content--my-content-delete-target="confirm"
                data-action="click->content--my-content-delete#confirm"
            >
                {{ 'my_content.action.confirm_delete'|trans }}
            </button>
        </div>
    </dialog>
</section>
{% endblock %}
