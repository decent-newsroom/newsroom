{% extends 'layout.html.twig' %}

{% block body %}
    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5 mb-1">
            <h1>{{ 'follows.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'follows.eyebrow'|trans }}</p>
        </div>
    </section>

    <div class="w-container mb-5 mt-5">
        {% if not isLoggedIn %}
            <div class="alert alert-info">
                <h4>{{ 'follows.signInRequired'|trans }}</h4>
                <p class="mb-3">{{ 'follows.signInDescription'|trans }}</p>
                <a href="{{ path('app_login') }}" class="btn btn-primary">{{ 'text.signIn'|trans }}</a>
            </div>
        {% elseif error is defined %}
            <div class="alert alert-danger">
                <h4>{{ 'follows.error'|trans }}</h4>
                <p class="mb-0">{{ error }}</p>
            </div>
        {% elseif followCount is defined and followCount == 0 %}
            <div class="alert alert-info">
                <h4>{{ 'follows.noFollows'|trans }}</h4>
                <p class="mb-0">{{ 'follows.noFollowsHint'|trans }}</p>
            </div>
        {% elseif articles is empty %}
            <div class="alert alert-info">
                <h4>{{ 'follows.noArticles'|trans }}</h4>
                <p class="mb-0">{{ 'follows.noArticlesHint'|trans }}</p>
            </div>
        {% else %}
            <div class="discover-section">
                <twig:Organisms:CardList :list="articles" :authorsMetadata="authorsMetadata" class="article-list" />
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block aside %}
    <twig:Atoms:FeaturedWriters />
    <twig:Atoms:ForumAside />
{% endblock %}
