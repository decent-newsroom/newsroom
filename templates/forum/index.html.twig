{% extends 'layout.html.twig' %}
{% import 'macros/interest_set_card.html.twig' as iset %}

{% block body %}
    <twig:Atoms:PageHeading heading="Topics" tagline="Explore your interests"/>

    {% if deprecated is defined and deprecated %}
        <div class="deprecation-notice">
            <p>{{ 'forum.deprecated.notice'|trans }} <a href="{{ path('home_feed_tab', {tab: 'interests'}) }}">{{ 'forum.deprecated.link'|trans }}</a></p>
        </div>
    {% endif %}

{% if userInterests %}
    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5 mb-5">
            <h2>Your Interests</h2>
            <p>{{ 'forum.deprecated.notice'|trans }}</p>
        </div>
    </section>
{% endif %}

{% for catKey, category in topics %}
    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5 mb-5">
            <h2>
                <a href="{{ path('forum_main_topic', { topic: catKey }) }}">{{ category.name }}</a>
            </h2>
        </div>
    </section>
{% endfor %}
{% endblock %}

{% block aside %}{% endblock %}
