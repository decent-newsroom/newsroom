{% extends 'layout.html.twig' %}

{% block title %}{{ category.name }} — {{ brand_name }}{% endblock %}

{% block body %}
    <section class="w-container">
        <div class="discover-section">
            <form action="{{ path('app_search_index') }}"
                  method="get"
                  class="discover-search-form"
                  data-controller="search--nostr-redirect"
                  data-action="submit->search--nostr-redirect#submit">
                <label class="search">
                    <input type="search"
                           name="q"
                           placeholder="{{ 'discover.searchPlaceholder'|trans }}"
                           class="form-control"
                           data-search--nostr-redirect-target="input"
                           required
                    />
                    <button type="submit" class="btn btn-primary">
                        <twig:ux:icon name="iconoir:search" class="icon" /> {{ 'heading.search'|trans }}
                    </button>
                </label>
            </form>
        </div>
    </section>

    <section class="w-container mb-3">
        <div class="discover-section topics-strip">
            {% if mainTopicsMap is defined and mainTopicsMap is not empty %}
                <div class="topics-buttons d-flex flex-row flex-wrap gap-2 justify-content-center">
                    {% for key, name in mainTopicsMap %}
                        <a href="{{ path('forum_main_topic', { topic: key }) }}"
                           class="btn btn-sm {{ key == categoryKey ? 'btn-secondary' : 'btn-outline-primary' }}"
                           {% if key == categoryKey %}aria-current="page"{% endif %}>
                            {{ name }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>

    <section class="w-container">
        <div class="discover-section">
            {% if articles is empty %}
                <div class="alert alert-info">{{ 'topics.noArticles'|trans }}</div>
            {% else %}
                <twig:Organisms:CardList :list="articles" class="article-list" />
            {% endif %}

            {% if hasPrev or hasMore %}
                <nav class="pagination" aria-label="Topic pagination">
                    <div class="pagination-prev">
                        {% if hasPrev %}
                            <a class="pagination-link" href="{{ path('forum_main_topic', {topic: categoryKey, page: page - 1}) }}">&larr; Previous</a>
                        {% else %}
                            <span class="pagination-link pagination-disabled">&larr; Previous</span>
                        {% endif %}
                    </div>

                    <div class="pagination-info">
                        Page {{ page }}
                    </div>

                    <div class="pagination-next">
                        {% if hasMore %}
                            <a class="pagination-link" href="{{ path('forum_main_topic', {topic: categoryKey, page: page + 1}) }}">Next &rarr;</a>
                        {% else %}
                            <span class="pagination-link pagination-disabled">Next &rarr;</span>
                        {% endif %}
                    </div>
                </nav>
            {% endif %}
        </div>
    </section>
{% endblock %}

{% block aside %}{% endblock %}
