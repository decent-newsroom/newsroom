{# Payment targets tab — NIP-A3 kind 10133 (payto: payment targets) #}
<div class="settings-section"
     data-controller="nostr--nostr-settings-payment-targets"
     data-nostr--nostr-settings-payment-targets-publish-url-value="{{ path('api_settings_event_publish') }}"
     data-nostr--nostr-settings-payment-targets-targets-value="{{ paymentTargets|default([])|json_encode }}"
     data-nostr--nostr-settings-payment-targets-recognized-value="{{ paymentTargetTypes|default({})|json_encode }}">

    <h2 class="settings-section__title">{{ 'settings.payments.heading'|trans }}</h2>
    <p class="settings-section__desc">{{ 'settings.payments.description'|trans }}</p>

    <div class="payment-targets-list"
         data-nostr--nostr-settings-payment-targets-target="list">
        {% if paymentTargets is empty %}
            <p class="text-muted" data-nostr--nostr-settings-payment-targets-target="empty">
                {{ 'settings.payments.empty'|trans }}
            </p>
        {% endif %}

        {% for target in paymentTargets %}
            <div class="payment-target-row settings-multi-field__row"
                 data-nostr--nostr-settings-payment-targets-target="row">
                <label for="payment-target-type-{{ loop.index0 }}" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">
                    {{ 'settings.payments.type'|trans }}
                </label>
                <input type="text"
                       id="payment-target-type-{{ loop.index0 }}"
                       data-nostr--nostr-settings-payment-targets-target="typeInput"
                       value="{{ target.type }}"
                       placeholder="{{ 'settings.payments.typePlaceholder'|trans }}"
                       aria-label="{{ 'settings.payments.type'|trans }}"
                       class="payment-target-row__type">
                <label for="payment-target-authority-{{ loop.index0 }}" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">
                    {{ 'settings.payments.authority'|trans }}
                </label>
                <input type="text"
                       id="payment-target-authority-{{ loop.index0 }}"
                       data-nostr--nostr-settings-payment-targets-target="authorityInput"
                       value="{{ target.authority }}"
                       placeholder="{{ 'settings.payments.authorityPlaceholder'|trans }}"
                       aria-label="{{ 'settings.payments.authority'|trans }}"
                       class="payment-target-row__authority">
                <button type="button"
                        class="btn btn--secondary settings-multi-field__remove"
                        data-action="click->nostr--nostr-settings-payment-targets#removeRow">−</button>
            </div>
        {% endfor %}
    </div>

    <div class="settings-form__actions">
        <button type="button"
                class="btn btn--secondary"
                data-action="click->nostr--nostr-settings-payment-targets#addRow">
            + {{ 'settings.payments.addTarget'|trans }}
        </button>
        <button type="button"
                class="btn btn--primary"
                data-nostr--nostr-settings-payment-targets-target="publishButton"
                data-action="click->nostr--nostr-settings-payment-targets#publish">
            {{ 'settings.payments.publish'|trans }}
        </button>
    </div>

    {% if paymentTargetsRawJson is defined and paymentTargetsRawJson %}
        <details class="settings-raw-json mt-3">
            <summary class="settings-raw-json__toggle">{{ 'settings.payments.rawJson'|trans }}</summary>
            <pre class="settings-raw-json__content"><code>{{ paymentTargetsRawJson }}</code></pre>
        </details>
    {% endif %}

    {% if paymentTargetTypes is not empty %}
        <details class="settings-raw-json mt-3">
            <summary class="settings-raw-json__toggle">{{ 'settings.payments.recognized'|trans }}</summary>
            <ul class="payment-recognized-types">
                {% for type, meta in paymentTargetTypes %}
                    <li><code>{{ type }}</code> — {{ meta.label }} ({{ meta.shortLabel }})</li>
                {% endfor %}
            </ul>
        </details>
    {% endif %}
</div>

