{% extends 'layout.html.twig' %}

{% block title %}{{ 'auth.loginTitle'|trans }}{% endblock %}

{% block body %}
<div class="container my-5">
  <h1 class="h3 mb-4">{{ 'auth.login'|trans }}</h1>
  {% if authenticated %}
    <div class="alert alert-success">{{ 'auth.alreadyAuthenticated'|trans }}</div>
  {% else %}
    <div class="card" data-controller="utility--login-modal">
      <div class="card-body">
        <p class="text-muted small mb-3">{{ 'auth.nostrCredentials'|trans }}</p>
        <button class="btn btn--primary" data-action="click->utility--login-modal#openDialog">{{ 'auth.login'|trans }}</button>
      </div>
      <twig:LoginModal />
    </div>
  {% endif %}
</div>
{% endblock %}
