{% extends 'layout-full.html.twig' %}

{% block title %}Decent Newsroom — A decentralized platform for collaborative publishing{% endblock %}

{% block ogtags %}
    {{ parent() }}
    <meta property="og:title" content="Decent Newsroom — A decentralized platform for collaborative publishing">
    <meta property="og:description" content="Explore, publish articles, and create magazines on Nostr">
    <meta property="og:url" content="{{ url('home') }}">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Newsroom",
        "alternateName": "Decent Newsroom",
        "description": "A decentralized platform for collaborative publishing on Nostr",
        "url": "{{ url('home') }}",
        "potentialAction": {
            "@type": "SearchAction",
            "target": {
                "@type": "EntryPoint",
                "urlTemplate": "{{ url('app_search_index') }}?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
        }
    }
    </script>
{% endblock %}

{% block body %}
    <main class="home-landing">
        <section class="landing-hero">
            <div class="landing-hero__copy">
                <p class="eyebrow">{{ 'brand.tagline'|trans }}</p>
                <h1 class="brand">{{ brand_name }}</h1>
                <p class="lede">{{ 'home.hero.lede'|trans }}</p>
                <div class="landing-actions">
                    <a class="btn btn--lg" href="{{ path('discover') }}">{{ 'home.explore.cta'|trans }}</a>
                    <a class="btn btn--secondary btn--lg" href="{{ path('mag_wizard_setup') }}">{{ 'home.newsroom.cta'|trans }}</a>
                </div>
            </div>

            <figure class="landing-hero__preview">
                <img
                    src="{{ asset('images/preview-unfold.png') }}"
                    alt="{{ 'journey.landing.organized.heading'|trans }}"
                    loading="eager"
                    width="760"
                >
            </figure>
        </section>

        <section class="landing-paths">
            <div class="landing-path">
                <p class="eyebrow">{{ 'home.newsstand.eyebrow'|trans }}</p>
                <h2>{{ 'home.newsstand.heading'|trans }}</h2>
                <p>{{ 'home.newsstand.description'|trans }}</p>
                <a class="text-link" href="{{ path('newsstand') }}">
                    {{ 'home.newsstand.cta'|trans }}
                    {{ ux_icon('iconoir:arrow-right', {class: 'icon'}) }}
                </a>
            </div>

            <div class="landing-path">
                <p class="eyebrow">{{ 'home.explore.eyebrow'|trans }}</p>
                <h2>{{ 'home.explore.heading'|trans }}</h2>
                <p>{{ 'home.explore.description'|trans }}</p>
                <a class="text-link" href="{{ path('discover') }}">
                    {{ 'home.explore.cta'|trans }}
                    {{ ux_icon('iconoir:arrow-right', {class: 'icon'}) }}
                </a>
            </div>

            <div class="landing-path">
                <p class="eyebrow">{{ 'home.editor.eyebrow'|trans }}</p>
                <h2>{{ 'home.editor.heading'|trans }}</h2>
                <p>{{ 'home.editor.description'|trans }}</p>
                <a class="text-link" href="{{ path('editor-create') }}">
                    {{ 'home.editor.cta'|trans }}
                    {{ ux_icon('iconoir:arrow-right', {class: 'icon'}) }}
                </a>
            </div>

            <div class="landing-path">
                <p class="eyebrow">{{ 'home.newsroom.eyebrow'|trans }}</p>
                <h2>{{ 'home.newsroom.heading'|trans }}</h2>
                <p>{{ 'home.newsroom.description'|trans }}</p>
                <a class="text-link" href="{{ path('mag_wizard_setup') }}">
                    {{ 'home.newsroom.cta'|trans }}
                    {{ ux_icon('iconoir:arrow-right', {class: 'icon'}) }}
                </a>
            </div>
        </section>

        <section class="landing-feature">
            <div>
                <p class="eyebrow">{{ 'home.unfold.eyebrow'|trans }}</p>
                <h2>{{ 'home.unfold.heading'|trans }}</h2>
            </div>
            <div>
                <p class="lede">{{ 'home.unfold.description'|trans }}</p>
                <a class="btn btn--secondary" href="{{ path('unfold') }}">{{ 'home.unfold.cta'|trans }}</a>
            </div>
        </section>
    </main>
{% endblock %}
