{% extends 'layout.html.twig' %}

{% block title %}Decent Newsroom — A decentralized platform for collaborative publishing{% endblock %}

{% block ogtags %}
    {{ parent() }}
    <meta property="og:title" content="Decent Newsroom — A decentralized platform for collaborative publishing">
    <meta property="og:description" content="Explore, publish articles, and create magazines on Nostr">
    <meta property="og:url" content="{{ url('home') }}">

    {# Override default WebSite schema with more detailed home page schema #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Newsroom",
        "alternateName": "Decent Newsroom",
        "description": "A decentralized platform for collaborative publishing on Nostr",
        "url": "{{ url('home') }}",
        "headline": "Explore, publish articles, and create magazines",
        "about": [
            {
                "@type": "Thing",
                "name": "Decentralized Publishing"
            },
            {
                "@type": "Thing",
                "name": "Nostr Protocol"
            },
            {
                "@type": "Thing",
                "name": "Digital Magazines"
            }
        ],
        "potentialAction": [
            {
                "@type": "SearchAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": "{{ url('app_search_index') }}?q={search_term_string}"
                },
                "query-input": "required name=search_term_string"
            },
            {
                "@type": "ReadAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": "{{ url('newsstand') }}"
                },
                "name": "Browse Newsstand"
            }
        ],
        "publisher": {
            "@type": "Organization",
            "name": "Newsroom",
            "url": "{{ url('home') }}"
        }
    }
    </script>
{% endblock %}

{% block body %}

    <section class="ln-hero d-flex gap-3 center">
        <h1 class="brand">{{ brand_name }}</h1>
        <p class="eyebrow">{{ 'brand.tagline'|trans }}</p>
        <p class="lede mb-5">{{ 'home.hero.lede'|trans }}</p>
    </section>

    <!-- Preview -->
    <!--twig:Organisms:MagazinePreview subdomain="newsroommag" /-->

    <section class="ln-hero d-flex gap-3 center">
        <h1>{{ 'journey.landing.hero'|trans }}</h1>
        <p class="eyebrow">{{ 'journey.landing.eyebrow'|trans }}</p>
        <p class="lede measure mb-3">Decent Newsroom lets you take articles you've published on Nostr and organize them into a magazine: with categories, guest posts, stable article pages, and optional hosted subdomains.</p>
        <div class="cta-row mb-1">
            <a class="btn btn--primary btn--lg" href="/blog/setup">{{ 'journey.landing.cta'|trans }}</a>
        </div>
        <div class="cta-row mb-5">
            <p>See it live: <a href="https://newsroommag.decentnewsroom.com">Newsroom Magazine</a></p>
        </div>
    </section>

    <section class="ln-hero d-flex gap-3 center mt-0 pt-0">
        <div class="ln-hero__frame">
            <div class="frame">
                <img class="ln-preview-img" src="{{ asset('images/preview-unfold.png') }}" alt="{{ 'journey.landing.organized.heading'|trans }}" loading="eager" width="560">
            </div>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5">
            <h1>{{ 'home.newsstand.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.newsstand.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.newsstand.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('newsstand') }}">{{ 'home.newsstand.cta'|trans }}</a>
            </div>
        </div>
    </section>

    <section class="d-flex gap-3 center ln-section--search">
        <div class="container mt-5">
            <h1>{{ 'home.explore.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'home.explore.eyebrow'|trans }}</p>
        </div>
        <div class="mb-5">
            <p class="measure">{{ 'home.explore.description'|trans }}</p>
            <div class="cta-row">
                <a class="btn btn--primary" href="{{ path('discover') }}">{{ 'home.explore.cta'|trans }}</a>
            </div>
        </div>
    </section>

