{% extends 'layout.html.twig' %}

{% block title %}Home — {{ brand_name }}{% endblock %}

{% block body %}
    <twig:Organisms:EssayistPromo />

    <section class="w-container">
        <div class="home-feed" data-controller="content--home-tabs" data-content--home-tabs-active-tab-value="articles">

            <nav class="profile-tabs home-feed__tabs">
                <a href="{{ path('home_feed_tab', {tab: 'articles'}) }}"
                   class="tab-link active"
                   data-content--home-tabs-target="tab"
                   data-tab="articles"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'home_feed.tab.articles'|trans }}
                </a>

                <a href="{{ path('home_feed_tab', {tab: 'featuredpack'}) }}"
                   class="tab-link"
                   data-content--home-tabs-target="tab"
                   data-tab="featuredpack"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'home_feed.tab.featured_pack'|trans }}
                </a>

                <a href="{{ path('home_feed_tab', {tab: 'activityfeed'}) }}"
                   class="tab-link"
                   data-content--home-tabs-target="tab"
                   data-tab="activityfeed"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'home_feed.tab.activity'|trans }}
                </a>

                <a href="{{ path('home_feed_tab', {tab: 'updatesfeed'}) }}"
                   class="tab-link"
                   data-content--home-tabs-target="tab"
                   data-tab="updatesfeed"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'home_feed.tab.updates'|trans }}
                </a>

            </nav>

            <div class="home-feed__content" data-content--home-tabs-target="content">
                <turbo-frame id="home-tab-content" src="{{ path('home_feed_tab', {tab: 'articles'}) }}" loading="lazy" data-controller="content--article-list-cache" data-tab="articles" data-cache-max-age="300000">
                    <div class="home-feed__loading">
                        <div class="spinner"></div>
                        <p>{{ 'home_feed.loading'|trans }}</p>
                    </div>
                </turbo-frame>
            </div>
        </div>
    </section>
{% endblock %}

{% block aside %}
    <twig:Atoms:FeaturedWriters />
{% endblock %}


