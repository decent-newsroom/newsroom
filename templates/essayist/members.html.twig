{% extends 'layout.html.twig' %}

{% block title %}{{ 'essayist.members.title'|trans }} — {{ brand_name }}{% endblock %}

{% block body %}
    <section class="w-container essayist-members">
        <div class="essayist-members__header">
            <h1>{{ 'essayist.members.heading'|trans }}</h1>
            <p class="essayist-members__lede">
                {{ 'essayist.members.lede'|trans({
                    '%min%': minimumSats|number_format,
                    '%through%': coverageThrough|format_date('long')
                }) }}
            </p>

            {% if isMember %}
                <div class="essayist-alert essayist-alert--success">
                    {{ 'essayist.members.alreadyMember'|trans }}
                </div>
            {% elseif isAdmin %}
                <div class="essayist-alert essayist-alert--info">
                    {{ 'essayist.feed.adminNotice'|trans }}
                </div>
            {% endif %}
        </div>

        {# Claim zap form for logged-in users #}
        {% if app.user %}
            <div class="essayist-members__claim-section">
                <h2 class="essayist-members__claim-title">{{ 'essayist.claim.heading'|trans('Claim your zap') }}</h2>
                <p class="essayist-members__claim-description">{{ 'essayist.claim.description'|trans('Paid for a membership but do not see it reflected? Submit your claim below.') }}</p>
                <twig:Molecules:EssayistClaimZapButton />
            </div>
        {% endif %}

        {% if claimsToAttest is defined and claimsToAttest is not empty %}
            <div class="essayist-members__claim-section">
                <h2 class="essayist-members__claim-title">Confirm incoming membership payments</h2>
                <p class="essayist-members__claim-description">
                    These users claim they paid your wallet. Confirming acts like a superchat-style recipient attestation and grants membership.
                </p>

                <ul class="essayist-members__claims-to-attest">
                    {% for claim in claimsToAttest %}
                        <li class="essayist-members__claims-to-attest-item">
                            <div>
                                <p><strong>Payer:</strong> <code>{{ claim.payerPubkey|toNpub }}</code></p>
                                {% if claim.claimedAmountSats %}
                                    <p><strong>Claimed:</strong> {{ claim.claimedAmountSats|number_format }} sats</p>
                                {% endif %}
                                {% if claim.bolt11Invoice %}
                                    <p><strong>Invoice:</strong> <code>{{ claim.bolt11Invoice|slice(0, 42) ~ '...' }}</code></p>
                                {% endif %}
                                {% if claim.zapReceiptEventId %}
                                    <p><strong>Receipt ID:</strong> <code>{{ claim.zapReceiptEventId }}</code></p>
                                {% endif %}
                            </div>

                            <form method="post" action="{{ path('app_essayist_claim_attest', {id: claim.id}) }}" class="essayist-members__attest-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('essayist_attest_claim_' ~ claim.id) }}">
                                <input type="number" name="amount_sats" min="1" step="100" placeholder="Amount sats (optional)">
                                <input type="text" name="attestation_event_id" maxlength="64" placeholder="Optional kind:9741 event id">
                                <input type="text" name="note" maxlength="255" placeholder="Optional note">
                                <button type="submit" class="btn btn--primary">Confirm payment</button>
                            </form>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% if members is empty %}
            <p class="essayist-members__empty">{{ 'essayist.members.empty'|trans }}</p>
        {% else %}
            <ul class="essayist-members__list">
                {% for m in members %}
                    <li class="essayist-members__item">
                        <div class="essayist-members__avatar">
                            {% if m.picture %}
                                <img src="{{ m.picture }}" alt="" loading="lazy" referrerpolicy="no-referrer">
                            {% else %}
                                <span class="essayist-members__avatar-placeholder" aria-hidden="true"></span>
                            {% endif %}
                        </div>
                        <div class="essayist-members__body">
                            <a class="essayist-members__name" href="{{ path('author-profile', {npub: m.npub}) }}">
                                {{ m.displayName }}
                            </a>
                            {% if m.isFollowed %}
                                <span class="essayist-members__badge essayist-members__badge--follow">{{ 'essayist.members.badge.follow'|trans }}</span>
                            {% endif %}
                            {% if m.isEarlyBird %}
                                <span class="essayist-members__badge essayist-members__badge--earlybird">{{ 'essayist.members.badge.earlybird'|trans }}</span>
                            {% endif %}
                            {% if m.nip05 %}
                                <p><span class="essayist-members__nip05">{{ m.nip05 }}</span></p>
                            {% endif %}
                            {% if m.about %}
                                <p class="essayist-members__about">{{ m.about|u.truncate(180, '…') }}</p>
                            {% endif %}
                            <p class="essayist-members__lud16"><code>{{ m.lud16 }}</code></p>
                        </div>
                        <div class="essayist-members__action">
                            {% if app.user.userIdentifier != (m.pubkey|toNpub) %}
                                <twig:Molecules:ZapButton
                                    recipientPubkey="{{ m.pubkey }}"
                                    recipientLud16="{{ m.lud16 }}"
                                    :initialAmount="1000"
                                    :enableMembershipClaim="true"
                                />
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}

        <p class="essayist-members__footnote">
            {{ 'essayist.members.footnote'|trans({
                '%min%': minimumSats|number_format,
                '%through%': coverageThrough|format_date('long')
            }) }}
        </p>
    </section>
{% endblock %}






