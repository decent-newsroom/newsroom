{% extends 'layout.html.twig' %}

{% block title %}{{ 'essayist.home.title'|trans }} — {{ brand_name }}{% endblock %}

{% block body %}
    <twig:Atoms:PageHeading heading="{{ 'essayist.home.heading'|trans }}" tagline="{{ 'essayist.home.subheading'|trans }}" />
    <div class="actions center">
        <a class="btn btn--primary" href="{{ path('app_essayist_members') }}">{{ 'essayist.members.heading'|trans }}</a>
    </div>
    <section class="w-container">
        <div class="home-feed" data-controller="content--home-tabs" data-content--home-tabs-active-tab-value="foryou">

            <nav class="profile-tabs home-feed__tabs">
                <a href="{{ path('app_essayist_home_tab', {tab: 'foryou'}) }}"
                   class="tab-link active"
                   data-content--home-tabs-target="tab"
                   data-tab="foryou"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'essayist.home.tab.foryou'|trans }}
                </a>
                <a href="{{ path('app_essayist_home_tab', {tab: 'follows'}) }}"
                   class="tab-link"
                   data-content--home-tabs-target="tab"
                   data-tab="follows"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'essayist.home.tab.follows'|trans }}
                </a>
                <a href="{{ path('app_essayist_home_tab', {tab: 'topics'}) }}"
                   class="tab-link"
                   data-content--home-tabs-target="tab"
                   data-tab="topics"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'essayist.home.tab.topics'|trans }}
                </a>
                <a href="{{ path('app_essayist_home_tab', {tab: 'activity'}) }}"
                   class="tab-link"
                   data-content--home-tabs-target="tab"
                   data-tab="activity"
                   data-action="click->content--home-tabs#switchTab">
                    {{ 'essayist.home.tab.activity'|trans }}
                </a>
            </nav>

            <div class="home-feed__content" data-content--home-tabs-target="content">
                <turbo-frame id="home-tab-content" src="{{ path('app_essayist_home_tab', {tab: 'foryou'}) }}" loading="lazy" target="_top">
                    <div class="home-feed__loading">
                        <div class="spinner"></div>
                        <p>{{ 'home_feed.loading'|trans }}</p>
                    </div>
                </turbo-frame>
            </div>

        </div>
    </section>
{% endblock %}

{% block aside %}
    <nav class="essayist-feed-nav">
        <a href="{{ path('app_essayist_feed') }}" class="btn btn--sm">{{ 'essayist.home.nav.allArticles'|trans }}</a>
        <a href="{{ path('app_static_essayist') }}" class="btn btn--sm">{{ 'essayist.feed.backToLanding'|trans }}</a>
        <a href="{{ path('app_essayist_members') }}" class="btn btn--sm">{{ 'essayist.members.heading'|trans }}</a>
    </nav>

    {# ── Latest essays widget — live via Mercure SSE ── #}
    <div class="essayist-latest-essays-widget"
         data-controller="content--essayist-latest"
         data-content--essayist-latest-topic-value="{{ mercure_topic }}"
         data-content--essayist-latest-keepalive-url-value="{{ path('app_essayist_home_keepalive') }}">
        <twig:Atoms:LatestEssayistArticles :limit="2" />
    </div>

    {% if featuredPackInfo is not null and featuredPackMembers is not empty %}
        <div class="essayist-featured-pack">
            <h3 class="essayist-featured-pack__heading">{{ 'essayist.home.featuredPack.heading'|trans }}</h3>
            <ul class="essayist-featured-pack__list">
                {% for member in featuredPackMembers|slice(0, 8) %}
                    <li class="essayist-featured-pack__item">
                        <a href="{{ path('author-profile', {npub: member.npub}) }}" class="essayist-featured-pack__member">
                            {% if member.picture %}
                                <img src="{{ member.picture }}" alt="{{ member.displayName }}" class="essayist-featured-pack__avatar" width="32" height="32" loading="lazy" />
                            {% else %}
                                <span class="essayist-featured-pack__avatar essayist-featured-pack__avatar--placeholder"></span>
                            {% endif %}
                            <span class="essayist-featured-pack__name">{{ member.displayName ?: (member.npub|slice(0, 12) ~ '…') }}</span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
            {% if featuredPackMembers|length > 8 %}
                <p class="essayist-featured-pack__more">
                    {{ 'essayist.home.featuredPack.andMore'|trans({'%count%': featuredPackMembers|length - 8}) }}
                </p>
            {% endif %}
            <a href="{{ path('follow_pack_view', {npub: featuredPackInfo.npub, dtag: featuredPackInfo.dtag}) }}" class="btn btn--sm mt-2">
                {{ 'essayist.home.featuredPack.viewAll'|trans }}
            </a>
        </div>
    {% endif %}
{% endblock %}

