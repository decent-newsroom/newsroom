<turbo-frame id="home-tab-content" target="_top">
    {% if not isLoggedIn|default(true) %}
        <div class="alert alert-info">
            <p>{{ 'essayist.home.topics.signInRequired'|trans }}</p>
        </div>
    {% elseif interestTags is defined and interestTags is empty %}
        <div class="alert alert-info">
            <h4>{{ 'home_feed.interests.noInterests'|trans }}</h4>
            <p>{{ 'home_feed.interests.noInterestsHint'|trans }}</p>
            <a data-turbo-frame="_top" href="{{ path('my_interests') }}" class="btn btn-primary btn-sm mt-2">{{ 'home_feed.interests.configure'|trans }}</a>
        </div>
    {% elseif articles is empty %}
        <div class="alert alert-info">
            <p>{{ 'essayist.home.topics.noArticles'|trans }}</p>
        </div>
    {% else %}
        <twig:Organisms:CardList :list="articles" :authorsMetadata="authorsMetadata" class="article-list" />
    {% endif %}
</turbo-frame>

