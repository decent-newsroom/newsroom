<turbo-frame id="home-tab-content" target="_top">
    {% if not isLoggedIn|default(true) %}
        <div class="alert alert-info">
            <p>{{ 'essayist.home.activity.signInRequired'|trans }}</p>
        </div>
    {% elseif activity is empty %}
        <div class="alert alert-info">
            <p>{{ 'essayist.home.activity.empty'|trans }}</p>
        </div>
    {% else %}
        <div class="article-list">
            {% for item in activity %}
                <div class="mb-2">
                    <span class="text-muted">
                        {{ ('essayist.home.activity.type.' ~ item.type)|trans }}
                    </span>
                </div>
                {% if item.type == 'highlight' and item.highlight is defined %}
                    {% set highlightItem = item.highlight|merge({
                        pubkey: item.event.pubkey,
                        created_at: item.event.createdAt,
                    }) %}
                    {% include 'partial/_highlight_feed_card.html.twig' with {highlight: highlightItem} %}
                {% else %}
                    {% include 'partial/_bookmark_event_card.html.twig' with {event: item.event} %}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
</turbo-frame>

