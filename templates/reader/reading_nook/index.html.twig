{% extends 'reading-nook-layout.html.twig' %}

{% set activeFilterCount = 0 %}
{% if filters.q is not empty %}{% set activeFilterCount = activeFilterCount + 1 %}{% endif %}
{% if filters.section != 'all' %}{% set activeFilterCount = activeFilterCount + 1 %}{% endif %}
{% if filters.timespan != 'all' %}{% set activeFilterCount = activeFilterCount + 1 %}{% endif %}
{% if filters.tag is not empty %}{% set activeFilterCount = activeFilterCount + 1 %}{% endif %}
{% set topTags = allTags|slice(0, 8) %}
{% set filterQuery = {
    q: filters.q,
    timespan: filters.timespan,
    tag: filters.tag,
} %}

{% block body %}
<section class="reading-nook-page">
    <twig:Atoms:PageHeading :heading="'reading_nook.title'|trans" :tagline="'reading_nook.subtitle'|trans" />

    <div class="reading-nook-shell">

        <div class="reading-nook-content">
            <nav class="reading-nook-tabs" aria-label="{{ 'reading_nook.filters.section'|trans }}">
                <a
                    href="{{ path('reading_nook', filterQuery|merge({section: 'all'})) }}"
                    {% if filters.section == 'all' %}aria-current="page"{% endif %}
                >
                    <span>{{ 'reading_nook.section.all'|trans }}</span>
                    <strong>{{ totalCount }}</strong>
                </a>
                {% for section in sectionKeys %}
                    <a
                        href="{{ path('reading_nook', filterQuery|merge({section: section})) }}"
                        {% if filters.section == section %}aria-current="page"{% endif %}
                    >
                        <span>{{ sectionLabels[section]|trans }}</span>
                        <strong>{{ sectionCounts[section] }}</strong>
                    </a>
                {% endfor %}
            </nav>

            <form class="reading-nook-toolbar" action="{{ path('reading_nook') }}" method="get">
                <input type="hidden" name="section" value="{{ filters.section }}">

                <label class="reading-nook-search">
                    <span class="visually-hidden">{{ 'reading_nook.filters.search'|trans }}</span>
                    {{ ux_icon('iconoir:search', {class: 'icon'}) }}
                    <input
                        id="nook-search"
                        type="search"
                        name="q"
                        value="{{ filters.q }}"
                        placeholder="{{ 'reading_nook.filters.search_placeholder'|trans }}"
                        autocomplete="off"
                    >
                </label>

                <label class="reading-nook-select" for="nook-timespan">
                    <span>{{ 'reading_nook.filters.timespan'|trans }}</span>
                    <select id="nook-timespan" name="timespan">
                        {% for value, label in timespanOptions %}
                            <option value="{{ value }}"{% if filters.timespan == value %} selected{% endif %}>{{ label|trans }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label class="reading-nook-select" for="nook-tag">
                    <span>{{ 'reading_nook.filters.tag'|trans }}</span>
                    <select id="nook-tag" name="tag">
                        <option value="">{{ 'reading_nook.filters.any_tag'|trans }}</option>
                        {% for tag in allTags %}
                            <option value="{{ tag }}"{% if filters.tag == tag %} selected{% endif %}>#{{ tag }}</option>
                        {% endfor %}
                    </select>
                </label>

                <button class="btn btn-sm" type="submit">{{ 'reading_nook.filters.apply'|trans }}</button>

                {% if activeFilterCount > 0 %}
                    <br>
                    <a class="reading-nook-toolbar__clear" href="{{ path('reading_nook') }}">
                        {{ 'reading_nook.filters.reset'|trans }}
                    </a>
                {% endif %}
            </form>

            <div class="reading-nook-results">
                <p>{{ 'reading_nook.results_count'|trans({'%count%': filteredCount}) }}</p>

                {% if activeFilterCount > 0 %}
                    <div class="reading-nook-results__filters">
                        {% if filters.section != 'all' %}
                            <span><strong>{{ 'reading_nook.filters.section'|trans }}</strong> {{ sectionLabels[filters.section]|default('reading_nook.section.all')|trans }}</span>
                        {% endif %}
                        {% if filters.timespan != 'all' %}
                            <span><strong>{{ 'reading_nook.filters.timespan'|trans }}</strong> {{ timespanOptions[filters.timespan]|default('reading_nook.timespan.all')|trans }}</span>
                        {% endif %}
                        {% if filters.tag is not empty %}
                            <span><strong>{{ 'reading_nook.filters.tag'|trans }}</strong> #{{ filters.tag }}</span>
                        {% endif %}
                        {% if filters.q is not empty %}
                            <span><strong>{{ 'reading_nook.filters.search'|trans }}</strong> {{ filters.q }}</span>
                        {% endif %}
                    </div>
                {% endif %}
            </div>

            <div class="reading-nook-inventory">
                <div class="reading-nook-row reading-nook-row--head" aria-hidden="true">
                    <span>{{ 'reading_nook.column.item'|trans }}</span>
                    <span>{{ 'reading_nook.column.section'|trans }}</span>
                    <span>{{ 'reading_nook.column.date'|trans }}</span>
                    <span>{{ 'reading_nook.column.count'|trans }}</span>
                    <span>&nbsp;</span> {# actions #}
                </div>

                {% for item in items %}
                    {% set title = item.title %}
                    {% set titleUrl = item.url ?: item.manageUrl %}
                    {% set rowDate = item.updatedAt ? item.updatedAt : item.createdAt %}
                    {% set countValue = null %}
                    {% set countLabel = null %}
                    {% if item.meta.itemCount is defined %}
                        {% set countValue = item.meta.itemCount %}
                        {% set countLabel = 'reading_nook.item.entries'|trans %}
                    {% elseif item.meta.topicCount is defined %}
                        {% set countValue = item.meta.topicCount %}
                        {% set countLabel = 'reading_nook.item.topics'|trans %}
                    {% elseif item.meta.memberCount is defined %}
                        {% set countValue = item.meta.memberCount %}
                        {% set countLabel = 'reading_nook.item.members'|trans %}
                    {% endif %}

                    <article class="reading-nook-row" data-nook-section="{{ item.section }}">
                        <div class="reading-nook-row__main">
                            <span class="reading-nook-row__icon reading-nook-row__icon--{{ item.section|replace({'_': '-'}) }}" aria-hidden="true">
                                {% if item.section == 'bookmarks' %}
                                    {{ ux_icon('iconoir:bookmark', {class: 'icon'}) }}
                                {% elseif item.section == 'interests' %}
                                    {{ ux_icon('iconoir:compass', {class: 'icon'}) }}
                                {% elseif item.section == 'follow_packs' %}
                                    {{ ux_icon('iconoir:community', {class: 'icon'}) }}
                                {% elseif item.section == 'subscriptions' %}
                                    {{ ux_icon('iconoir:rss-feed', {class: 'icon'}) }}
                                {% else %}
                                    {{ ux_icon('iconoir:journal-page', {class: 'icon'}) }}
                                {% endif %}
                            </span>
                            <div>
                                <h2>
                                    {% if titleUrl %}
                                        <a href="{{ titleUrl }}">{{ title }}</a>
                                    {% else %}
                                        <span>{{ title }}</span>
                                    {% endif %}
                                </h2>

                                {% if item.summary %}
                                    <p>{{ item.summary }}</p>
                                {% endif %}

                                {% if item.tags is not empty %}
                                    <div class="reading-nook-row__tags" aria-label="{{ 'reading_nook.filters.tag'|trans }}">
                                        {% for tag in item.tags|slice(0, 4) %}
                                            <span>#{{ tag }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="reading-nook-row__status">
                            <span class="reading-nook-status reading-nook-status--{{ item.section|replace({'_': '-'}) }}">
                                {{ sectionLabels[item.section]|trans }}
                            </span>
                            {% if item.meta.sourceTypeLabel is defined %}
                                <small>{{ item.meta.sourceTypeLabel|trans }}</small>
                            {% else %}
                                <small>{{ 'reading_nook.item.kind'|trans }} {{ item.kind }}</small>
                            {% endif %}
                        </div>

                        <time datetime="{{ rowDate|date('c') }}">
                            {{ rowDate|date('Y-m-d') }}
                        </time>

                        <span class="reading-nook-row__count">
                            {% if countValue is not null %}
                                <strong>{{ countValue }}</strong>
                                <small>{{ countLabel }}</small>
                            {% else %}
                                &mdash;
                            {% endif %}
                        </span>

                        {% if item.url or item.manageUrl %}
                            <details class="reading-nook-menu" name="reading-nook-actions">
                                <summary aria-label="{{ 'reading_nook.action.menu'|trans({'%title%': title}) }}">
                                    {{ ux_icon('iconoir:plus', {class: 'icon'}) }}
                                </summary>
                                <div class="reading-nook-menu__panel">
                                    {% if item.url %}
                                        <a href="{{ item.url }}">
                                            {{ ux_icon('iconoir:open-new-window', {class: 'icon'}) }}
                                            {{ 'reading_nook.item.open'|trans }}
                                        </a>
                                    {% endif %}
                                    {% if item.manageUrl %}
                                        <a href="{{ item.manageUrl }}">
                                            {{ ux_icon('iconoir:edit-pencil', {class: 'icon'}) }}
                                            {{ 'reading_nook.item.manage'|trans }}
                                        </a>
                                    {% endif %}
                                </div>
                            </details>
                        {% else %}
                            <span class="reading-nook-row__no-actions" aria-hidden="true">&nbsp;</span>
                        {% endif %}
                    </article>
                {% else %}
                    <div class="reading-nook-empty">
                        {{ ux_icon('iconoir:search', {class: 'icon'}) }}
                        <p>{{ 'reading_nook.empty'|trans }}</p>
                        {% if activeFilterCount > 0 %}
                            <a class="btn btn-secondary btn-sm" href="{{ path('reading_nook') }}">{{ 'reading_nook.filters.reset'|trans }}</a>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block aside %}
    <div class="reading-nook-aside">
        <section class="reading-nook-aside__panel">
            <h2>{{ 'reading_nook.title'|trans }}</h2>
            <div class="reading-nook-aside__stats">
                <div>
                    <span>{{ 'reading_nook.summary.total'|trans }}</span>
                    <strong>{{ totalCount }}</strong>
                </div>
                <div>
                    <span>{{ 'reading_nook.summary.visible'|trans }}</span>
                    <strong>{{ filteredCount }}</strong>
                </div>
                <div>
                    <span>{{ 'reading_nook.summary.filters'|trans }}</span>
                    <strong>{{ activeFilterCount }}</strong>
                </div>
            </div>
        </section>

        <section class="reading-nook-aside__panel">
            <h2>{{ 'reading_nook.filters.section'|trans }}</h2>
            <nav class="reading-nook-aside__nav">
                <a
                    href="{{ path('reading_nook', filterQuery|merge({section: 'all'})) }}"
                    {% if filters.section == 'all' %}aria-current="page"{% endif %}
                >
                    <span>{{ 'reading_nook.section.all'|trans }}</span>
                    <strong>{{ filteredCount }} / {{ totalCount }}</strong>
                </a>
                {% for section in sectionKeys %}
                    <a
                        href="{{ path('reading_nook', filterQuery|merge({section: section})) }}"
                        {% if filters.section == section %}aria-current="page"{% endif %}
                    >
                        <span>{{ sectionLabels[section]|trans }}</span>
                        <strong>{{ filteredSectionCounts[section] }} / {{ sectionCounts[section] }}</strong>
                    </a>
                {% endfor %}
            </nav>
        </section>

        {% if topTags is not empty %}
            <section class="reading-nook-aside__panel">
                <h2>{{ 'reading_nook.aside.top_tags'|trans }}</h2>
                <div class="reading-nook-aside__tags">
                    {% for tag in topTags %}
                        <a href="{{ path('reading_nook', {
                            q: filters.q,
                            section: filters.section,
                            timespan: filters.timespan,
                            tag: tag,
                        }) }}">#{{ tag }}</a>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <section class="reading-nook-aside__panel reading-nook-aside__panel--cta ln-section--reader">
            <div>{{ 'nav.discoverMoreContent'|trans }}</div>
            <a class="btn" href="{{ path('discover') }}">{{ 'nav.browseArticles'|trans }}</a>
        </section>
    </div>
{% endblock %}
