{% extends 'layout.html.twig' %}

{% block title %}{{ 'expressionsList.heading'|trans }} — {{ brand_name }}{% endblock %}

{% block ogtags %}
    <meta property="og:title" content="{{ 'expressionsList.heading'|trans }} - {{ brand_name }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="{{ 'expressionsList.eyebrow'|trans }}">
    <meta property="og:site_name" content="{{ brand_name }}">
{% endblock %}

{% block body %}
    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5 mb-5">
            <h1>{{ 'expressionsList.heading'|trans }}</h1>
            <p class="eyebrow">{{ 'expressionsList.eyebrow'|trans }}</p>
        </div>
    </section>
    <section class="mb-5">
        <twig:Organisms:ExpressionList />
    </section>
{% endblock %}

