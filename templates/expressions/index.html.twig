{% extends 'expressions-layout.html.twig' %}

{% set currentTab = activeTab|default('expressions') %}

{% block body %}
<section class="my-content-page expression-workspace-page">
    <header class="my-content-header expression-workspace-header">
        <div class="my-content-header__copy">
            <p class="eyebrow">{{ 'expressions.workspace.eyebrow'|trans }}</p>
            <h1>{{ 'expressions.workspace.title'|trans }}</h1>
            <p>{{ 'expressions.workspace.description'|trans }}</p>
        </div>
        <div class="my-content-header__actions">
            <a class="btn" href="{{ path('expression_create') }}">
                {{ ux_icon('iconoir:edit-pencil', {class: 'icon'}) }}
                {{ 'expressionsList.createNew'|trans }}
            </a>
        </div>
    </header>

    <nav class="my-content-tabs" aria-label="{{ 'expressions.workspace.tabs.label'|trans }}">
        <a href="{{ path('expressions_workspace', {tab: 'expressions'}) }}" {% if currentTab == 'expressions' %}aria-current="page"{% endif %}>
            <span>{{ 'expressions.workspace.tabs.expressions'|trans }}</span>
        </a>
        <a href="{{ path('expressions_workspace', {tab: 'spells'}) }}" {% if currentTab == 'spells' %}aria-current="page"{% endif %}>
            <span>{{ 'expressions.workspace.tabs.spells'|trans }}</span>
        </a>
    </nav>

    <div class="my-content-results expression-workspace-links">
        <p>{{ 'expressions.workspace.testing_hint'|trans }}</p>
        <a href="{{ path(currentTab == 'spells' ? 'spell_list' : 'expression_list') }}">{{ 'expressions.workspace.open_public_list'|trans }}</a>
    </div>

    {% if currentTab == 'spells' %}
        <section class="expression-workspace-list">
            <twig:Organisms:SpellList />
        </section>
    {% else %}
        <section class="expression-workspace-list">
            <twig:Organisms:ExpressionList />
        </section>
    {% endif %}
</section>
{% endblock %}

