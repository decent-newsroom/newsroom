{% extends 'layout.html.twig' %}

{% block title %}{{ title }} — {{ brand_name }}{% endblock %}

{% block ogtags %}
    <meta property="og:title" content="{{ title }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    {% if description %}
        <meta property="og:description" content="{{ description }}">
    {% endif %}
    <meta property="og:site_name" content="{{ brand_name }}">
{% endblock %}

{% block body %}
    <section class="d-flex gap-3 center ln-section--newsstand mb-3">
        <div class="container mt-5">
            <h1>{{ title }}</h1>
            {% if description %}
                <p class="eyebrow">{{ description }}</p>
            {% endif %}
            <div>
                {{ 'expressionView.by'|trans }}
                <twig:Molecules:UserFromNpub :ident="authorNpub" />
            </div>
        </div>
    </section>

    <section class="w-container mb-5">
        {% if error is defined and error %}
            <div class="alert alert-warning">
                {{ error }}
            </div>
        {% elseif needsLogin is defined and needsLogin %}
            <div class="alert alert-info">
                {{ 'expressionView.loginRequired'|trans }}
            </div>
        {% elseif articles is empty %}
            <div class="alert alert-info">
                {{ 'expressionView.noResults'|trans }}
            </div>
        {% else %}
            {# Expressions can return any event kind. Split longform articles
               (which render nicely as grid cards) from other kinds (rendered
               via the kind-dispatching bookmark card partial). #}
            {% set articleCards = [] %}
            {% set otherEvents = [] %}
            {% for item in articles %}
                {% if item.kind in [30023, 30024] and item.slug is not empty and item.title is not empty %}
                    {% set articleCards = articleCards|merge([item]) %}
                {% else %}
                    {% set otherEvents = otherEvents|merge([item]) %}
                {% endif %}
            {% endfor %}

            {% if articleCards|length > 0 %}
                <twig:Organisms:CardList :list="articleCards" :authorsMetadata="authorsMetadata" class="article-list" />
            {% endif %}

            {% if otherEvents|length > 0 %}
                <div class="expression-results-events">
                    {% for event in otherEvents %}
                        {% include 'partial/_bookmark_event_card.html.twig' with {event: event} %}
                    {% endfor %}
                </div>
            {% endif %}

            {% if pager is defined and pager.getNbPages() > 1 %}
                <twig:Atoms:Pagination :pager="pager" route="expression_view" :routeParams="{npub: authorNpub, dtag: exprDtag}" />
            {% endif %}
        {% endif %}
    </section>
{% endblock %}

{% block aside %}
    <div class="d-flex gap-3 center mt-3 mb-3 ln-section--reader">
        <a href="{{ path('expression_list') }}" class="btn btn-sm">← {{ 'expressionView.backToList'|trans }}</a>
    </div>
{% endblock %}

