{% extends 'base.html.twig' %}

{% block layout %}
    <div class="layout" data-controller="ui--sidebar-toggle">
        <div class="aside-wrapper">
            <nav id="leftNav">
                <header>
                    <button class="close" data-action="click->ui--sidebar-toggle#close" aria-label="{{ 'nav.closeLeftSidebar'|trans }}">✕</button>
                </header>
                <div class="nav-section">
                    <div class="nav-section__label">{{ 'nav.discover'|trans }}</div>
                    <ul class="user-nav">
                        <li><a href="{{ path('discover') }}">{{ 'nav.articles'|trans }}</a></li>
                        <li><a href="{{ path('forum') }}">{{ 'nav.topics'|trans }}</a></li>
                        <li><a href="{{ path('media-discovery') }}">{{ 'nav.multimedia'|trans }}</a></li>
                        <li><a href="{{ path('highlights') }}">{{ 'nav.highlights'|trans }}</a></li>
                    </ul>
                </div>

                <div class="nav-section">
                    <div class="nav-section__label">{{ 'nav.newsroom'|trans }}</div>
                    <ul class="user-nav">
                        <li><a href="{{ path('newsstand') }}">{{ 'nav.newsstand'|trans }}</a></li>
                        <li class="hidden"><a href="{{ path('bookshelf') }}">{{ 'nav.bookshelf'|trans }}</a></li>
                        <li><a href="{{ path('lists') }}">{{ 'nav.collections'|trans }}</a></li>
                        <li class="hidden"><a href="{{ path('follow_packs') }}">{{ 'nav.followPacks'|trans }}</a></li>
                        {% if app.user %}
                            <li class="hidden"><a href="{{ path('my_content') }}">{{ 'nav.myContent'|trans }}</a></li>
                            <li><a href="{{ path('my_bookmarks') }}">{{ 'nav.bookmarks'|trans }}</a></li>
                            <li><a href="{{ path('my_magazines') }}">{{ 'nav.myMagazines'|trans }}</a></li>
                            <li><a href="{{ path('reading_list_index') }}">{{ 'nav.myReadingLists'|trans }}</a></li>
                            <li><a href="{{ path('my_interests') }}">{{ 'nav.myInterests'|trans }}</a></li>
                            <li><a href="{{ path('media_manager') }}">Media Manager</a></li>
                        {% endif %}
                    </ul>
                </div>

                <div class="nav-section">
                    <div class="nav-section__label">{{ 'nav.create'|trans }}</div>
                    <ul class="user-nav">
                        <li><a href="{{ path('mag_wizard_setup') }}">{{ 'nav.magazine'|trans }}</a></li>
                        <li><a href="{{ path('reading_list_index') }}">{{ 'nav.readingList'|trans }}</a></li>
                        <li><a href="{{ path('editor-create') }}">{{ 'nav.article'|trans }}</a></li>
                    </ul>
                </div>
                <twig:UserMenu />

                <div class="container mt-2 mb-2 text-end hidden">
                    <a href="{{ path('feedback_form') }}" class="btn btn-outline-primary">{{ 'nav.sendFeedback'|trans }}</a>
                </div>
                {% block nav %}{% endblock %}
            </nav>
        </div>
        <main>
            {% block body %}{% endblock %}

        </main>
        <div>
            <aside id="rightNav">
                <header>
                    <button class="close" data-action="click->sidebar-toggle#close" aria-label="{{ 'nav.closeRightSidebar'|trans }}">✕</button>
                </header>
                <div class="d-flex gap-3 center mt-3 mb-3">
                    <a class="btn" href="{{ path('blog_journey_landing') }}">{{ 'nav.startBlog'|trans }}</a>
                </div>
                {% block aside %}
                    {# Contribution invitation section #}
                    {% if contribution_npub and contribution_lud16 %}
                        <div class="contribution-section mt-3 mb-3 p-3 ln-section--newsstand">
                            <div class="text-center mb-2">
                                <strong>{{ 'contribution.title'|trans }}</strong>
                            </div>
                            <p class="small text-muted mb-2 text-center hidden">
                                {{ 'contribution.description'|trans }}
                            </p>
                            <div class="text-center">
                                <twig:Molecules:ZapButton
                                    btnClass="btn-sm w-100"
                                    recipientPubkey="{{ contribution_npub|toHex }}"
                                    recipientLud16="{{ contribution_lud16 }}"
                                />
                            </div>
                        </div>
                    {% endif %}
                {% endblock %}
            </aside>
        </div>

        {# Back to top button #}
        <div data-controller="ui--back-to-top">
            <button class="back-to-top-btn"
                    data-ui--back-to-top-target="button"
                    data-action="click->ui--back-to-top#scrollToTop"
                    aria-label="{{ 'nav.backToTop'|trans }}"
                    title="{{ 'nav.backToTop'|trans }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="18 15 12 9 6 15"></polyline>
                </svg>
            </button>
        </div>
    </div>
{% endblock %}
