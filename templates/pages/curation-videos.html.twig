{% extends 'layout.html.twig' %}

{% block ogtags %}
    <meta property="og:title" content="{{ curation.title }} - Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="{{ curation.summary ?? '' }}">
    <meta property="og:site_name" content="Newsroom">
{% endblock %}

{% block body %}
    <section class="ln-section--newsstand curation-page__hero">
        <div class="curation-page__hero-inner">
            <h1 class="curation-page__hero-title">{{ curation.title }}</h1>
            <div class="curation-page__hero-meta">
                <span class="badge bg-secondary">{{ type }}</span>
                <span class="badge bg-info text-dark">{{ mediaEvents|length }} video{{ mediaEvents|length != 1 ? 's' : '' }}</span>
            </div>
            {% if curation.summary %}
                <p class="eyebrow curation-page__hero-summary">{{ curation.summary }}</p>
            {% endif %}
            <div class="curation-page__hero-author">by <twig:Molecules:UserFromNpub :ident="curation.pubkey" /></div>
        </div>
    </section>

    <div class="curation-page__content"
         {% if hasPendingMediaSync %}
             data-controller="content--curation-mercure"
             data-content--curation-mercure-status-url-value="{{ curationMediaSyncStatusUrl }}"
             data-content--curation-mercure-initial-missing-count-value="{{ pendingMediaCount }}"
             data-content--curation-mercure-reload-url-value="{{ app.request.uri }}"
         {% endif %}>
        {% if mediaEvents|length > 0 %}
            <div class="video-playlist" data-controller="media--video-playlist">

                {# Main player area #}
                <div class="video-playlist__player">
                    <div class="video-playlist__player-wrapper" data-media--video-playlist-target="player">
                        <video controls preload="metadata" class="video-player">
                            <source src="" />
                            Your browser does not support the video tag.
                        </video>
                    </div>
                    <h2 class="video-playlist__player-title" data-media--video-playlist-target="playerTitle"></h2>
                    <p class="video-playlist__player-meta" data-media--video-playlist-target="playerMeta"></p>
                </div>

                {# Playlist sidebar #}
                <div class="video-playlist__list">
                    <div class="video-playlist__list-header">
                        {{ curation.title }} &middot; {{ mediaEvents|length }} video{{ mediaEvents|length != 1 ? 's' : '' }}
                    </div>

                    {% for event in mediaEvents %}
                        {% if event.notFound is defined and event.notFound %}
                            <div class="video-playlist__item">
                                <span class="video-playlist__item-index">{{ loop.index }}</span>
                                <div class="video-playlist__placeholder">Not synced</div>
                                <div class="video-playlist__item-info">
                                    <span class="video-playlist__item-title">{{ event.id ?? 'Unknown' }}</span>
                                </div>
                            </div>
                        {% else %}
                            {# Extract video URL, title, preview from imeta #}
                            {% set videoUrl = null %}
                            {% set previewImage = null %}
                            {% set videoTitle = null %}
                            {% set videoAlt = null %}
                            {% if event.tags is defined %}
                                {% for tag in event.tags %}
                                    {% if tag[0] == 'title' %}
                                        {% set videoTitle = tag[1] %}
                                    {% endif %}
                                    {% if tag[0] == 'imeta' and videoUrl is null %}
                                        {% for i in 1..(tag|length - 1) %}
                                            {% set param = tag[i] %}
                                            {% if param starts with 'url ' and videoUrl is null %}
                                                {% set potentialUrl = param[4:] %}
                                                {% if potentialUrl matches '/\\.(mp4|webm|ogg|mov)$/i' or potentialUrl matches '/video/i' %}
                                                    {% set videoUrl = potentialUrl %}
                                                {% endif %}
                                            {% elseif param starts with 'image ' and previewImage is null %}
                                                {% set previewImage = param[6:] %}
                                            {% elseif param starts with 'alt ' and videoAlt is null %}
                                                {% set videoAlt = param[4:] %}
                                            {% endif %}
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                            {% endif %}

                            <div class="video-playlist__item {{ loop.index0 == 0 ? 'is-active' : '' }}"
                                 data-media--video-playlist-target="item"
                                 data-index="{{ loop.index0 }}"
                                 data-video-url="{{ videoUrl|default('') }}"
                                 data-video-title="{{ videoTitle|default(videoAlt|default('Video ' ~ loop.index)) }}"
                                 data-video-author=""
                                 data-action="click->media--video-playlist#select">
                                <span class="video-playlist__item-index">{{ loop.index }}</span>
                                <div class="video-playlist__item-thumb">
                                    {% if previewImage %}
                                        <img src="{{ previewImage }}" alt="" loading="lazy" />
                                    {% endif %}
                                    <div class="play-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white">
                                            <path d="M8 5v14l11-7z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="video-playlist__item-info">
                                    <span class="video-playlist__item-title">{{ videoTitle|default(videoAlt|default('Video ' ~ loop.index)) }}</span>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% else %}
            <p class="curation-page__empty">No videos in this curation set.</p>
        {% endif %}
    </div>
{% endblock %}
