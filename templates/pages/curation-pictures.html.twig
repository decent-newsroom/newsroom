{% extends 'layout.html.twig' %}

{% block ogtags %}
    <meta property="og:title" content="{{ curation.title }} - Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="{{ curation.summary ?? '' }}">
    <meta property="og:site_name" content="Newsroom">
{% endblock %}

{% block body %}
    <section class="ln-section--newsstand curation-page__hero">
        <div class="curation-page__hero-inner">
            <h1 class="curation-page__hero-title">{{ curation.title }}</h1>
            <div class="curation-page__hero-meta">
                <span class="badge bg-secondary">{{ type }}</span>
                <span class="badge bg-info text-dark">{{ mediaEvents|length }} picture{{ mediaEvents|length != 1 ? 's' : '' }}</span>
            </div>
            {% if curation.summary %}
                <p class="eyebrow curation-page__hero-summary">{{ curation.summary }}</p>
            {% endif %}
            <div class="curation-page__hero-author">by <twig:Molecules:UserFromNpub :ident="curation.pubkey" /></div>
        </div>
    </section>

    <div class="curation-page__content"
         {% if hasPendingMediaSync %}
             data-controller="content--curation-mercure"
             data-content--curation-mercure-status-url-value="{{ curationMediaSyncStatusUrl }}"
             data-content--curation-mercure-initial-missing-count-value="{{ pendingMediaCount }}"
             data-content--curation-mercure-reload-url-value="{{ app.request.uri }}"
         {% endif %}>
        {% if mediaEvents|length > 0 %}
            <div class="curation-picture-grid"
                 data-controller="media--picture-gallery">

                {% for event in mediaEvents %}
                    {% if event.notFound is defined and event.notFound %}
                        <div class="curation-picture-grid__placeholder">
                            <div>
                                <p class="mb-1 small">Not synced</p>
                                <small>{{ event.id ?? event.coordinate ?? 'Unknown' }}</small>
                            </div>
                        </div>
                    {% else %}
                        {# Collect valid image entries from imeta tags #}
                        {% set images = [] %}
                        {% set eventTitle = null %}
                        {% set eventContent = event.content|default('')|trim %}
                        {% if event.tags is defined %}
                            {% for tag in event.tags %}
                                {% if tag[0] == 'title' and eventTitle is null and tag[1] is defined %}
                                    {% set eventTitle = tag[1] %}
                                {% endif %}
                                {% if tag[0] == 'imeta' %}
                                    {% set currentImageUrl = null %}
                                    {% set currentImageAlt = null %}
                                    {% for i in 1..(tag|length - 1) %}
                                        {% set param = tag[i] %}
                                        {% if param starts with 'url ' and currentImageUrl is null %}
                                            {% set potentialUrl = param[4:] %}
                                            {% if not (potentialUrl matches '/\\.(mp4|webm|ogg|mov)$/i') %}
                                                {% set currentImageUrl = potentialUrl %}
                                            {% endif %}
                                        {% elseif param starts with 'alt ' and currentImageAlt is null %}
                                            {% set currentImageAlt = param[4:] %}
                                        {% endif %}
                                    {% endfor %}

                                    {% if currentImageUrl %}
                                        {% set images = images|merge([{
                                            url: currentImageUrl,
                                            alt: currentImageAlt
                                        }]) %}
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}

                        {% if images|length > 0 %}
                            {% set imageUrl = images[0].url %}
                            {% set imageAlt = images[0].alt %}
                            <div class="curation-picture-grid__item"
                                 data-media--picture-gallery-target="item"
                                 data-image-url="{{ imageUrl }}"
                                 data-image-alt="{{ imageAlt|default('') }}"
                                 data-images="{{ images|json_encode|e('html_attr') }}"
                                 data-action="click->media--picture-gallery#open">
                                <template data-picture-gallery-detail-template>
                                    <div class="picture-lightbox__details-inner">
                                        {% if eventTitle %}
                                            <h2 class="picture-lightbox__title">{{ eventTitle }}</h2>
                                        {% endif %}
                                        {% if eventContent is not empty %}
                                            <div class="picture-lightbox__content">
                                                {{ eventContent|e|linkify|nl2br }}
                                            </div>
                                        {% endif %}
                                        <div class="picture-lightbox__publisher">
                                            <span>{{ 'text.by'|trans }}</span>
                                            <twig:Molecules:UserFromNpub :ident="event.pubkey" />
                                        </div>
                                    </div>
                                </template>
                                <img src="{{ imageUrl }}"
                                     alt="{{ imageAlt|default('Picture') }}"
                                     loading="lazy"
                                     onerror="this.closest('.curation-picture-grid__item').style.display='none'" />
                                {% if images|length > 1 %}
                                    <div class="curation-picture-grid__gallery-indicator" aria-label="Gallery with {{ images|length }} images" title="Gallery with {{ images|length }} images">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                            <path d="M4 7a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7zm14-2h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H8a2 2 0 0 1-2-1h9a4 4 0 0 0 4-4V5z"/>
                                        </svg>
                                        <span>{{ images|length }}</span>
                                    </div>
                                {% endif %}
                                <div class="picture-overlay">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                                    </svg>
                                </div>
                            </div>
                        {% else %}
                            <div class="curation-picture-grid__placeholder">
                                <span>No preview</span>
                            </div>
                        {% endif %}
                    {% endif %}
                {% endfor %}

                {# Lightbox overlay #}
                <div class="picture-lightbox"
                     data-media--picture-gallery-target="lightbox"
                     data-action="click->media--picture-gallery#close">
                    <button class="picture-lightbox__close" data-action="click->media--picture-gallery#close">&times;</button>
                    <button class="picture-lightbox__nav picture-lightbox__nav--prev"
                              data-media--picture-gallery-target="prevButton"
                            data-action="click->media--picture-gallery#prev">&lsaquo;</button>
                    <img class="picture-lightbox__image"
                         data-media--picture-gallery-target="lightboxImage"
                         src="" alt=""
                         data-action="click@click.stop" />
                    <div class="picture-lightbox__details"
                         data-media--picture-gallery-target="lightboxDetails"
                         data-action="click@click.stop"></div>
                    <button class="picture-lightbox__nav picture-lightbox__nav--next"
                              data-media--picture-gallery-target="nextButton"
                            data-action="click->media--picture-gallery#next">&rsaquo;</button>
                </div>
            </div>
        {% else %}
            <p class="curation-page__empty">No pictures in this curation set.</p>
        {% endif %}
    </div>
{% endblock %}
