{% extends 'layout.html.twig' %}

{% block ogtags %}
    <meta property="og:title" content="Multimedia - Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="Discovery through serendipity - explore multimedia content">
    <meta property="og:site_name" content="Newsroom">

    {# JSON-LD Structured Data for Media Discovery Page #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Multimedia",
        "description": "Discovery through serendipity - explore multimedia content",
        "url": {{ app.request.uri|json_encode|raw }},
        "isPartOf": {
            "@type": "WebSite",
            "name": "Newsroom",
            "url": "{{ url('home') }}"
        },
        "about": {
            "@type": "Thing",
            "name": "Multimedia Content"
        }
    }
    </script>
{% endblock %}

{% block body %}
    <twig:Atoms:PageHeading heading="{{ 'media.heading'|trans }}" tagline="{{ 'media.tagline'|trans }}"/>

    <div class="w-container">
        <div class="media-discovery" data-controller="media--media-discovery-tabs" data-media--media-discovery-tabs-active-tab-value="latest">

            <nav class="profile-tabs media-discovery__tabs">
                <a href="{{ path('media_discovery_tab', {tab: 'latest'}) }}"
                   class="tab-link active"
                   data-media--media-discovery-tabs-target="tab"
                   data-tab="latest"
                   data-action="click->media--media-discovery-tabs#switchTab">
                    {{ 'media.tab.latest'|trans }}
                </a>
                <a href="{{ path('media_discovery_tab', {tab: 'follows'}) }}"
                   class="tab-link {{ not isLoggedIn ? 'disabled' : '' }}"
                   data-media--media-discovery-tabs-target="tab"
                   data-tab="follows"
                   data-action="click->media--media-discovery-tabs#switchTab"
                   {% if not isLoggedIn %}aria-disabled="true" title="{{ 'media.follows.signInRequired'|trans }}"{% endif %}>
                    {{ 'media.tab.follows'|trans }}
                </a>
                <a href="{{ path('media_discovery_tab', {tab: 'interests'}) }}"
                   class="tab-link {{ not isLoggedIn ? 'disabled' : '' }}"
                   data-media--media-discovery-tabs-target="tab"
                   data-tab="interests"
                   data-action="click->media--media-discovery-tabs#switchTab"
                   {% if not isLoggedIn %}aria-disabled="true" title="{{ 'media.interests.signInRequired'|trans }}"{% endif %}>
                    {{ 'media.tab.interests'|trans }}
                </a>
            </nav>

            <div class="media-discovery__content" data-media--media-discovery-tabs-target="content">
                <turbo-frame id="media-tab-content" src="{{ path('media_discovery_tab', {tab: 'latest'}) }}" loading="lazy">
                    <div class="media-discovery__loading">
                        <div class="spinner"><div class="lds-dual-ring"></div></div>
                        <p>{{ 'text.loading'|trans }}</p>
                    </div>
                </turbo-frame>
            </div>
        </div>
    </div>
{% endblock %}

{% block aside %}
{% endblock %}
