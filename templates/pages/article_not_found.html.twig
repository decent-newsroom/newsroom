{% extends 'layout.html.twig' %}

{% block title %}{{ 'article.notFoundTitle'|trans }}{% endblock %}

{% block body %}
    <twig:Atoms:PageHeading heading="{{ 'article.notFound'|trans }}" />
    <div class="w-container">
        <section class="text-center">
            {% if message %}
                <div class="alert alert-info">
                    {{ message }}
                </div>
            {% endif %}

            {% if essayistAccessDenied|default(false) %}
                <div class="notice warning mt-4">
                    <h3 class="h5 mb-3">{{ 'article.essayistAccessDeniedTitle'|trans }}</h3>
                    <p>{{ 'article.essayistAccessDeniedHint'|trans }}</p>
                    <a href="{{ path('app_static_essayist') }}" class="btn btn-primary mt-2">
                        {{ 'article.essayistAccessDeniedCta'|trans }}
                    </a>
                </div>
            {% else %}
                <div class="notice info mt-4">
                    <h3 class="h5 mb-3">{{ 'article.trySearching'|trans }}</h3>
                    <p>
                        {{ 'article.trySearchingHint'|trans }}
                    </p>
                </div>
            {% endif %}
        </section>

        {% if not essayistAccessDenied|default(false) %}
            <section class="search-section">
                <twig:SearchComponent :query="searchQuery" />
            </section>
        {% endif %}

        <section class="text-center mt-5">
            <a href="{{ path('home') }}" class="btn btn-secondary">{{ 'article.returnHome'|trans }}</a>
        </section>
    </div>
{% endblock %}
