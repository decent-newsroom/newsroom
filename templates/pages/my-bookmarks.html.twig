{% extends 'reading-nook-layout.html.twig' %}

{% block body %}
    <twig:Atoms:PageHeading heading="{{ 'bookmarks.heading'|trans }}" tagline="{{ 'bookmarks.tagline'|trans }}"/>

    <div class="w-container">
        {% if bookmarks|length > 0 %}
            <div class="bookmarks-list d-flex">
                {% for bookmark in bookmarks %}
                    <div
                        class="bookmark-item card"
                        data-controller="ui--bookmark-list"
                        data-ui--bookmark-list-kind-value="{{ bookmark.kind }}"
                        data-ui--bookmark-list-tags-value="{{ bookmark.tags|json_encode|e('html_attr') }}"
                        data-ui--bookmark-list-content-value="{{ bookmark.content|e('html_attr') }}"
                        data-ui--bookmark-list-publish-url-value="{{ path('api_bookmarks_publish') }}"
                        data-ui--bookmark-list-empty-message-value="{{ 'bookmarks.noItems'|trans|e('html_attr') }}"
                        data-ui--bookmark-list-item-singular-value="{{ 'bookmarks.itemSingular'|trans|e('html_attr') }}"
                        data-ui--bookmark-list-item-plural-value="{{ 'bookmarks.itemPlural'|trans|e('html_attr') }}"
                        data-ui--bookmark-list-removed-message-value="{{ 'bookmark.removed'|trans|e('html_attr') }}"
                        data-ui--bookmark-list-remove-failed-message-value="{{ 'bookmark.removeFailed'|trans|e('html_attr') }}"
                        data-ui--bookmark-list-signer-unavailable-message-value="{{ 'bookmark.signerUnavailable'|trans|e('html_attr') }}"
                    >
                        <div class="bookmark-header d-flex flex-row justify-content-between p-1 ln-section--newsstand">
                            <span class="bookmark-kind-badge">{{ bookmark.listType }}</span>
                            {% if bookmark.listType != 'Bookmarks' %}
                                <h3>{{ bookmark.title ?? bookmark.identifier ?? 'bookmarks.untitledList'|trans }}</h3>
                            {% endif %}
                            <div class="bookmark-meta">
                                <small>{{ bookmark.createdAt|date('M d, Y') }}</small>
                            </div>
                            {% if bookmark.description %}
                                <p class="bookmark-description text-muted">{{ bookmark.description }}</p>
                            {% endif %}
                            {% if bookmark.image %}
                                <img src="{{ bookmark.image }}" alt="{{ bookmark.title ?? 'List image' }}" class="bookmark-image" />
                            {% endif %}
                        </div>

                        {% if bookmark.items|length > 0 %}
                            <div class="bookmark-items-count p-1 ln-section--newsstand">
                                <small data-ui--bookmark-list-target="count">
                                    {{ bookmark.items|length }}
                                    {{ (bookmark.items|length == 1 ? 'bookmarks.itemSingular' : 'bookmarks.itemPlural')|trans }}
                                </small>
                            </div>

                            <div class="bookmark-items-list mt-3" data-ui--bookmark-list-target="items">
                                {% for item in bookmark.items %}
                                    {% if item.type == 'e' and item.value and resolvedEvents[item.value] is defined %}
                                        {# Event already in DB – render directly, no LiveComponent needed #}
                                        <div class="bookmark-item-container d-flex justify-content-between align-items-start gap-2" data-bookmark-list-item>
                                            <div class="flex-grow-1">
                                                {% include 'partial/_bookmark_event_card.html.twig' with {event: resolvedEvents[item.value]} %}
                                            </div>
                                            {% include 'partial/_bookmark_remove_button.html.twig' with {type: item.type, value: item.value} only %}
                                        </div>
                                    {% else %}
                                        <twig:Organisms:BookmarkItemResolver
                                            :type="item.type"
                                            :value="item.value"
                                            :relay="item.relay"
                                        />
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="empty-list text-muted">{{ 'bookmarks.noItems'|trans }}</p>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="no-content mt-5">
                <p>{{ 'bookmarks.noBookmarks'|trans }}</p>
                <small class="text-muted">{{ 'bookmarks.noBookmarksHint'|trans }}</small>
            </div>
        {% endif %}
    </div>
{% endblock %}
