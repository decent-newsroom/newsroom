{% extends 'layout.html.twig' %}

{% block body %}
    <twig:Atoms:PageHeading heading="{{ 'bookmarks.heading'|trans }}" tagline="{{ 'bookmarks.tagline'|trans }}"/>

    <div class="w-container">
        {% if bookmarks|length > 0 %}
            <div class="bookmarks-list d-flex">
                {% for bookmark in bookmarks %}
                    <div class="bookmark-item card">
                        <div class="bookmark-header d-flex flex-row justify-content-between p-1 ln-section--newsstand">
                            <span class="bookmark-kind-badge">{{ bookmark.listType }}</span>
                            {% if bookmark.listType != 'Bookmarks' %}
                                <h3>{{ bookmark.title ?? bookmark.identifier ?? 'bookmarks.untitledList'|trans }}</h3>
                            {% endif %}
                            <div class="bookmark-meta">
                                <small>{{ bookmark.createdAt|date('M d, Y') }}</small>
                            </div>
                            {% if bookmark.description %}
                                <p class="bookmark-description text-muted">{{ bookmark.description }}</p>
                            {% endif %}
                            {% if bookmark.image %}
                                <img src="{{ bookmark.image }}" alt="{{ bookmark.title ?? 'List image' }}" class="bookmark-image" />
                            {% endif %}
                        </div>

                        {% if bookmark.items|length > 0 %}
                            <div class="bookmark-items-count p-1 ln-section--newsstand">
                                <small>{{ bookmark.items|length }} item{{ bookmark.items|length > 1 ? 's' : '' }}</small>
                            </div>

                            <div class="bookmark-items-list mt-3">
                                {% for item in bookmark.items %}
                                    {% if item.type == 'e' and item.value and resolvedEvents[item.value] is defined %}
                                        {# Event already in DB – render directly, no LiveComponent needed #}
                                        {% include 'partial/_bookmark_event_card.html.twig' with {event: resolvedEvents[item.value]} %}
                                    {% else %}
                                        <twig:Organisms:BookmarkItemResolver
                                            :type="item.type"
                                            :value="item.value"
                                            :relay="item.relay"
                                        />
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="empty-list text-muted">{{ 'bookmarks.noItems'|trans }}</p>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="no-content mt-5">
                <p>{{ 'bookmarks.noBookmarks'|trans }}</p>
                <small class="text-muted">{{ 'bookmarks.noBookmarksHint'|trans }}</small>
            </div>
        {% endif %}
    </div>
{% endblock %}

