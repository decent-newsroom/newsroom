{% extends 'layout.html.twig' %}

{% block ogtags %}
    {{ parent() }}
    <meta property="og:title" content="Explore - Decent Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="Discover and search for articles on Newsroom">
    <meta property="og:site_name" content="Newsroom">

    {# JSON-LD Structured Data for Discover Page #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Explore",
        "description": "Discover and search for articles on Newsroom",
        "url": {{ app.request.uri|json_encode|raw }},
        "isPartOf": {
            "@type": "WebSite",
            "name": "Newsroom",
            "url": "{{ url('home') }}"
        },
        "potentialAction": {
            "@type": "SearchAction",
            "target": {
                "@type": "EntryPoint",
                "urlTemplate": "{{ url('app_search_index') }}?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
        }
    }
    </script>
{% endblock %}

{% block body %}
    {# Search Section #}
    <section class="w-container">
        <div class="discover-section">
            <form action="{{ path('app_search_index') }}"
                  method="get"
                  class="discover-search-form"
                  data-controller="search--nostr-redirect"
                  data-action="submit->search--nostr-redirect#submit">
                <label class="search">
                    <input type="search"
                           name="q"
                           placeholder="{{ 'discover.searchPlaceholder'|trans }}"
                           class="form-control"
                           data-search--nostr-redirect-target="input"
                           required
                    />
                    <button type="submit" class="btn btn-primary">
                        <twig:ux:icon name="iconoir:search" class="icon" /> {{ 'heading.search'|trans }}
                    </button>
                </label>
            </form>
        </div>
    </section>

    {# Main Topics #}
    <section class="w-container d-md-none mb-3">
        <div class="discover-section topics-strip">
            {% if mainTopicsMap is defined and mainTopicsMap is not empty %}
                <div class="topics-buttons d-flex flex-row flex-wrap gap-2 justify-content-center">
                    {% if app.user and hasInterests %}
                        <a href="{{ path('my_interests') }}" class="btn btn-outline-primary btn-sm">
                            {{ 'nav.myInterests'|trans }}
                        </a>
                    {% endif %}
                    {% if app.user and interestSets is defined %}
                        {% for set in interestSets %}
                            <a href="{{ path('interest_set_view', { dTag: set.dTag }) }}"
                               class="btn btn-outline-primary btn-sm">
                                {{ set.title }}
                            </a>
                        {% endfor %}
                    {% endif %}
                    {% for key, name in mainTopicsMap %}
                        <a href="{{ path('forum_main_topic', { topic: key }) }}"
                           class="btn btn-outline-primary btn-sm">
                            {{ name }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>

    <section class="w-container">
        <div class="discover-section">
            {# Tabs Navigation #}
            <div data-controller="content--discover-tabs">
                <nav class="profile-tabs">
                    <a href="#featured-writers" class="tab-link"
                       data-action="click->content--discover-tabs#switchTab"
                       data-content--discover-tabs-target="tab"
                       data-tab="featured-writers">
                        {{ 'discover.featuredWriters'|trans }}
                    </a>
                    <a href="#articles" class="tab-link active"
                       data-action="click->content--discover-tabs#switchTab"
                       data-content--discover-tabs-target="tab"
                       data-tab="articles">
                        {{ 'discover.articles'|trans }}
                    </a>
                    <a href="#activity" class="tab-link"
                       data-action="click->content--discover-tabs#switchTab"
                       data-content--discover-tabs-target="tab"
                       data-tab="activity">
                        {{ 'discover.activity'|trans }}
                    </a>
                    <a href="#editorial" class="tab-link"
                       data-action="click->content--discover-tabs#switchTab"
                       data-content--discover-tabs-target="tab"
                       data-tab="editorial">
                        {{ 'discover.editorial'|trans }}
                    </a>
                </nav>

                {# Articles Tab #}
                <div class="settings-panel active"
                     data-content--discover-tabs-target="panel"
                     data-panel="articles">
                    {% if articles is empty %}
                        <div class="alert alert-info">
                            {{ 'discover.noArticles'|trans }}
                        </div>
                    {% else %}
                        <twig:Organisms:CardList :list="articles" :authorsMetadata="authorsMetadata" class="article-list" />
                    {% endif %}
                </div>

                {# Activity Tab (Highlights + Comments) #}
                <div class="settings-panel"
                     data-content--discover-tabs-target="panel"
                     data-panel="activity">
                    {% if activityItems is empty %}
                        <div class="no-highlights">
                            <p>{{ 'discover.noActivity'|trans }}</p>
                        </div>
                    {% else %}
                        <div class="highlights-grid">
                            {% for item in activityItems %}
                                {% if item.type == 'comment' %}
                                    {# Comment item #}
                                    <div class="highlight-card">
                                        <div class="highlight-header">
                                            <div class="highlight-author">
                                                {% if item.pubkey %}
                                                    <twig:Molecules:UserFromNpub
                                                        ident="{{ item.pubkey }}"
                                                        :compact="true"
                                                    />
                                                    <span style="margin-left: 0.5rem; font-size: 0.85rem; color: var(--color-text-muted);">{{ 'discover.commented'|trans }}</span>
                                                {% else %}
                                                    <span>{{ 'text.anonymous'|trans }}</span>
                                                {% endif %}
                                            </div>
                                            <div class="highlight-date">
                                                {{ item.created_at|date('M j, Y') }}
                                            </div>
                                        </div>
                                        <div class="highlight-content" data-controller="utility--show-more">
                                            <div data-utility--show-more-target="preview" class="content-preview">
                                                {{ item.content|markdown_to_html|raw }}
                                            </div>
                                        </div>
                                        <div class="highlight-footer">
                                            {% if item.article_ref %}
                                                {% set refParts = item.article_ref|split(':', 3) %}
                                                {% set refNpub = refParts|length == 3 ? refParts[1]|hex_to_npub : '' %}
                                                {% if refNpub and refParts|length == 3 %}
                                                    <a href="{{ path('author-article-slug', {npub: refNpub, slug: refParts[2]}) }}"
                                                       class="article-reference"
                                                       data-turbo-frame="_top">
                                                        {{ item.article_title ?: ('discover.viewArticle'|trans) }}
                                                    </a>
                                                {% endif %}
                                            {% endif %}
                                        </div>
                                    </div>
                                {% else %}
                                    {# Highlight item #}
                                    {% set highlight = item %}
                                    {% include 'partial/_highlight_feed_card.html.twig' %}
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {# Editorial Tab (Magazines, Follow Packs, Collections) #}
                <div class="settings-panel"
                     data-content--discover-tabs-target="panel"
                     data-panel="editorial">
                    {% if editorial is empty %}
                        {# Fallback: show all magazines via the same component as the newsstand #}
                        <twig:Organisms:ZineList />
                    {% else %}
                        {% for item in editorial %}
                            {% if item.kind == 30040 %}
                                {% set itemUrl = path('magazine-index', {'mag': item.slug}) %}
                                {% set itemBadge = 'Magazine' %}
                            {% elseif item.kind == 39089 %}
                                {% set itemUrl = path('follow_pack_view', {'npub': item.pubkey|toNpub, 'dtag': item.slug}) %}
                                {% set itemBadge = 'Follow Pack' %}
                            {% else %}
                                {% set itemUrl = path('curation-set', {'kind': item.kind, 'npub': item.pubkey|toNpub, 'slug': item.slug}) %}
                                {% set itemBadge = item.kind == 30005 ? 'Video' : (item.kind == 30006 ? 'Pictures' : 'Collection') %}
                            {% endif %}
                            <div class="card p-3 ln-section--reader">
                                {% if item.image %}
                                    <div class="card-header m-0">
                                        <a href="{{ itemUrl }}">
                                            <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
                                        </a>
                                    </div>
                                {% endif %}
                                <div class="card-body text-center">
                                    <h2 class="card-title">
                                        <a href="{{ itemUrl }}">{{ item.title }}</a>
                                    </h2>
                                    {% if item.summary %}
                                        <p class="lede line-clamp-5">{{ item.summary }}</p>
                                    {% endif %}
                                    <p><small><twig:Molecules:UserFromNpub :ident="item.pubkey" /></small></p>
                                    <span class="badge bg-secondary">{{ itemBadge }}</span>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                {# Featured Writers Tab #}
                <div class="settings-panel"
                     data-content--discover-tabs-target="panel"
                     data-panel="featured-writers">
                    {% if featuredArticles is empty %}
                        <div class="alert alert-info">
                            {{ 'discover.noFeaturedWritersArticles'|trans }}
                        </div>
                    {% else %}
                        <twig:Organisms:CardList :list="featuredArticles" :authorsMetadata="featuredAuthorsMetadata" class="article-list" />
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block aside %}
    <twig:Organisms:FeaturedUnfoldSites />
    <twig:Atoms:FeaturedWriters />
{% endblock %}
