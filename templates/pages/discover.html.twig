{% extends 'layout.html.twig' %}

{% block ogtags %}
    {{ parent() }}
    <meta property="og:title" content="Explore - Decent Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="Discover and search for articles on Newsroom">
    <meta property="og:site_name" content="Newsroom">

    {# JSON-LD Structured Data for Discover Page #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Explore",
        "description": "Discover and search for articles on Newsroom",
        "url": {{ app.request.uri|json_encode|raw }},
        "isPartOf": {
            "@type": "WebSite",
            "name": "Newsroom",
            "url": "{{ url('home') }}"
        },
        "potentialAction": {
            "@type": "SearchAction",
            "target": {
                "@type": "EntryPoint",
                "urlTemplate": "{{ url('app_search_index') }}?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
        }
    }
    </script>
{% endblock %}

{% block body %}
    {# Search Section #}
    <section class="w-container">
        <div class="discover-section">
            <form action="{{ path('app_search_index') }}"
                  method="get"
                  class="discover-search-form"
                  data-controller="search--nostr-redirect"
                  data-action="submit->search--nostr-redirect#submit">
                <label class="search">
                    <input type="search"
                           name="q"
                           placeholder="{{ 'discover.searchPlaceholder'|trans }}"
                           class="form-control"
                           data-search--nostr-redirect-target="input"
                           required
                    />
                    <button type="submit" class="btn btn-primary">
                        <twig:ux:icon name="iconoir:search" class="icon" /> {{ 'heading.search'|trans }}
                    </button>
                </label>
            </form>
        </div>
    </section>

    {# Main Topics #}
    <section class="w-container d-md-none mb-3">
        <div class="discover-section topics-strip">
            {% if mainTopicsMap is defined and mainTopicsMap is not empty %}
                <div class="topics-buttons d-flex flex-row flex-wrap gap-2 justify-content-center">
                    {% if app.user and hasInterests %}
                        <a href="{{ path('my_interests') }}" class="btn btn-outline-primary btn-sm">
                            {{ 'nav.myInterests'|trans }}
                        </a>
                    {% endif %}
                    {% if app.user and interestSets is defined %}
                        {% for set in interestSets %}
                            <a href="{{ path('interest_set_view', { dTag: set.dTag }) }}"
                               class="btn btn-outline-primary btn-sm">
                                {{ set.title }}
                            </a>
                        {% endfor %}
                    {% endif %}
                    {% for key, name in mainTopicsMap %}
                        <a href="{{ path('forum_main_topic', { topic: key }) }}"
                           class="btn btn-outline-primary btn-sm">
                            {{ name }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>

    <twig:Organisms:FeaturedUnfoldSites />

    <section class="w-container">
        <div class="discover-section">
            {# Tabs Navigation #}
            <div data-controller="content--discover-tabs">
                <nav class="profile-tabs">
                    <a href="#articles" class="tab-link active"
                       data-action="click->content--discover-tabs#switchTab"
                       data-content--discover-tabs-target="tab"
                       data-tab="articles">
                        {{ 'discover.articles'|trans }}
                    </a>
                    <a href="#highlights" class="tab-link"
                       data-action="click->content--discover-tabs#switchTab"
                       data-content--discover-tabs-target="tab"
                       data-tab="highlights">
                        {{ 'discover.highlights'|trans }}
                    </a>
                    <a href="#editorial" class="tab-link"
                       data-action="click->content--discover-tabs#switchTab"
                       data-content--discover-tabs-target="tab"
                       data-tab="editorial">
                        {{ 'discover.editorial'|trans }}
                    </a>
                </nav>

                {# Articles Tab #}
                <div class="settings-panel active"
                     data-content--discover-tabs-target="panel"
                     data-panel="articles">
                    {% if articles is empty %}
                        <div class="alert alert-info">
                            {{ 'discover.noArticles'|trans }}
                        </div>
                    {% else %}
                        <twig:Organisms:CardList :list="articles" :authorsMetadata="authorsMetadata" class="article-list" />
                    {% endif %}
                </div>

                {# Highlights Tab #}
                <div class="settings-panel"
                     data-content--discover-tabs-target="panel"
                     data-panel="highlights">
                    {% if highlights is empty %}
                        <div class="no-highlights">
                            <p>{{ 'highlights.noHighlights'|trans }}</p>
                        </div>
                    {% else %}
                        <div class="highlights-grid">
                            {% for highlight in highlights %}
                                {% include 'partial/_highlight_feed_card.html.twig' with {highlight: highlight} %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {# Editorial Tab (Magazines, Follow Packs, Collections) #}
                <div class="settings-panel"
                     data-content--discover-tabs-target="panel"
                     data-panel="editorial">
                    {% if editorial is empty %}
                        <div class="alert alert-info">
                            {{ 'discover.noEditorial'|trans|default('No publications found') }}
                        </div>
                    {% else %}
                        <div class="editorial-grid">
                            {% for item in editorial %}
                                {% if item.kind == 30040 %}
                                    {# Magazine #}
                                    <div class="editorial-card">
                                        {% if item.image %}
                                            <div class="editorial-card__image">
                                                <a href="{{ path('magazine-index', {'mag': item.slug}) }}">
                                                    <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
                                                </a>
                                            </div>
                                        {% endif %}
                                        <div class="editorial-card__body">
                                            <h3 class="editorial-card__title">
                                                <a href="{{ path('magazine-index', {'mag': item.slug}) }}">{{ item.title }}</a>
                                            </h3>
                                            {% if item.summary %}
                                                <p class="editorial-card__summary">{{ item.summary }}</p>
                                            {% endif %}
                                            <span class="badge bg-primary">Magazine</span>
                                        </div>
                                    </div>
                                {% elseif item.kind == 39089 %}
                                    {# Follow Pack #}
                                    <div class="editorial-card">
                                        {% if item.image %}
                                            <div class="editorial-card__image">
                                                <a href="{{ path('follow_pack_view', {'npub': item.pubkey|toNpub, 'dtag': item.slug}) }}">
                                                    <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
                                                </a>
                                            </div>
                                        {% endif %}
                                        <div class="editorial-card__body">
                                            <h3 class="editorial-card__title">
                                                <a href="{{ path('follow_pack_view', {'npub': item.pubkey|toNpub, 'dtag': item.slug}) }}">{{ item.title }}</a>
                                            </h3>
                                            {% if item.summary %}
                                                <p class="editorial-card__summary">{{ item.summary }}</p>
                                            {% endif %}
                                            <span class="badge bg-secondary">Follow Pack</span>
                                        </div>
                                    </div>
                                {% else %}
                                    {# Curation Set #}
                                    <div class="editorial-card">
                                        {% if item.image %}
                                            <div class="editorial-card__image">
                                                <a href="{{ path('curation-set', {'kind': item.kind, 'npub': item.pubkey|toNpub, 'slug': item.slug}) }}">
                                                    <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
                                                </a>
                                            </div>
                                        {% endif %}
                                        <div class="editorial-card__body">
                                            <h3 class="editorial-card__title">
                                                <a href="{{ path('curation-set', {'kind': item.kind, 'npub': item.pubkey|toNpub, 'slug': item.slug}) }}">{{ item.title }}</a>
                                            </h3>
                                            {% if item.summary %}
                                                <p class="editorial-card__summary">{{ item.summary }}</p>
                                            {% endif %}
                                            <span class="badge bg-info text-dark">
                                                {% if item.kind == 30005 %}Video{% elseif item.kind == 30006 %}Audio{% else %}Collection{% endif %}
                                            </span>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block aside %}
    <twig:Atoms:FeaturedWriters />
{% endblock %}
