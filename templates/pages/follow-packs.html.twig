{% extends 'layout.html.twig' %}

{% block title %}{{ 'followPacks.heading'|trans }} — Newsroom{% endblock %}

{% block ogtags %}
    <meta property="og:title" content="{{ 'followPacks.heading'|trans }} - Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="{{ 'followPacks.eyebrow'|trans }}">
    <meta property="og:site_name" content="Newsroom">
{% endblock %}

{% block body %}
    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5 mb-5">
            <div class="d-flex align-items-center justify-content-between">
                <h1>{{ 'followPacks.heading'|trans }}</h1>
            </div>
            <p class="eyebrow">{{ 'followPacks.eyebrow'|trans }}</p>

            <div class="d-flex align-items-center justify-content-between">
            {% if app.user %}
                <a href="{{ path('follow_pack_setup') }}" class="btn btn-sm">{{ 'followPacks.create'|trans }}</a>
            {% endif %}
            </div>
        </div>
    </section>
    <section class="mb-5">
        <twig:Organisms:FollowPackList />
    </section>
{% endblock %}

