{% extends 'layout.html.twig' %}

{% block ogtags %}
    <meta property="og:title" content="My Magazines - Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="Your magazines on Newsroom">
    <meta property="og:site_name" content="Newsroom">
{% endblock %}

{% block body %}
    <section class="d-flex gap-3 center ln-section--newsstand">
        <div class="container mt-5 mb-1">
            <h1>My Magazines</h1>
        </div>
        <div class="cta-row mb-5">
            <a class="btn btn-primary" href="{{ path('mag_wizard_setup') }}">Create new</a>
        </div>
    </section>
    <section class="mb-5">
        <twig:Organisms:ZineList :pubkey="pubkey" />
    </section>

{% endblock %}

