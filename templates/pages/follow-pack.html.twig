{% extends 'layout.html.twig' %}

{% block title %}{{ title }} — Newsroom{% endblock %}

{% block ogtags %}
    <meta property="og:title" content="{{ title }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    {% if image %}
        <meta property="og:image" content="{{ image }}">
    {% endif %}
    {% if description %}
        <meta property="og:description" content="{{ description }}">
    {% endif %}
    <meta property="og:site_name" content="Newsroom">
{% endblock %}

{% block body %}
    {# Hero section — mirrors the magazine-hero pattern #}
    <div class="magazine-hero">
        <div data-controller="utility--share-dropdown" class="dropdown share-dropdown magazine-hero__actions">
            <button data-utility--share-dropdown-target="button"
                    class="btn btn-secondary btn-sm"
                    type="button"
                    aria-haspopup="true"
                    aria-expanded="false"
                    data-action="click->utility--share-dropdown#toggle">
                ⋯
            </button>
            <div data-utility--share-dropdown-target="menu"
                 class="dropdown-menu dropdown-menu-end"
                 style="display:none;position:absolute;z-index:1000;min-width:200px;">
                <button class="dropdown-item"
                        type="button"
                        data-action="click->utility--share-dropdown#copy"
                        data-copy="{{ url('follow_pack_view', { npub: authorNpub, dtag: packDtag }) }}">
                    {{ 'followPackView.shareNewsroomLink'|trans }}
                </button>
                <button class="dropdown-item"
                        type="button"
                        data-action="click->utility--share-dropdown#copy"
                        data-copy="{{ packEvent|naddrEncode }}">
                    {{ 'followPackView.shareNaddr'|trans }}
                </button>
                {% if app.user and app.user.userIdentifier != authorNpub %}
                    <div class="dropdown-divider"></div>
                    <form method="post" action="{{ path('updates_subscriptions_add') }}" class="m-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('update-subscribe') }}" />
                        <input type="hidden" name="identifier" value="{{ packEvent|naddrEncode }}" />
                        <input type="hidden" name="redirect_to" value="{{ app.request.requestUri }}" />
                        <button class="dropdown-item" type="submit">
                            {{ 'updates.subscription.addSubmit'|trans }}
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>

        {% if image %}
            <div class="magazine-hero__cover">
                <img src="{{ image }}" alt="{{ title }}" class="magazine-hero__cover-img">
            </div>
        {% endif %}

        <section class="d-flex gap-3 center ln-section--newsstand mb-3">
            <div class="container mt-5">
                <h1>{{ title }}</h1>
                {% if description %}
                    <p class="eyebrow">{{ description }}</p>
                {% endif %}
                <div>
                    {{ 'followPackView.by'|trans }}
                    <twig:Molecules:UserFromNpub :ident="authorNpub" />
                </div>
            </div>
        </section>
    </div>

    {# Articles from pack members #}
    <section class="w-container mb-5">
        {% if articles is empty %}
            <div class="alert alert-info">
                {{ 'followPackView.noArticles'|trans }}
            </div>
        {% else %}
            <twig:Organisms:CardList :list="articles" :authorsMetadata="authorsMetadata" class="article-list" />

            {% if pager is defined and pager.getNbPages() > 1 %}
                <twig:Atoms:Pagination :pager="pager" route="follow_pack_view" :routeParams="{npub: authorNpub, dtag: packDtag}" />
            {% endif %}
        {% endif %}
    </section>
{% endblock %}

{% block aside %}
    {# Pack members list — reuses FeaturedWriters styles #}
    <div class="featured-writers">
        <div class="d-flex gap-3 center mt-3 mb-3 ln-section--reader">
            <h2 class="mb-4">{{ 'followPackView.members'|trans }}</h2>
        </div>
        <ul class="featured-writers-list list-unstyled">
            {% for member in members %}
                <li class="featured-writer-item">
                    <a href="{{ path('author-profile', { npub: member.npub }) }}" class="featured-writer-link">
                        {% if member.picture %}
                            <img src="{{ member.picture }}"
                                 alt="{{ member.displayName|default(member.name)|default('Writer') }}"
                                 class="featured-writer-avatar"
                                 loading="lazy"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                            <span class="featured-writer-avatar-placeholder" style="display: none;">
                                <twig:ux:icon name="iconoir:user" class="icon" />
                            </span>
                        {% else %}
                            <span class="featured-writer-avatar-placeholder">
                                <twig:ux:icon name="iconoir:user" class="icon" />
                            </span>
                        {% endif %}
                        <span class="featured-writer-info">
                            <span class="featured-writer-name">{{ member.displayName|default(member.name)|default('Anonymous') }}</span>
                            {% if member.nip05 %}
                                <span class="featured-writer-nip05">{{ member.nip05 is iterable ? member.nip05|first : member.nip05 }}</span>
                            {% endif %}
                        </span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </div>
{% endblock %}

