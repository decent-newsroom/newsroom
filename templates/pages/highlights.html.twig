{% extends 'layout.html.twig' %}

{% block ogtags %}
    {{ parent() }}
    <meta property="og:title" content="Highlights - Decent Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="Noteworthy passages highlighted by the community">
    <meta property="og:site_name" content="Newsroom">

    {# JSON-LD Structured Data for Highlights Page #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Highlights",
        "description": "Noteworthy passages highlighted by the community",
        "url": {{ app.request.uri|json_encode|raw }},
        "isPartOf": {
            "@type": "WebSite",
            "name": "Newsroom",
            "url": "{{ url('home') }}"
        }
    }
    </script>
{% endblock %}

{% block body %}
    <twig:Atoms:PageHeading
        heading="{{ 'highlights.heading'|trans }}"
        tagline="{{ 'highlights.tagline'|trans }}"
    />

    <div class="highlights-container w-container">
        {% if error is defined %}
            <div class="error-message">
                <p>{{ error }}</p>
            </div>
        {% endif %}

        {% if highlights|length > 0 %}
            <div class="highlights-stats hidden">
                <span><strong>{{ total }}</strong> highlights found</span>
                <span>From the last 90 days</span>
            </div>

            <div class="highlights-grid">
                {% for highlight in highlights %}
                    {% include 'partial/_highlight_feed_card.html.twig' with {highlight: highlight} %}
                {% endfor %}
            </div>
        {% else %}
            <div class="no-highlights">
                <p>{{ 'highlights.noHighlights'|trans }}</p>
            </div>
        {% endif %}
    </div>
{% endblock %}

