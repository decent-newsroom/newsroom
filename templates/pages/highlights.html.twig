{% extends 'layout.html.twig' %}

{% block ogtags %}
    {{ parent() }}
    <meta property="og:title" content="Highlights - Decent Newsroom">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:description" content="Noteworthy passages highlighted by the community">
    <meta property="og:site_name" content="Newsroom">

    {# JSON-LD Structured Data for Highlights Page #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Highlights",
        "description": "Noteworthy passages highlighted by the community",
        "url": {{ app.request.uri|json_encode|raw }},
        "isPartOf": {
            "@type": "WebSite",
            "name": "Newsroom",
            "url": "{{ url('home') }}"
        }
    }
    </script>
{% endblock %}

{% block body %}
    <twig:Atoms:PageHeading
        heading="{{ 'highlights.heading'|trans }}"
        tagline="{{ 'highlights.tagline'|trans }}"
    />

    <div class="highlights-container w-container">
        {% if error is defined %}
            <div class="error-message">
                <p>{{ error }}</p>
            </div>
        {% endif %}

        {% include 'partial/_highlights_feed.html.twig' with {highlights: highlights} only %}
    </div>
{% endblock %}

