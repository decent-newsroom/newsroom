{% extends 'layout.html.twig' %}

{% import 'macros/jsonld.html.twig' as jsonld %}

{% block ogtags %}
    {{ parent() }}
    <meta property="og:title" content="{{ article.title }}">
    <meta property="og:type" content="article">
    <meta property="og:url" content="{{ canonical }}">
    {% if article.image %}
        <meta property="og:image" content="{{ article.image }}">
    {% endif %}
    <meta property="og:description" content="{{ article.summary|striptags|u.truncate(159,'…')|e }}">
    <meta property="og:site_name" content="Newsroom">

    {# BreadcrumbList for navigation #}
    {% set breadcrumbItems = [
        {"name": "Home", "url": url('home')},
        {"name": author.name ?? author.display_name ?? npub, "url": url('author-profile', {'npub': npub})},
        {"name": article.title, "url": canonical}
    ] %}
    <script type="application/ld+json">
    {{ jsonld.breadcrumbs(breadcrumbItems)|raw }}
    </script>

    {# JSON-LD Structured Data for Article #}
    <script type="application/ld+json">
    {{ jsonld.article(article, author, npub, canonical)|raw }}
    </script>
{% endblock %}

{% block body %}
    {% if magazine is defined %}
        <twig:Organisms:MagazineHero :mag="mag" :magazine="magazine"  />
    {% endif %}

    <article class="w-container"
             data-controller="ui--highlights-toggle{% if app.user and not (isDraft is defined and isDraft) %} nostr--nostr-highlight{% endif %}"
             {% if app.user and not (isDraft is defined and isDraft) %}
             data-nostr--nostr-highlight-publish-url-value="{{ path('highlight_publish') }}"
             data-nostr--nostr-highlight-csrf-token-value="{{ csrf_token('highlight_publish') }}"
             data-nostr--nostr-highlight-coordinate-value="30023:{{ article.pubkey }}:{{ article.slug }}"
             data-nostr--nostr-highlight-author-pubkey-value="{{ article.pubkey }}"
             {% endif %}
    >
        {% if isDraft is defined and isDraft %}
            <div class="alert alert-info" role="alert">
                <strong>{{ 'article.draftPreview'|trans }}:</strong> {{ 'article.draftPreviewHint'|trans }}
            </div>
        {% endif %}

        {# Post-publish: suggest writing a kind 1 note about the article #}
        {% for flashData in app.flashes('article_published') %}
            {% set pubData = flashData|json_decode %}
            {% if pubData and pubData.slug == article.slug %}
                <div data-controller="nostr--nostr-suggest-note"
                     data-nostr--nostr-suggest-note-title-value="{{ pubData.title }}"
                     data-nostr--nostr-suggest-note-slug-value="{{ pubData.slug }}"
                     data-nostr--nostr-suggest-note-pubkey-value="{{ pubData.pubkey }}"
                     data-nostr--nostr-suggest-note-publish-url-value="{{ path('api_note_publish') }}">

                    {# Banner #}
                    <div class="notice info suggest-note-banner"
                         data-nostr--nostr-suggest-note-target="banner">
                        <p>
                            🎉 {{ 'article.publishedSuccess'|trans|default('Your article was published!') }}
                            <button class="btn btn-primary btn-sm"
                                    type="button"
                                    data-action="nostr--nostr-suggest-note#openDialog">
                                {{ 'article.suggestNote'|trans|default('Announce it with a note') }}
                            </button>
                            <button class="btn btn-link btn-sm"
                                    type="button"
                                    data-action="nostr--nostr-suggest-note#dismiss">
                                {{ 'common.dismiss'|trans|default('Dismiss') }}
                            </button>
                        </p>
                    </div>

                    {# Modal dialog — reuses .iu-backdrop / .iu-modal from modal.css #}
                    <div class="iu-backdrop"
                         data-nostr--nostr-suggest-note-target="dialog"
                         style="display:none;"
                         data-action="click->nostr--nostr-suggest-note#closeDialog">
                        <div class="iu-modal" data-action="click->nostr--nostr-suggest-note#stopPropagation">
                            <div class="modal-header">
                                <h5>{{ 'article.announceNote'|trans|default('Announce your article') }}</h5>
                                <button class="close" type="button"
                                        data-action="nostr--nostr-suggest-note#closeDialog">&times;</button>
                            </div>
                            <div class="modal-body">
                                <p class="text-muted">{{ 'article.announceNoteHint'|trans|default('Write a short note to let people know about your new article. The link is included automatically.') }}</p>
                                <textarea data-nostr--nostr-suggest-note-target="textarea"
                                          class="form-control"
                                          rows="5"></textarea>
                                <div data-nostr--nostr-suggest-note-target="status"
                                     class="suggest-note__status"></div>
                            </div>
                            <div class="suggest-note__footer">
                                <button class="btn btn-secondary" type="button"
                                        data-action="nostr--nostr-suggest-note#closeDialog">
                                    {{ 'common.cancel'|trans|default('Cancel') }}
                                </button>
                                <button class="btn btn-primary" type="button"
                                        data-action="nostr--nostr-suggest-note#publishNote">
                                    {{ 'article.publishNote'|trans|default('Sign & Publish Note') }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}

        {% set articleCoordinate = '30023:' ~ article.pubkey ~ ':' ~ article.slug %}
        {% set isProtected = not (isDraft is defined and isDraft) ? article.isNip70Protected() : false %}
        {% set userRelays = null %}
        {% if app.user %}
            {% set relayData = app.user.relays %}
            {% set userRelays = relayData is not null and relayData.write is defined ? relayData.write : (relayData is not null and relayData.all is defined ? relayData.all : null) %}
        {% endif %}
        {% set recipientLud16 = author.lud16 is defined and author.lud16 ? (author.lud16 is iterable ? author.lud16|first : author.lud16) : null %}
        {% set recipientLud06 = author.lud06 is defined and author.lud06 ? (author.lud06 is iterable ? author.lud06|first : author.lud06) : null %}

        {% if isDraft is defined and isDraft %}
        <div class="article-actions">
            <a class="btn btn-primary" href="{{ path('editor-edit-slug-draft', {'slug': article.slug}) }}">{{ 'article.editDraft'|trans }}</a>
        </div>
        {% else %}
            <div class="article-actions"
                 data-ui--highlights-toggle-target="actionBar"
                 {% if not canEdit and not app.user %}data-highlights-only="true" hidden{% endif %}>
                {% if canEdit %}
                    <a class="btn btn-primary" href="{{ path('editor-edit-slug', {'slug': article.slug}) }}">{{ 'article.editArticle'|trans }}</a>
                {% endif %}

                {% if app.user %}
                    <twig:ReadingListDropdown :coordinate="articleCoordinate" />
                {% endif %}

                <button data-ui--highlights-toggle-target="button"
                        data-action="click->ui--highlights-toggle#toggle"
                        class="btn btn-secondary article-highlights-toggle"
                        type="button"
                        aria-pressed="false"
                        title="{{ 'articleActions.highlights'|trans }}"
                        hidden>
                    {{ ux_icon('iconoir:edit-pencil', {class: 'icon article-highlights-toggle__icon', 'aria-hidden': 'true'}) }}
                    <span>{{ 'articleActions.highlights'|trans }}</span>
                    <span class="article-highlights-toggle__count"
                          data-ui--highlights-toggle-target="count"
                          hidden></span>
                </button>
            </div>
        {% endif %}

        <div class="card heading">
            <div class="card-header">
                <h1 class="card-title">{{ article.title }}</h1>
            </div>
            {% if author %}
                <div class="byline">
                    <span>
                        {{ 'text.byline'|trans }} <a href="{{ path('author-redirect', {'pubkey': article.pubkey}) }}">
                            <twig:Atoms:NameOrNpub :author="author" :npub="npub" />
                        </a>
                    </span>
                    <span>
                        {% if article.publishedAt is not null %}
                            <small>{{ article.publishedAt|date('F j, Y') }}</small>
                            {% if article.createdAt is not null and article.publishedAt|date('U') != article.createdAt|date('U') %}
                                <small class="article-edited-note">· {{ 'text.edited'|trans }} {{ article.createdAt|date('F j, Y') }}</small>
                            {% endif %}
                        {% else %}
                            <small>{{ article.createdAt|date('F j, Y') }}</small>
                        {% endif %}
                    </span>
                </div>
            {% endif %}
            {% if isProtected %}
                <div class="article-protected-notice">
                    <span class="article-protected-badge" title="{{ 'articleActions.protectedNote'|trans }}">
                        {{ 'articleActions.protectedBadge'|trans }}
                    </span>
                </div>
            {% endif %}
        </div>
        <div class="card-body">
            <div class="lede"
                 data-controller="utility--katex"
                 data-utility--katex-display-value="false">
                {{ article.summary }}
            </div>

            {% if article.image %}
                <div class="article__image">
                    <img src="{{ article.image }}" alt="{{ article.title }}">
                </div>
            {% endif %}

            {% if article.raw is defined and article.raw.tags is defined and article.raw.tags|length > 0 %}
                {# Separate r and imeta tags #}
                {% set reference_tags = [] %}
                {% set media_tags = [] %}
                {% for tag in article.raw.tags %}
                    {% if tag[0] == 'r' %}
                        {% set reference_tags = reference_tags|merge([tag]) %}
                    {% elseif tag[0] == 'imeta' %}
                        {% set media_tags = media_tags|merge([tag]) %}
                    {% endif %}
                {% endfor %}
                {% if media_tags|length > 0 %}
                    <section class="article-media-section">
                        <ul class="media-list list-unstyled">
                            {% for tag in media_tags %}
                                {% set audio_url = null %}
                                {% for param in tag %}
                                    {% if param starts with 'url ' and (param ends with '.mp3' or 'audio' in param) %}
                                        {% set audio_url = param|replace({'url ': ''}) %}
                                    {% endif %}
                                {% endfor %}
                                {% if audio_url %}
                                    <li>
                                        <audio controls style="width:100%;">
                                            <source src="{{ audio_url }}" type="audio/mpeg">
                                            Your browser does not support the audio element.
                                        </audio>
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </section>
                {% endif %}
            {% endif %}

            <div class="article-main"
                 data-controller="utility--katex"
                 data-utility--katex-display-value="true">
                {{ content|resolve_nostr_embeds|raw }}
            </div>

            {% if article.raw is defined and article.raw.tags is defined and article.raw.tags|length > 0 %}
                {% if reference_tags|length > 0 %}
                    <section class="article-references-section p-0 my-5">
                        <ul class="reference-list list-unstyled">
                            {% for tag in reference_tags %}
                                {% if tag[1] is defined and not (tag[1] starts with 'ws://') and not (tag[1] starts with 'wss://') %}
                                    <li>
                                        {{ 'text.reference'|trans }}: <a href="{{ tag[1] }}" target="_blank" rel="noopener noreferrer">{{ tag[1] }}</a>
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </section>
                {% endif %}
            {% endif %}

            {% if article.topics|length > 0 %}
            <hr class="divider" />
            <div class="tags">
                {% for tag in article.topics %}
                    {% if tag is not empty %}
                    <a href="{{ path('forum_tag', {'tag': tag|url_encode}) }}" class="tag">#{{ tag }}</a>
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}

        </div>

        {% if is_granted('ROLE_ADMIN') %}
        <details class="my-3">
            <summary>Raw event</summary>
            <pre>{{ article.raw|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
        </details>
        {% endif %}

        {% if not (isDraft is defined and isDraft) %}
        <twig:Molecules:ArticleSocialActions
            :article="article"
            :coordinate="articleCoordinate"
            :canonicalUrl="canonical"
            :naddrEncoded="article|naddrEncode"
            :recipientLud16="recipientLud16"
            :recipientLud06="recipientLud06"
            :isProtected="isProtected"
            :relays="userRelays"
        />

        {% set articleRoot = {
            tag: 'A',
            value: articleCoordinate,
            relay: null,
            pubkey: article.pubkey,
            kind: 30023
        } %}
        <details id="article-comment-form" class="comment-form-toggle article-social-comment-form">
            <summary class="comment-form-toggle__cta">{{ 'comments.writeCta'|trans }}</summary>
            <twig:Organisms:CommentForm
                :publish_url="path('comment_publish')"
                :csrf_token="csrf_token('comment_publish')"
                :root_context="articleRoot"
                :parent_context="{
                    tag: 'a',
                    value: articleCoordinate,
                    relay: null,
                    pubkey: article.pubkey,
                    kind: 30023
                }" />
        </details>

        <turbo-frame id="article-comments"
                     src="{{ path('article-comments-frame', {npub: npub, slug: article.slug}) }}"
                     loading="lazy">
        </turbo-frame>
        {% endif %}

        {% if not (isDraft is defined and isDraft) %}
            <turbo-frame id="article-highlights"
                         src="{{ path('article-highlights-frame', {npub: npub, slug: article.slug}) }}">
            </turbo-frame>
        {% endif %}

        {# Prev/Next article navigation from reading list — lazy Turbo Frame #}
        {% if not (isDraft is defined and isDraft) %}
        <turbo-frame id="article-list-nav"
                     src="{{ path('article-list-nav-frame', {npub: npub, slug: article.slug}) }}"
                     loading="lazy"
                     target="_top"
        >
        </turbo-frame>
        {% endif %}
    </article>
    {% if article.topics|length > 0 and not (isDraft is defined and isDraft) %}
        <turbo-frame id="article-related-articles"
                     src="{{ path('article-related-frame', {npub: npub, slug: article.slug}) }}"
                     loading="lazy"
                     target="_top"
        >
        </turbo-frame>
    {% endif %}
{% endblock %}

{% block aside %}
    {% if not (isDraft is defined and isDraft) %}
        <turbo-frame id="article-publications"
                     src="{{ path('article-aside-frame', {npub: npub, slug: article.slug}) }}"
                     target="_top">
        </turbo-frame>
    {% endif %}
{% endblock %}
