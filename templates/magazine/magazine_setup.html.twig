{% extends 'layout.html.twig' %}

{% block body %}
    <twig:Atoms:PageHeading heading="Magazine Setup" tagline="Step 1: Define the basics of your magazine"/>

    {% include 'magazine/_wizard_steps.html.twig' with { currentStep: 1 } %}

    {# Login prompt #}
    {% if not isLoggedIn %}
        <div class="notice info mb-4">
            <p>You'll need a Nostr identity to publish your magazine.
        </div>
    {% endif %}

    {# Desktop device suggestion #}
    <div class="wizard-desktop-hint mb-3">
        <p>📐 For the best experience, we recommend using a desktop device to create your magazine.</p>
    </div>

    <div class="wizard-setup-layout"
         data-controller="ui--magazine-preview ui--wizard-autosave"
         data-ui--wizard-autosave-key-value="mag_wizard_setup">

        {# Autosave restore banner #}
        <div class="wizard-autosave-banner hidden" data-ui--wizard-autosave-target="banner"></div>

        {# Live preview — uses the real MagazineHero component in preview mode #}
        <div class="wizard-preview-hero" data-ui--magazine-preview-target="preview">
            <twig:Organisms:MagazineHero
                :preview="true"
                :previewTitle="draft.title ?: null"
                :previewSummary="draft.summary ?: null"
                :previewImageUrl="draft.imageUrl ?: null"
                :mag="draft.slug ?: 'preview'"
            />
        </div>

        <div class="wizard-setup-form">
            {{ form_start(form) }}

            {{ form_errors(form) }}

            {{ form_row(form.title) }}
            {{ form_row(form.summary) }}

            {# Image URL field with upload button #}
            {{ form_row(form.imageUrl) }}

            <div class="actions" data-controller="publishing--image-upload">
                <button type="button"
                        class="btn btn-secondary btn-sm"
                        data-action="click->publishing--image-upload#openDialog">
                    Upload Image
                </button>

                <div data-publishing--image-upload-target="dialog" class="iu-dialog">
                    <div class="iu-backdrop" data-action="click->publishing--image-upload#closeDialog"></div>
                    <div class="iu-modal">
                        <div class="modal-header">
                            <h5>Upload Image</h5>
                            <button type="button" class="close" data-action="click->publishing--image-upload#closeDialog">&times;</button>
                        </div>
                        <div class="modal-body">
                            <div>
                                <label for="upload-provider">Upload to</label>
                                <select id="upload-provider" data-publishing--image-upload-target="provider">
                                    <option value="sovbit">files.sovbit.host</option>
                                    <option value="nostrbuild">nostr.build</option>
                                    <option value="nostrcheck">nostrcheck.me</option>
                                    <option value="blossomband">blossom.band</option>
                                </select>
                            </div>
                            <div data-publishing--image-upload-target="dropArea" class="upload-area">
                                <span>Drag &amp; drop or click to select an image</span>
                                <input type="file" accept="image/*" data-publishing--image-upload-target="fileInput">
                            </div>
                            <div data-publishing--image-upload-target="progress" class="upload-progress"></div>
                            <div data-publishing--image-upload-target="error" class="upload-error"></div>
                        </div>
                    </div>
                </div>
            </div>

            {{ form_row(form.language, {row_attr: {class: 'hidden'}}) }}
            {{ form_row(form.tags) }}

            <div class="mt-3 d-flex flex-row gap-2 actions align-items-center">
                <a class="btn btn-secondary" href="{{ path('mag_wizard_cancel') }}" data-action="click->ui--wizard-autosave#clearAll">Cancel</a>
                <button class="btn btn-primary">Next: Categories →</button>
                <span class="wizard-autosave-status" data-ui--wizard-autosave-target="status"></span>
            </div>

            {{ form_end(form) }}
        </div>

    </div>

    {% if isNewDraft %}
    <script>
        // Starting a fresh wizard — clear any stale autosave snapshots
        ['mag_wizard_setup', 'mag_wizard_categories', 'mag_wizard_articles'].forEach(k => {
            try { localStorage.removeItem(k); } catch(e) {}
        });
    </script>
    {% endif %}
{% endblock %}
