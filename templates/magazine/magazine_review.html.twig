{% extends 'layout.html.twig' %}

{% block body %}
  <twig:Atoms:PageHeading heading="Review & Sign" tagline="Step 4: Review, sign and publish your magazine"/>

  {% include 'magazine/_wizard_steps.html.twig' with { currentStep: 4 } %}

  {% if not is_granted('ROLE_USER') %}
    <div class="notice warning mb-4">
      <p><strong>Login required:</strong> You need to <a href="{{ path('app_login') }}">log in</a> with your Nostr identity to sign and publish your magazine.</p>
    </div>
  {% endif %}

  <div class="notice info">
      <p class="mb-2">This is a preview of your magazine.</p>
      <p class="mb-2">Review the details below. You'll find the events also shown at the very bottom. When ready, click <code>Sign & Publish.</code></p>
      <p>You'll be prompted to sign any newly-created categories and the main magazine event.</p>
  </div>

    <div class="wizard-preview-hero">
      <twig:Organisms:MagazineHero
        :preview="true"
        :previewTitle="draft.title ?: null"
        :previewSummary="draft.summary ?: null"
        :previewImageUrl="draft.imageUrl ?: null"
        :mag="draft.slug ?: 'preview'"
      />
    </div>


  {% if draft.categories is defined and draft.categories|length %}
      <div class="w-container mb-3">
      {% for cat in draft.categories %}
          <div class="featured-cat mb-0"><small><b>{{ cat.title }}</b>{% if cat.summary %} &mdash; <em>{{ cat.summary }}</em>{% endif %}</small></div>

        {% if cat.articles is defined and cat.articles|length %}
          <div class="article-list p-2">
            {% for coordinate in cat.articles %}
              <twig:Organisms:ArticleFromCoordinate :coordinate="coordinate" />
            {% endfor %}
          </div>
        {% else %}
          <p class="text-muted ms-3">No articles in this category yet.</p>
        {% endif %}
    {% endfor %}
      </div>
  {% else %}
    <section class="mb-4">
      <p class="text-muted">No categories.</p>
    </section>
  {% endif %}

  <section class="mb-1 pb-1">
    <details>
      <summary>Show event previews (JSON)</summary>
      <div class="mt-2">
        <h3>Category events</h3>
        <pre class="small">{{ categoryEventsJson }}</pre>
        <h3>Magazine event</h3>
        <pre class="small">{{ magazineEventJson }}</pre>
      </div>
    </details>
  </section>

  <div
    {{ stimulus_controller('nostr--nostr-index-sign', {
      categoryEvents: categoryEventsJson,
      magazineEvent: magazineEventJson,
      publishUrl: path('api-index-publish'),
      csrfToken: csrfToken,
      redirectUrl: redirectUrl|default('')
    }) }}
  >
    <section class="mb-3">
      <h3>Final magazine event preview</h3>
      <pre class="small" data-nostr--nostr-index-sign-target="computedPreview"></pre>
    </section>

    <div class="d-flex flex-row gap-2 actions">
      <a class="btn btn-secondary" href="{{ path(backRoute) }}">← Back</a>
      <a class="btn btn-secondary" href="{{ path('mag_wizard_cancel') }}">Cancel</a>
      <button class="btn btn-primary" data-nostr--nostr-index-sign-target="publishButton" data-action="click->nostr--nostr-index-sign#signAndPublish">Sign & Publish</button>
    </div>

    <div class="mt-3" data-nostr--nostr-index-sign-target="status"></div>
  </div>
{% endblock %}
