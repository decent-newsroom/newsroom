{# Wizard progress indicator — shared across all magazine wizard steps #}
{% set allSteps = [
    { label: 'wizard.magazine'|trans, route: 'mag_wizard_setup' },
    { label: 'wizard.categories'|trans, route: 'mag_wizard_categories' },
    { label: 'wizard.articles'|trans, route: 'mag_wizard_articles' },
    { label: 'wizard.review'|trans, route: 'mag_wizard_review' },
] %}

{% if not (skipSubdomain|default(false)) %}
    {% set allSteps = allSteps|merge([{ label: 'wizard.subdomain'|trans, route: 'mag_wizard_subdomain' }]) %}
{% endif %}

{% set allSteps = allSteps|merge([{ label: 'wizard.done'|trans, route: 'mag_wizard_launched' }]) %}

<nav class="wizard-steps mb-4" aria-label="Wizard progress">
    <ol class="wizard-steps__list">
        {% for step in allSteps %}
            {% set stepNumber = loop.index %}
            {% set isCurrent = app.request.attributes.get('_route') == step.route %}
            {% set isComplete = currentStep is defined and stepNumber < currentStep %}
            <li class="wizard-steps__item{% if isCurrent %} wizard-steps__item--current{% endif %}{% if isComplete %} wizard-steps__item--complete{% endif %}">
                <span class="wizard-steps__number">{{ stepNumber }}</span>
                <span class="wizard-steps__label">{{ step.label }}</span>
            </li>
        {% endfor %}
    </ol>
</nav>
