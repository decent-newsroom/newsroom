{% extends 'layout.html.twig' %}

{% block title %}Sessions — {{ community.name }}{% endblock %}

{% block body %}
<div class="admin-dashboard">
    <h1>Sessions — {{ community.name }}</h1>

    <table class="admin-table">
        <thead><tr><th>User</th><th>Last Seen</th><th>Created</th><th>Expires</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        {% for session in sessions %}
            <tr>
                <td>{{ session.user.displayName }}</td>
                <td>{{ session.lastSeenAt|date('Y-m-d H:i') }}</td>
                <td>{{ session.createdAt|date('Y-m-d') }}</td>
                <td>{{ session.expiresAt|date('Y-m-d') }}</td>
                <td>{{ session.revokedAt ? 'Revoked' : (session.isValid ? 'Active' : 'Expired') }}</td>
                <td>
                    {% if session.isValid %}
                        <form method="post" action="{{ path('admin_chat_session_revoke', {communityId: community.id, sessionId: session.id}) }}" style="display:inline;">
                            <button type="submit" class="btn btn--small">Revoke</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('admin_chat_community_show', {id: community.id}) }}" class="btn">Back</a>
</div>
{% endblock %}

