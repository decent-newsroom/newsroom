{% extends 'layout.html.twig' %}

{% block title %}Members — {{ group.name }}{% endblock %}

{% block body %}
<div class="admin-dashboard">
    <h1>Members — {{ group.name }} ({{ community.name }})</h1>

    <table class="admin-table">
        <thead><tr><th>Name</th><th>Role</th><th>Joined</th></tr></thead>
        <tbody>
        {% for m in members %}
            <tr>
                <td>{{ m.user.displayName }}</td>
                <td>{{ m.role }}</td>
                <td>{{ m.joinedAt|date('Y-m-d') }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('admin_chat_groups', {communityId: community.id}) }}" class="btn">Back</a>
</div>
{% endblock %}

