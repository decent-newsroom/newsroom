{% extends 'base.html.twig' %}

{% block layout %}
    <div class="layout" data-controller="ui--sidebar-toggle">
        <div class="aside-wrapper">
            {# Newsroom local navigation #}
            <twig:SidebarNav
                :sections="newsroomNav"
                :backLink="{ label: 'nav.backToDiscover', route: 'discover' }"
                :footerComponent="'components/UserMenu.html.twig'"
            />
        </div>

        <main>
            {% block body %}{% endblock %}
        </main>

        <div>
            <aside id="rightNav">
                <header>
                    <button class="close" data-action="click->sidebar-toggle#close" aria-label="{{ 'nav.closeRightSidebar'|trans }}">✕</button>
                </header>
                {% block aside %}
                    {# Newsroom-specific right sidebar content can go here #}
                    {% if app.user %}
                        <div class="d-flex gap-3 center mt-3 mb-3 p-3 ln-section--newsroom">
                            <div class="text-center">{{ 'nav.publishYourContent'|trans }}</div>
                            <a class="btn" href="{{ path('editor-create') }}">{{ 'nav.createArticle'|trans }}</a>
                        </div>
                    {% else %}
                        <div class="mt-3 mb-3">
                            {% include 'blog-journey/_login_cta_card.html.twig' %}
                        </div>
                    {% endif %}
                {% endblock %}
            </aside>
        </div>

        {# Back to top button #}
        <div data-controller="ui--back-to-top">
            <button class="back-to-top-btn"
                    data-ui--back-to-top-target="button"
                    data-action="click->ui--back-to-top#scrollToTop"
                    aria-label="{{ 'nav.backToTop'|trans }}"
                    title="{{ 'nav.backToTop'|trans }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="18 15 12 9 6 15"></polyline>
                </svg>
            </button>
        </div>
    </div>
{% endblock %}

