{
    # To disable automatic HTTPS (e.g., behind a proxy), add to your .env:
    # CADDY_EXTRA_CONFIG="{ auto_https off }"
    {$CADDY_GLOBAL_OPTIONS}

    frankenphp {
        {$FRANKENPHP_CONFIG}
    }
}

{$CADDY_EXTRA_CONFIG}

# Main site block - handles main domain, relay subdomain, and Unfold subdomains
# Configure via environment variables:
#   SERVER_NAME - main site address (e.g., "example.com" or ":80" for catch-all behind proxy)
#   RELAY_DOMAIN - relay subdomain (e.g., "relay.example.com")
#
# For production behind a proxy:
#   - Set SERVER_NAME=:80 (accepts all traffic from proxy)
#   - Set RELAY_DOMAIN=relay.yourdomain.com
#   - Your proxy handles TLS and routes all domains/subdomains to this container
#   - Symfony's UnfoldRequestListener handles subdomain routing
#
# For standalone production (Caddy manages HTTPS):
#   - Set SERVER_NAME=yourdomain.com, *.yourdomain.com (must include wildcard for subdomains!)
#   - Set RELAY_DOMAIN=relay.yourdomain.com
#   - Symfony's UnfoldRequestListener handles subdomain routing
#
# ⚠️  IMPORTANT: If you set SERVER_NAME to a specific domain without a wildcard,
#     subdomain requests (e.g., support.yourdomain.com) will NOT match this block
#     and Caddy will return 502. Either:
#     a) Use :80 behind a proxy (recommended), or
#     b) Include both the domain AND wildcard: yourdomain.com, *.yourdomain.com
#
# For local development:
#   - Set SERVER_NAME=localhost,*.localhost (matches both main and subdomains)
#   - Set RELAY_DOMAIN=relay.localhost
#   - Symfony's UnfoldRequestListener handles subdomain routing
{$SERVER_NAME:localhost,*.localhost} {
	log {
		{$CADDY_SERVER_LOG_OPTIONS}
		# Redact the authorization query parameter that can be set by Mercure
		format filter {
			request>uri query {
				replace authorization REDACTED
			}
		}
	}


        # Nostr relay WebSocket proxy
        # When behind a reverse proxy that might rewrite Host headers, also match X-Forwarded-Host
        @relay {
            host {$RELAY_DOMAIN:relay.localhost}
        }
        @relayForwarded {
            header X-Forwarded-Host {$RELAY_DOMAIN:relay.localhost}
        }
        handle @relay {
                encode zstd gzip
                reverse_proxy strfry:7777
        }
        handle @relayForwarded {
                encode zstd gzip
                reverse_proxy strfry:7777
        }

        # Essayist writer-first relay WebSocket proxy
        # Production: essayist.decentnewsroom.com  →  essayist-gateway:7780  →  strfry-essayist:7779
        # The gateway enforces NIP-42 AUTH + ROLE_ESSAYIST_MEMBER on every connection.
        # Activated only when the `essayist` Docker profile is running.
        # Configure: ESSAYIST_RELAY_DOMAIN=essayist.decentnewsroom.com
        #
        # When behind a reverse proxy, match on X-Forwarded-Host (if present) as well as Host
        # to handle proxies that rewrite the Host header.
        @essayistRelay {
            host {$ESSAYIST_RELAY_DOMAIN:essayist.localhost}
        }
        @essayistRelayForwarded {
            header X-Forwarded-Host {$ESSAYIST_RELAY_DOMAIN:essayist.localhost}
        }
        handle @essayistRelay {
                encode zstd gzip
                reverse_proxy essayist-gateway:7780
        }
        handle @essayistRelayForwarded {
                encode zstd gzip
                reverse_proxy essayist-gateway:7780
        }

	# ── Block scanner / attacker probe paths ─────────────────────────────────────
	# Caddy responds immediately with 404; PHP is never invoked, no Symfony routing,
	# no DB write, and no visit-tracking overhead.
	#
	# Covers:
	#   - Environment / secrets files  (.env, .env.local, .env.production, …)
	#   - VCS metadata dirs            (.git/*, .svn/*, .hg/*)
	#   - Apache / server config files (.htaccess, .htpasswd, web.config)
	#   - PHP info / install scripts   (phpinfo.php, info.php, install.php, setup.php, …)
	#   - Composer manifests           (composer.json, composer.lock)
	#   - WordPress probes             (wp-login.php, xmlrpc.php, wp-admin/*, …)
	#   - Common admin tools           (adminer.php, phpmyadmin/*)
	#   - Spring Boot actuator         (/actuator/*)
	#
	# Uses `handle @blockProbes` so Caddy's subroute ordering guarantees this
	# fires BEFORE the catch-all `handle {}` block below.
	@blockProbes path_regexp blockProbes ^/(\.env.*|\.git(/.*)?|\.svn(/.*)?|\.hg(/.*)?|\.htaccess|\.htpasswd|web\.config|phpinfo\.php|info\.php|install\.php|setup\.php|config\.php|admin\.php|composer\.(json|lock)|wp-login\.php|xmlrpc\.php|wp-admin(/.*)?|wp-content(/.*)?|wp-includes(/.*)?|wlwmanifest\.xml|adminer\.php|phpmyadmin(/.*)?|actuator(/.*)?)(\/.*)?$
	handle @blockProbes {
		respond 404
	}

	# Main application (handles both main site and Unfold subdomains via Symfony routing)
	handle {

		root /app/public
		# gzip only — zstd and brotli are CPU-heavy (brotli is 5-10× slower).
		# If behind a reverse proxy, the proxy should handle compression instead.
		# Exclude Mercure SSE paths — gzip buffering breaks streaming responses
		# and causes EventSource connections to cycle every few seconds.
		@notSse {
			not path /.well-known/mercure*
		}
		encode @notSse gzip

		mercure {
			transport bolt {
				path /data/mercure.db
				size 100000
				cleanup_frequency 0.5
			}

			# JWT key for both publisher and subscriber
			publisher_jwt {env.MERCURE_JWT_SECRET}
			subscriber_jwt {env.MERCURE_JWT_SECRET}

			anonymous
			subscriptions
			cors_origins {$MERCURE_CORS_ORIGINS:*}

			# Keep SSE connections alive through proxies and Docker networking.
			# Without this, idle connections are closed before the default 40s
			# heartbeat fires, causing visible reconnect cycling in browsers.
			heartbeat_interval 15s

			{$MERCURE_EXTRA_DIRECTIVES}
		}

		# vulcain disabled — generates huge Link preload headers that can
		# exceed upstream proxy header-buffer limits (→ 502).
		# vulcain

		{$CADDY_SERVER_EXTRA_DIRECTIVES}

		# Disable Topics tracking if not enabled explicitly: https://github.com/jkarlin/topics
		header ?Permissions-Policy "browsing-topics=()"
		# Diagnostic: if a 502 response does NOT have this header, the proxy generated it
		header X-Served-By "frankenphp"
		# Strip Link preload headers — they can exceed proxy header-buffer limits (→ 502).
		# Assets are already referenced in HTML via <link> and importmap tags.
		header -Link


		@phpRoute {
			not path /.well-known/mercure*
			not file {path}
		}
		rewrite @phpRoute index.php

		@frontController path index.php
		php @frontController

		# Cache fingerprinted assets (AssetMapper generates unique filenames on change)
		@staticAssets path /assets/* /bundles/*
		header @staticAssets Cache-Control "public, max-age=31536000, immutable"

		file_server
	}

	# Prevent any CDN, proxy or browser from caching error responses.
	# Without this, a transient 502 can be served to users long after the origin recovers.
	handle_errors {
		header Cache-Control "no-store"
	}
}

# Configuration Examples:
#
# Production behind external proxy (proxy handles TLS) — RECOMMENDED:
#   SERVER_NAME=:80
#   CADDY_GLOBAL_OPTIONS=auto_https off
#   RELAY_DOMAIN=relay.yourdomain.com
#   External proxy routes all domains/subdomains → this container on port 80
#
# Standalone production (Caddy manages HTTPS with Let's Encrypt):
#   SERVER_NAME=yourdomain.com, *.yourdomain.com
#   RELAY_DOMAIN=relay.yourdomain.com
#   Caddy automatically obtains TLS certificates for domain + all subdomains
#
# Local development:
#   SERVER_NAME=localhost,*.localhost
#   RELAY_DOMAIN=relay.localhost
#   Handles both main site and Unfold subdomains locally
